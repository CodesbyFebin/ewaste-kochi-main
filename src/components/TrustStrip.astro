---
const certifications = [
  { name: "KSPCB Authorized", icon: "🏛️", desc: "KL/EW/628" },
  { name: "NIST 800-88", icon: "🔒", desc: "Certified" },
  { name: "DoD 5220.22-M", icon: "🛡️", desc: "Standard" },
  { name: "DPDP Act", icon: "⚖️", desc: "2023 Compliant" },
  { name: "EPR Authorized", icon: "📜", desc: "Form-6 Issuer" },
  { name: "ISO 27001", icon: "✅", desc: "Ready" }
];
---

<section class="trust-strip" aria-label="Certifications">
  <div class="trust-container">
    {certifications.map((cert) => (
      <div class="trust-item">
        <span class="trust-icon">{cert.icon}</span>
        <div class="trust-info">
          <div class="trust-name">{cert.name}</div>
          <div class="trust-desc">{cert.desc}</div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .trust-strip {
    background: rgba(11, 15, 20, 0.5);
    border-top: 1px solid rgba(34, 197, 94, 0.1);
    border-bottom: 1px solid rgba(34, 197, 94, 0.1);
    padding: 1.8rem 0;
    backdrop-filter: blur(10px);
  }

  .trust-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    gap: 2.5rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .trust-icon {
    font-size: 1.5rem;
    filter: drop-shadow(0 0 8px rgba(0, 208, 132, 0.3));
  }

  .trust-info {
    display: flex;
    flex-direction: column;
  }

  .trust-name {
    font-family: 'Syne', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #dff0e4;
    letter-spacing: 0.05em;
  }

  .trust-desc {
    font-size: 10.5px;
    color: #7da686;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .trust-container {
      padding: 0 1.2rem;
      gap: 1.5rem;
    }
    .trust-strip {
      padding: 1.2rem 0;
    }
  }
</style>
