---
const steps = [
  { number: "01", icon: "📋", title: "Asset Audit", description: "Full inventory with serial numbers, condition assessment, and data risk classification." },
  { number: "02", icon: "🔒", title: "Data Destruction", description: "NIST 800-88 wipe or physical shredding. Certificate of Destruction per device." },
  { number: "03", icon: "💰", title: "Value Recovery", description: "Functional assets remarketed. You receive buyback value minus service fees." },
  { number: "04", icon: "♻️", title: "Certified Recycling", description: "Non-recoverable assets processed per KSPCB guidelines with EPR certificates." },
  { number: "05", icon: "📄", title: "Full Documentation", description: "CoD, EPR, Form-6, weight manifest and chain-of-custody delivered within 48 hours." }
];
---

<section class="process-section" id="process" aria-labelledby="process-title">
  <div class="container">
    <span class="section-label">Our Process</span>
    <h2 class="section-title" id="process-title">5-Step ITAD Lifecycle</h2>
    <p class="section-subtitle">
      From pickup to certificate — every step documented, compliant, and audit-ready.
    </p>
    
    <div class="process-grid">
      {steps.map((step, index) => (
        <div class="process-card glass-card">
          <div class="process-number">{step.number}</div>
          <div class="process-icon">{step.icon}</div>
          <h3 class="process-title">{step.title}</h3>
          <p class="process-description">{step.description}</p>
          {index < steps.length - 1 && <div class="process-arrow">→</div>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    padding: 5rem 0;
    background: rgba(15, 23, 32, 0.5);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #22c55e;
    margin-bottom: 0.9rem;
  }

  .section-label::before {
    content: '';
    width: 22px;
    height: 2px;
    background: #22c55e;
  }

  .section-title {
    font-family: 'Syne', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(1.75rem, 3.8vw, 2.7rem);
    font-weight: 700;
    line-height: 1.13;
    letter-spacing: -1px;
    margin-bottom: 0.7rem;
    color: #dff0e4;
  }

  .section-subtitle {
    color: #7da686;
    font-size: 1rem;
    max-width: 620px;
    margin-bottom: 2.8rem;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(195px, 1fr));
    gap: 0.875rem;
    position: relative;
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 14px;
    padding: 1.4rem;
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.55);
    transition: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: center;
    position: relative;
  }

  .glass-card:hover {
    transform: translateY(-2px);
    border-color: rgba(34, 197, 94, 0.32);
    box-shadow: 0 8px 24px rgba(34, 197, 94, 0.15);
  }

  .process-number {
    font-family: 'Syne', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 2.8rem;
    font-weight: 800;
    color: #22c55e;
    opacity: 0.13;
    line-height: 1;
    margin-bottom: 0.4375rem;
  }

  .process-icon {
    font-size: 1.8rem;
    margin-bottom: 0.5625rem;
  }

  .process-title {
    font-family: 'Syne', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.3125rem;
    color: #dff0e4;
  }

  .process-description {
    font-size: 11.5px;
    color: #7da686;
    line-height: 1.6;
  }

  .process-arrow {
    position: absolute;
    right: -1.25rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    color: #22c55e;
    opacity: 0.5;
  }

  @media (max-width: 640px) {
    .container {
      padding: 0 1.2rem;
    }
    .process-section {
      padding: 3.2rem 0;
    }
    .process-grid {
      grid-template-columns: 1fr 1fr;
    }
    .process-arrow {
      display: none;
    }
  }
</style>
