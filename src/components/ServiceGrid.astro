---
interface Service {
  icon: string;
  title: string;
  description: string;
  price: string;
  link: string;
}

const services: Service[] = [
  {
    icon: "🚛",
    title: "Free E-Waste Pickup Kochi",
    description: "Same-day corporate pickup across all Kochi business districts. Free for 10+ units. Certificate of Collection within 2 hours.",
    price: "Free for 10+ units · ₹299 single item",
    link: "/free-e-waste-pickup-kochi/"
  },
  {
    icon: "💻",
    title: "Laptop Buyback Kochi",
    description: "Up to ₹65,000 for MacBook Pro M2. All brands, all conditions. Transparent price matrix. Instant WhatsApp quote.",
    price: "Up to ₹65,000 · All brands accepted",
    link: "/laptop-buyback-kochi/"
  },
  {
    icon: "🔒",
    title: "NIST Data Destruction Kerala",
    description: "NIST 800-88 & DoD 5220.22-M certified. Certificate of Destruction per device. DPDP Act 2023 compliant.",
    price: "₹299/device · Bulk pricing available",
    link: "/nist-data-destruction-kerala/"
  },
  {
    icon: "📋",
    title: "ITAD Services Kochi",
    description: "Full IT Asset Disposition lifecycle. Audit → Destroy → Remarket → Recycle. Complete chain of custody.",
    price: "Custom quote · Enterprise contracts",
    link: "/itad-services-kochi/"
  },
  {
    icon: "📜",
    title: "EPR Compliance Certificates",
    description: "Extended Producer Responsibility under E-Waste Rules 2022. Form-6 manifest generation included automatically.",
    price: "₹2,500/tonne · Annual contracts",
    link: "/epr-compliance-certificates-kochi/"
  },
  {
    icon: "🔋",
    title: "Battery Recycling Kochi",
    description: "Lithium-ion, lead-acid, NiMH battery disposal. KSPCB-authorized hazardous waste management facility.",
    price: "₹8/kg lead-acid · ₹25/kg lithium",
    link: "/battery-recycling-kochi/"
  }
];
---

<section class="services-section" id="services" aria-labelledby="services-title">
  <div class="container">
    <span class="section-label">Our Services</span>
    <h2 class="section-title" id="services-title">Complete E-Waste & ITAD Solutions in Kerala</h2>
    <p class="section-subtitle">
      From a single broken laptop to a full data-centre decommission — every step handled with certified compliance documentation and zero data risk.
    </p>
    
    <div class="services-grid">
      {services.map((service) => (
        <a href={service.link} class="service-card glass-card">
          <div class="service-icon">{service.icon}</div>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-description">{service.description}</p>
          <div class="service-price">{service.price}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 5rem 0;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #22c55e;
    margin-bottom: 0.9rem;
  }

  .section-label::before {
    content: '';
    width: 22px;
    height: 2px;
    background: #22c55e;
  }

  .section-title {
    font-family: 'Syne', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(1.75rem, 3.8vw, 2.7rem);
    font-weight: 700;
    line-height: 1.13;
    letter-spacing: -1px;
    margin-bottom: 0.7rem;
    color: #dff0e4;
  }

  .section-subtitle {
    color: #7da686;
    font-size: 1rem;
    max-width: 620px;
    margin-bottom: 2.8rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 0.875rem;
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 14px;
    padding: 1.4rem;
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.55);
    transition: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: inherit;
  }

  .glass-card:hover {
    transform: translateY(-2px);
    border-color: rgba(34, 197, 94, 0.32);
    box-shadow: 0 8px 24px rgba(34, 197, 94, 0.15);
  }

  .service-icon {
    font-size: 1.9rem;
    margin-bottom: 0.6875rem;
  }

  .service-title {
    font-family: 'Syne', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.98rem;
    font-weight: 700;
    margin-bottom: 0.4375rem;
    color: #dff0e4;
  }

  .service-description {
    font-size: 12.5px;
    color: #7da686;
    line-height: 1.6;
    margin-bottom: 0.625rem;
  }

  .service-price {
    font-size: 11.5px;
    color: #22c55e;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .container {
      padding: 0 1.2rem;
    }
    .services-section {
      padding: 3.2rem 0;
    }
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
