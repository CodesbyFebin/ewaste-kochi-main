---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PeopleAlsoAskEngine from '../utils/peopleAlsoAskEngine.js';

interface Props {
  post: CollectionEntry<'blog'>;
  relatedPosts?: CollectionEntry<'blog'>[];
  tableOfContents?: TOCItem[];
}

interface TOCItem {
  id: string;
  title: string;
  level: number;
}

const { post, relatedPosts = [], tableOfContents = [] } = Astro.props;
const { Content } = await post.render();

// Initialize People Also Ask engine
const paaEngine = new PeopleAlsoAskEngine();

// Generate People Also Ask questions
const clusterName = post.data.cluster || 'general';
const paaQuestions = paaEngine.generatePeopleAlsoAsk(
  post.data.content || '', 
  clusterName, 
  post.data.title
);

// Generate PAA schema
const paaSchema = paaEngine.generatePAASchema(paaQuestions);

// Generate content freshness timestamp
const lastmod = post.data.lastmod ? new Date(post.data.lastmod) : new Date();
const isRecentlyUpdated = (Date.now() - lastmod.getTime()) < (30 * 24 * 60 * 60 * 1000); // Within 30 days

// Clean title to remove trailing location slugs (fixes "Vyttila 2026 Vyttila" bug)
const cleanTitle = post.data.title.replace(/\s+(in|at|near|for)\s+[\w-]+$/gi, '');

// Helper functions for enhanced article layout
function getCategoryGradient(category) {
  const gradients = {
    'compliance': 'linear-gradient(135deg,#0a1f2e,#0d3b55)',
    'legal': 'linear-gradient(135deg,#0a1f2e,#0d3b55)',
    'how-to': 'linear-gradient(135deg,#0a1f0d,#0d3b1a)',
    'comparison': 'linear-gradient(135deg,#1f1a0a,#3b2e0d)',
    'pricing': 'linear-gradient(135deg,#1f0a0a,#3b1a0d)',
    'itad': 'linear-gradient(135deg,#1a0a1f,#2e0d3b)',
    'data-destruction': 'linear-gradient(135deg,#1a0a0a,#3b0d0d)',
    'battery-recycling': 'linear-gradient(135deg,#1f1f0a,#3b2e0d)',
    'locations': 'linear-gradient(135deg,#0a1f1a,#0d3b30)',
    'default': 'linear-gradient(135deg,#0a1f1a,#0d3b30)'
  };
  return gradients[category] || gradients['default'];
}

function getCategoryEmoji(category) {
  const emojis = {
    'compliance': '⚖️',
    'legal': '⚖️',
    'how-to': '📋',
    'comparison': '⚖️',
    'pricing': '💰',
    'itad': '🏢',
    'data-destruction': '🔐',
    'battery-recycling': '🔋',
    'locations': '📍',
    'default': '♻️'
  };
  return emojis[category] || emojis['default'];
}

function getServiceName(service) {
  const serviceNames = {
    'e-waste-recycling': 'e-waste recycling',
    'itad': 'ITAD',
    'data-destruction': 'data destruction',
    'laptop-buyback': 'laptop buyback',
    'battery-recycling': 'battery recycling',
    'default': 'e-waste services'
  };
  return serviceNames[service] || serviceNames['default'];
}

function getLocationName(location) {
  const locationNames = {
    'kakkanad': 'Kakkanad',
    'infopark': 'Infopark',
    'smart-city': 'Smart City',
    'edappally': 'Edappally',
    'thrippunithura': 'Thrippunithura',
    'vytilla': 'Vyttila',
    'aluva': 'Aluva',
    'mg-road': 'MG Road',
    'fort-kochi': 'Fort Kochi',
    'kalamassery': 'Kalamassery',
    'default': 'Kochi'
  };
  return locationNames[location] || locationNames['default'];
}

// Generate enhanced schema for blog posts
const schema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": cleanTitle,
  "description": post.data.description,
  "author": {
    "@type": "Organization",
    "name": "EWaste Kochi Editorial Team",
    "@id": "https://ewastekochi.com/#organization"
  },
  "publisher": {
    "@id": "https://ewastekochi.com/#organization"
  },
  "datePublished": post.data.published ? post.data.published.toISOString() : new Date().toISOString(),
  "dateModified": lastmod.toISOString(),
  "articleSection": post.data.category || "E-Waste Management",
  "inLanguage": "en-IN",
  "about": {
    "@type": "Service",
    "name": post.data.service || "E-Waste Recycling",
    "areaServed": post.data.location || "Kochi"
  },
  "mainEntityOfPage": `https://www.ewastekochi.com/blog/${post.slug}/`,
  "breadcrumbList": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.ewastekochi.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "https://www.ewastekochi.com/blog/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": post.data.title,
        "item": `https://www.ewastekochi.com/blog/${post.slug}/`
      }
    ]
  },
  "hasPart": [
    {
      "@type": "FAQPage",
      "mainEntity": {
        "@type": "FAQ",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We provide detailed certificates of data destruction and recycling for your records and compliance."
        },
        "suggestedAnswer": {
          "@type": "Answer",
          "text": "Yes, we are KSPCB authorized and follow NIST 800-88 standards for data destruction and environmental compliance."
        }
      }
    }
  ]
};

// Generate breadcrumbs
const breadcrumbs = [
  { name: "Home", url: "https://www.ewastekochi.com/" },
  { name: "Blog", url: "https://www.ewastekochi.com/blog/" },
  { name: post.data.title, url: `https://www.ewastekochi.com/blog/${post.slug}/` }
];

// Generate internal links based on content
const generateInternalLinks = (content: string) => {
  const links = [
    {
      keyword: "e-waste pickup",
      url: "/services/free-ewaste-pickup-kochi/",
      text: "free e-waste pickup service"
    },
    {
      keyword: "data destruction",
      url: "/services/data-destruction-kochi/", 
      text: "certified data destruction"
    },
    {
      keyword: "laptop recycling",
      url: "/services/laptop-recycling-kochi/",
      text: "professional laptop recycling"
    },
    {
      keyword: "sell laptop",
      url: "/buyback/dell-laptop-kochi/",
      text: "sell your laptop"
    },
    {
      keyword: "KSPCB",
      url: "/blog/dpdp-act-2023-it-disposal-compliance/",
      text: "KSPCB compliance"
    }
  ];

  let processedContent = content;
  links.forEach(link => {
    const regex = new RegExp(`\\b${link.keyword}\\b`, 'gi');
    processedContent = processedContent.replace(regex, `[${link.text}](${link.url})`);
  });

  return processedContent;
};

// Generate conversion-focused CTAs
const generateCTAs = (content: string, category: string) => {
  const ctas = {
    'guides': [
      {
        title: "Ready to Start Recycling?",
        text: "Schedule free pickup for your e-waste",
        url: "/contact/",
        type: "primary"
      },
      {
        title: "Need Professional Help?",
        text: "Get expert consultation for your business",
        url: "/services/corporate-e-waste-pickup-kochi/",
        type: "secondary"
      }
    ],
    'comparisons': [
      {
        title: "Make the Right Choice",
        text: "Get personalized recommendation for your e-waste",
        url: "/contact/",
        type: "primary"
      },
      {
        title: "Compare All Services",
        text: "View our complete service comparison",
        url: "/services/",
        type: "secondary"
      }
    ],
    'pricing': [
      {
        title: "Get Best Price",
        text: "Instant quote for your electronic items",
        url: "/buyback/dell-laptop-kochi/",
        type: "primary"
      },
      {
        title: "Business Pricing",
        text: "Special rates for bulk disposal",
        url: "/services/bulk-it-asset-disposal-kochi/",
        type: "secondary"
      }
    ]
  };

  return ctas[category as keyof typeof ctas] || ctas['guides'];
};

// Generate FAQ section
const generateFAQ = (content: string) => {
  const faqs = [
    {
      question: "How quickly can you pick up my e-waste in Kochi?",
      answer: "We offer same-day pickup service across Kochi. Schedule your pickup and we'll collect within 4 hours."
    },
    {
      question: "Is your e-waste recycling certified?",
      answer: "Yes, we are KSPCB authorized and follow NIST 800-88 standards for data destruction and environmental compliance."
    },
    {
      question: "Do you provide data destruction certificates?",
      answer: "Absolutely! We provide detailed certificates of data destruction and recycling for your records and compliance."
    }
  ];

  return faqs;
};
---

<BaseLayout 
  title={post.data.title}
  description={post.data.description}
  canonical={post.data.canonical}
  schema={schema}
>
  <div class="article-layout">
    <!-- LEFT COLUMN - Main Content -->
    <main class="article-main">
      <!-- Breadcrumb Navigation -->
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <a href="/">Home</a> &gt; <a href="/blog/">Blog</a> &gt; <span>{post.data.category || 'Article'}</span> &gt; <span>{cleanTitle}</span>
      </nav>

      <!-- Article Header -->
      <header class="article-header">
        <!-- Category & Type Badges -->
        <div class="article-badges">
          <span class="category-badge">{post.data.category || 'Guide'}</span>
          <span class="type-badge">{post.data.topic || 'How-To'}</span>
        </div>
        
        <!-- Conversational H1 -->
        <h1 class="article-title">{cleanTitle}</h1>
        
        <!-- Author Block -->
        <div class="author-block">
          <div class="author-avatar">EK</div>
          <div class="author-info">
            <div class="author-name">EWaste Kochi Editorial Team</div>
            <div class="author-cred">KSPCB Authorized · Est. 2018</div>
          </div>
          <div class="author-meta">
            <time datetime={post.data.published ? post.data.published.toISOString() : new Date().toISOString()}>
              {post.data.published ? post.data.published.toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
              }) : new Date().toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
              })}
            </time>
            <span class="read-time">{post.data.wordCount ? Math.ceil(post.data.wordCount / 180) : 15} min read</span>
          </div>
        </div>

        <!-- Social Share -->
        <div class="social-share">
          <button class="share-btn" onclick="copyLink()" title="Copy link">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M10 13a5 5 0 0 0-5 5v1a1 1 0 0 1-1h10a1 1 0 0 1 1v-1a1 1 0 0 1-1h-10a1 1 0 0-1 1z"/>
              <path d="M8 8v-2a2 2 0 0 1-2h6a2 2 0 0 1 2v2a2 2 0 0 1-2h-6a2 2 0 0-1 2z"/>
            </svg>
          </button>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://ewastekochi.com/blog/${post.slug}/`)}&title=${encodeURIComponent(cleanTitle)}`} 
             class="share-btn" target="_blank" title="Share on LinkedIn">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-16.894L6.756 8.938v-2.828a.5.5.5 0 0 1 1h4.444a.5.5.5 0 0 1-1v4.444a.5.5.5 0 0 1-1h-4.444a.5.5.5 0 0 1 1zm-3.5 6.5a1.5 1.5 0 0 3 0h4a1.5 1.5 0 0 1.5v4a1.5 1.5 0 0 1.5h-4a1.5 1.5 0 0-1.5z"/>
              <path d="M19.5 7.5a1.5 1.5 0 0 1.5v6a1.5 1.5 0 0-1.5h-9a1.5 1.5 0 0-1.5v-6a1.5 1.5 0 0 1.5z"/>
            </svg>
          </a>
          <a href={`https://wa.me/917500555454?text=${encodeURIComponent(`Check out this article: ${cleanTitle}`)}`} 
             class="share-btn" target="_blank" title="Share on WhatsApp">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.093-.459-.232-.67-.141l.831-2.515c-.215-.68-.534-1.236-.534-1.236 0-.697.382-1.236h-2.492c-.665 0-1.208.487-1.236h-2.492c-.376.743-.209 1.236h1.587l.673-1.534c.096-.297.262-.23.465-.23-.67.141-.831-2.515c-.215-.68-.534-1.236-.534-1.236 0-.697.382-1.236z"/>
              <path d="M12 0C5.373 0 0 5.373 0s5.373 4.958 0 8.473c0 1.657.358 3.158 1.089.535 1.089 0 1.657.358 3.158 1.089.535 1.089 0 1.657.358 3.158zm0 22c-6.627 0-12 5.373-12 5.373 0 6.627 0 12 5.373 0 12 6.627zm0 22a9 9 0 1 9 0 4 0 4 0 9 0 4 0zm0 22a9 9 0 1 9 0 4 0 4 0 9 0 4z"/>
            </svg>
          </a>
        </div>
      </header>

      <!-- Article Hero Image Zone -->
      <div class="article-hero" style={`background: ${getCategoryGradient(post.data.category || 'default')}`}>
        <span class="hero-emoji">{getCategoryEmoji(post.data.category || 'default')}</span>
      </div>

      <!-- Table of Contents -->
      {tableOfContents.length > 0 && (
        <nav class="table-of-contents sticky-toc" aria-label="Table of Contents">
          <h2>In this guide:</h2>
          <ol>
            {tableOfContents.map(item => (
              <li style={`margin-left: ${(item.level - 1) * 20}px`}>
                <a href={`#${item.id}`}>{item.title}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <!-- Article Body -->
      <div class="article-body">
        <Content />
        
        <!-- Service CTA Boxes (after every 3rd H2) -->
        <div class="service-cta-inserts" id="service-cta-inserts"></div>
      </div>

      <!-- Bottom of Article -->
      <section class="article-footer">
        <!-- Final CTA Block -->
        <div class="final-cta">
          <h3>Ready to recycle {getServiceName(post.data.service)} in {getLocationName(post.data.location)}?</h3>
          <p>Free pickup · Certificate of Destruction · Same-day available</p>
          <div class="cta-buttons">
            <a href="tel:+917500555454" class="cta-btn primary">
              📞 Book Free Pickup
            </a>
            <a href="https://wa.me/917500555454" class="cta-btn secondary">
              💬 WhatsApp +91 75005 55454
            </a>
          </div>
        </div>

        <!-- Share Buttons -->
        <div class="share-section">
          <h4>Share this guide</h4>
          <div class="share-buttons">
            <button class="share-btn" onclick="copyLink()">🔗 Copy Link</button>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://ewastekochi.com/blog/${post.slug}/`)}&title=${encodeURIComponent(cleanTitle)}`} 
               class="share-btn" target="_blank">LinkedIn</a>
            <a href={`https://wa.me/917500555454?text=${encodeURIComponent(`Check out this article: ${cleanTitle}`)}`} 
               class="share-btn" target="_blank">WhatsApp</a>
          </div>
        </div>

        <!-- Feedback -->
        <div class="helpful-feedback">
          <h4>Was this helpful?</h4>
          <div class="feedback-buttons">
            <button class="feedback-btn" onclick="markHelpful(true)">👍 Yes</button>
            <button class="feedback-btn" onclick="markHelpful(false)">👎 No</button>
          </div>
        </div>
      </section>
    </main>

    <!-- RIGHT COLUMN - Sticky Sidebar -->
    <aside class="article-sidebar">
      <!-- Quick Contact Card -->
      <div class="sidebar-card contact-card">
        <h3>Need help in {getLocationName(post.data.location)}?</h3>
        <div class="contact-info">
          <a href="tel:+917500555454" class="contact-item">
            📞 +91 75005 55454
          </a>
          <a href="https://wa.me/917500555454" class="contact-item">
            💬 WhatsApp
          </a>
        </div>
        <a href="/contact/" class="sidebar-cta">
          Book Free Pickup →
        </a>
      </div>

      <!-- Table of Contents (Sticky) -->
      {tableOfContents.length > 0 && (
        <div class="sidebar-card toc-card">
          <h3>Table of Contents</h3>
          <ol class="sidebar-toc">
            {tableOfContents.map(item => (
              <li style={`margin-left: ${(item.level - 1) * 15}px`}>
                <a href={`#${item.id}`}>{item.title}</a>
              </li>
            ))}
          </ol>
        </div>
      )}

      <!-- Related Articles -->
      {relatedPosts.length > 0 && (
        <div class="sidebar-card related-card">
          <h3>Related Articles</h3>
          <div class="related-articles">
            {relatedPosts.slice(0, 3).map(relatedPost => (
              <article class="related-article">
                <div class="related-thumbnail" style={`background: ${getCategoryGradient(relatedPost.data.category || 'default')}`}>
                  <span class="related-emoji">{getCategoryEmoji(relatedPost.data.category || 'default')}</span>
                </div>
                <div class="related-content">
                  <h4><a href={`/blog/${relatedPost.slug}/`}>{relatedPost.data.title}</a></h4>
                  <time>{relatedPost.data.published ? relatedPost.data.published.toLocaleDateString() : new Date().toLocaleDateString()}</time>
                  <span class="related-read-time">{Math.ceil((relatedPost.data.wordCount || 1500) / 180)} min read</span>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}

      <!-- Certification Badges -->
      <div class="sidebar-card certification-card">
        <h3>Certifications</h3>
        <div class="cert-badges">
          <div class="cert-badge">
            <div class="cert-icon">🏢</div>
            <div class="cert-info">
              <strong>KSPCB</strong><br>
              KL/EW/628
            </div>
          </div>
          <div class="cert-badge">
            <div class="cert-icon">🔐</div>
            <div class="cert-info">
              <strong>NIST 800-88</strong><br>
              Data Destruction
            </div>
          </div>
          <div class="cert-badge">
            <div class="cert-icon">🛡️</div>
            <div class="cert-info">
              <strong>DPDP 2023</strong><br>
              Data Protection
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>

    <!-- People Also Ask Section -->
    <section class="people-also-ask" id="people-also-ask">
      <h2>People Also Ask</h2>
      <div class="paa-container">
        {paaQuestions.map((q, index) => (
          <div class="paa-item" data-paa-id={`${post.slug}-${index}`}>
            <details class="paa-question" open={index === 0}>
              <summary class="paa-trigger">
                <span class="paa-question-text">{q.question}</span>
                <span class="paa-icon">+</span>
              </summary>
              <div class="paa-answer">
                <p>{q.answer}</p>
                <div class="paa-actions">
                  <a href="/contact/" class="paa-cta">Get Help</a>
                  <button class="paa-helpful" data-question={q.question}>Helpful</button>
                </div>
              </div>
            </details>
          </div>
        ))}
      </div>
    </section>

    <!-- PAA Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(paaSchema)} />

    <!-- Conversion CTAs -->
    <section class="blog-ctas">
      {generateCTAs(post.data.content || '', post.data.category || 'guides').map(cta => (
        <div class={`cta-card cta-${cta.type}`}>
          <h3>{cta.title}</h3>
          <p>{cta.text}</p>
          <a href={cta.url} class={`btn btn-${cta.type}`}>
            {cta.type === 'primary' ? 'Get Started' : 'Learn More'}
          </a>
        </div>
      ))}
    </section>

    <!-- FAQ Section -->
    <section class="blog-faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {generateFAQ(post.data.content || '').map((faq, index) => (
          <details class="faq-item" open={index === 0}>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="related-posts">
        <h2>Related Articles</h2>
        <div class="related-grid">
          {relatedPosts.map(relatedPost => (
            <article class="related-card">
              <a href={`/blog/${relatedPost.slug}/`}>
                <h3>{relatedPost.data.title}</h3>
                <p>{relatedPost.data.description}</p>
                <time datetime={relatedPost.data.published ? relatedPost.data.published.toISOString() : new Date().toISOString()}>
                  {relatedPost.data.published ? relatedPost.data.published.toLocaleDateString() : new Date().toLocaleDateString()}
                </time>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Internal Links Section -->
    <section class="internal-links">
      <h2>Explore Our Services</h2>
      <div class="links-grid">
        <a href="/services/free-ewaste-pickup-kochi/" class="service-link">
          <h3>Free E-Waste Pickup</h3>
          <p>Same-day pickup service across Kochi</p>
        </a>
        <a href="/services/data-destruction-kochi/" class="service-link">
          <h3>Data Destruction</h3>
          <p>Certified secure data destruction</p>
        </a>
        <a href="/buyback/dell-laptop-kochi/" class="service-link">
          <h3>Sell Your Laptop</h3>
          <p>Best prices for used laptops</p>
        </a>
      </div>
    </section>
  </article>

  <!-- Blog Styles -->
  <style>
    .blog-post {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem;
    }

    /* Breadcrumb Navigation */
    .breadcrumb-nav {
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      color: #666;
    }
    .breadcrumb-nav a {
      color: #3182ce;
      text-decoration: none;
    }
    .breadcrumb-nav a:hover {
      text-decoration: underline;
    }

    /* Author Block */
    .author-block {
      display: flex;
      gap: 1rem;
      align-items: center;
      margin-bottom: 2rem;
      padding: 1.5rem;
      background: linear-gradient(135deg, #f8fafc, #e2e8f0);
      border-radius: 12px;
      border: 1px solid #e2e8f0;
    }

    .author-avatar {
      width: 48px;
      height: 48px;
      background: linear-gradient(135deg, #00ff88, #00d084);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #000;
      font-size: 1.2rem;
    }

    .author-info {
      flex: 1;
    }

    .author-name {
      font-weight: 600;
      color: #1a202c;
      font-size: 1.1rem;
    }

    .author-cred {
      font-size: 0.9rem;
      color: #666;
      margin-top: 0.25rem;
    }

    .author-meta {
      margin-top: 0.5rem;
      font-size: 0.85rem;
      color: #666;
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    /* Article Badges */
    .article-badges {
