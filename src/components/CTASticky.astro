---
interface Props {
  title?: string;
  subtitle?: string;
  primaryCTA?: string;
  secondaryCTA?: string;
  primaryLink?: string;
  secondaryLink?: string;
  phone?: string;
  whatsapp?: string;
}

const {
  title = "Get Free Pickup Today",
  subtitle = "Free corporate pickup · Certificate of Destruction · Same-day available",
  primaryCTA = "📞 Call Now",
  secondaryCTA = "💬 WhatsApp",
  primaryLink = "tel:+917500555454",
  secondaryLink = "https://wa.me/917500555454",
  phone = "+91 75005 55454",
  whatsapp = "917500555454"
} = Astro.props;
---

<section class="cta-sticky-section" aria-label="Call to action">
  <div class="cta-container glass-card">
    <div class="cta-glow" aria-hidden="true"></div>
    <h3 class="cta-title">{title}</h3>
    <p class="cta-subtitle">{subtitle}</p>
    <div class="cta-buttons">
      <a href={primaryLink} class="btn btn-primary">
        {primaryCTA}
      </a>
      <a href={secondaryLink} class="btn btn-secondary" target="_blank" rel="noopener">
        {secondaryCTA}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-sticky-section {
    padding: 3.5rem 0;
    position: relative;
    overflow: hidden;
  }

  .cta-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3.5rem;
    text-align: center;
    position: relative;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.07) 0%, transparent 55%);
    border: 1px solid rgba(34, 197, 94, 0.13);
  }

  .cta-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(34, 197, 94, 0.09) 0%, transparent 70%);
    pointer-events: none;
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.55);
  }

  .cta-title {
    font-family: 'Syne', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(1.75rem, 3.8vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -1px;
    margin-bottom: 0.875rem;
    color: #dff0e4;
  }

  .cta-subtitle {
    color: #7da686;
    margin-bottom: 1.8rem;
    font-size: 1rem;
  }

  .cta-buttons {
    display: flex;
    gap: 0.625rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    padding: 0.75rem 1.5rem;
    border-radius: 9px;
    font-size: 13.5px;
    font-weight: 700;
    border: none;
    transition: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .btn-primary {
    background: #22c55e;
    color: #fff;
    box-shadow: 0 3px 18px rgba(34, 197, 94, 0.28);
  }

  .btn-primary:hover {
    background: #16a34a;
    transform: translateY(-2px);
    box-shadow: 0 7px 26px rgba(34, 197, 94, 0.38);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.04);
    color: #7da686;
    border: 1.5px solid rgba(34, 197, 94, 0.13);
  }

  .btn-secondary:hover {
    color: #22c55e;
    border-color: rgba(34, 197, 94, 0.32);
    background: rgba(34, 197, 94, 0.1);
  }

  @media (max-width: 640px) {
    .cta-container {
      padding: 2.2rem 1.3rem;
      margin: 0 1.2rem;
    }
    .cta-sticky-section {
      padding: 2rem 0;
    }
  }
</style>
