---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "E-Waste & ITAD Knowledge Base | EWaste Kochi Blog";
const description = "1,000+ expert guides on e-waste recycling, ITAD services, data destruction, and compliance for Kerala businesses. Updated weekly with practical how-tos and regulatory insights.";

// Import blog data from content collection
const allBlogs = [
  {
    title: "Best Way to Battery Recycle in Vyttila",
    slug: "best-way-to-battery-recycle-in-vyttila-2026-vyttila",
    publishDate: "2026-04-21",
    service: "battery-recycling",
    location: "vyttila",
    category: "how-to",
    description: "Complete guide to proper battery disposal and recycling in Vyttila. Learn about collection points, pricing, and environmental compliance.",
    wordCount: 1850,
    priority: 0.9
  },
  {
    title: "Compliance Guide for E-Waste Collection in Vyttila",
    slug: "compliance-guide-for-e-waste-collection-in-vyttila-vyttila",
    publishDate: "2026-04-21",
    service: "e-waste-collection",
    location: "vyttila",
    category: "legal",
    description: "Navigate KSPCB regulations and legal requirements for e-waste disposal in Vyttila. Essential reading for businesses.",
    wordCount: 2200,
    priority: 0.85
  },
  {
    title: "Best Data Destruction Providers in Angamaly: Comparison",
    slug: "best-data-destruction-providers-in-angamaly-comparison-angamaly-2",
    publishDate: "2026-04-20",
    service: "data-destruction",
    location: "angamaly",
    category: "comparison",
    description: "Detailed comparison of NIST 800-88 certified data destruction services in Angamaly. Pricing, features, and reliability analysis.",
    wordCount: 1950,
    priority: 0.8
  },
  {
    title: "Economic Benefits of Cable Recycling in Thrippunithura",
    slug: "economic-benefits-of-cable-recycling-in-thrippunithura-thrippunithura-1",
    publishDate: "2026-04-20",
    service: "cable-recycling",
    location: "thrippunithura",
    category: "benefits",
    description: "Discover how cable recycling saves money and protects the environment. ROI analysis for businesses in Thrippunithura.",
    wordCount: 1600,
    priority: 0.75
  },
  {
    title: "E-Waste Laws in Kochi: Complete Guide",
    slug: "e-waste-laws-in-kochi-complete-guide-kochi-4",
    publishDate: "2026-04-20",
    service: "monitor-recycling",
    location: "kochi",
    category: "legal",
    description: "Comprehensive overview of e-waste regulations in Kochi. DPDP Act 2023, KSPCB guidelines, and compliance requirements.",
    wordCount: 2400,
    priority: 0.8
  },
  {
    title: "Best Way to Cable Recycle in Vyttila",
    slug: "best-way-to-cable-recycle-in-vyttila-2026-vyttila",
    publishDate: "2026-04-19",
    service: "cable-recycling",
    location: "vyttila",
    category: "how-to",
    description: "Step-by-step guide to cable recycling in Vyttila. From pickup scheduling to certificate issuance.",
    wordCount: 1750,
    priority: 0.75
  },
  {
    title: "Data Destruction Problems in Edappally: Solutions",
    slug: "data-destruction-problems-in-edappally-solutions-edappally-1",
    publishDate: "2026-04-19",
    service: "data-destruction",
    location: "edappally",
    category: "troubleshooting",
    description: "Common data destruction challenges and practical solutions for Edappally businesses. Expert troubleshooting tips.",
    wordCount: 1650,
    priority: 0.7
  },
  {
    title: "Best Way to E-Waste Collection in Ernakulam",
    slug: "best-way-to-e-waste-collection-in-ernakulam-2026-ernakulam",
    publishDate: "2026-04-19",
    service: "e-waste-collection",
    location: "ernakulam",
    category: "how-to",
    description: "Master e-waste collection in Ernakulam. Free pickup scheduling, sorting guides, and compliance documentation.",
    wordCount: 1900,
    priority: 0.75
  },
  {
    title: "Complete Guide to IT Asset Disposition in Vyttila",
    slug: "complete-guide-to-it-asset-disposition-in-vyttila-vyttila",
    publishDate: "2026-04-18",
    service: "itad",
    location: "vyttila",
    category: "how-to",
    description: "Enterprise ITAD services in Vyttila. Inventory audit, data sanitization, and value recovery for business assets.",
    wordCount: 2100,
    priority: 0.85
  },
  {
    title: "Common E-Waste Collection Issues in Vyttila",
    slug: "common-e-waste-collection-issues-in-vyttila-vyttila-1",
    publishDate: "2026-04-18",
    service: "e-waste-collection",
    location: "vyttila",
    category: "troubleshooting",
    description: "Troubleshoot common e-waste collection problems in Vyttila. Quick fixes and professional support options.",
    wordCount: 1550,
    priority: 0.7
  },
  {
    title: "Best Battery Recycling Providers in North Paravur",
    slug: "best-battery-recycling-providers-in-north-paravur-comparison-north-paravur",
    publishDate: "2026-04-17",
    service: "battery-recycling",
    location: "north-paravur",
    category: "comparison",
    description: "Compare top battery recycling services in North Paravur. Pricing transparency and service quality analysis.",
    wordCount: 1800,
    priority: 0.75
  },
  {
    title: "Printer Recycling Prices in Ernakulam 2026",
    slug: "printer-recycling-prices-in-ernakulam-2026-ernakulam-2",
    publishDate: "2026-04-17",
    service: "printer-recycling",
    location: "ernakulam",
    category: "pricing",
    description: "Current printer recycling rates in Ernakulam. Get the best value for your office equipment with our pricing guide.",
    wordCount: 1700,
    priority: 0.8
  }
];

// Featured article - highest priority
const featuredArticle = allBlogs.reduce((prev, current) => (prev.priority > current.priority) ? prev : current);

// Recent articles (excluding featured)
const recentArticles = allBlogs.filter(blog => blog.slug !== featuredArticle.slug).slice(0, 12);

// Statistics
const totalArticles = 1247;
const totalCategories = 12;
const totalLocations = 569;

// Category data with counts
const categoryData = [
  { name: "Recycling Guides", slug: "recycling", emoji: "♻️", count: 312 },
  { name: "Data Destruction", slug: "data-destruction", emoji: "🔐", count: 198 },
  { name: "ITAD & Compliance", slug: "itad", emoji: "🏢", count: 145 },
  { name: "Battery Recycling", slug: "battery-recycling", emoji: "🔋", count: 87 },
  { name: "Laptop & Devices", slug: "laptop-buyback", emoji: "💻", count: 134 },
  { name: "E-Waste Laws", slug: "legal", emoji: "📋", count: 76 },
  { name: "Pricing & Buyback", slug: "pricing", emoji: "💰", count: 68 },
  { name: "Location Guides", slug: "locations", emoji: "📍", count: 569 }
];

// Filter categories for chips
const filterCategories = [
  { id: "all", label: "All" },
  { id: "how-to", label: "How-To" },
  { id: "legal", label: "Compliance" },
  { id: "itad", label: "ITAD" },
  { id: "data-destruction", label: "Data Destruction" },
  { id: "battery-recycling", label: "Battery" },
  { id: "pricing", label: "Pricing" },
  { id: "comparison", label: "Comparison" }
];

// Helper functions
function getCategoryGradient(category) {
  const gradients = {
    "how-to": "linear-gradient(135deg, #0a1f0d, #0d3b1a)",
    "legal": "linear-gradient(135deg, #0a1f2e, #0d3b55)",
    "comparison": "linear-gradient(135deg, #1f1a0a, #3b2e0d)",
    "pricing": "linear-gradient(135deg, #1f0a0a, #3b1a0d)",
    "itad": "linear-gradient(135deg, #1a0a1f, #2e0d3b)",
    "data-destruction": "linear-gradient(135deg, #1a0a0a, #3b0d0d)",
    "battery-recycling": "linear-gradient(135deg, #1f1f0a, #3b2e0d)",
    "benefits": "linear-gradient(135deg, #0a1f1a, #0d3b30)",
    "troubleshooting": "linear-gradient(135deg, #1a1a1a, #2d2d2d)",
    "default": "linear-gradient(135deg, #0a1f1a, #0d3b30)"
  };
  return gradients[category] || gradients["default"];
}

function getCategoryEmoji(category) {
  const emojis = {
    "how-to": "📋",
    "legal": "⚖️",
    "comparison": "⚖️",
    "pricing": "💰",
    "itad": "🏢",
    "data-destruction": "🔐",
    "battery-recycling": "🔋",
    "benefits": "✨",
    "troubleshooting": "🔧",
    "default": "♻️"
  };
  return emojis[category] || emojis["default"];
}

function formatDate(dateString) {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function calculateReadTime(wordCount) {
  return Math.ceil(wordCount / 180);
}

function truncateText(text, maxLength) {
  if (text.length <= maxLength) return text;
  return text.substring(0, maxLength).trim() + '...';
}

// Generate CollectionPage schema
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "EWaste Kochi Blog - E-Waste & ITAD Knowledge Base",
  "description": "1,000+ expert guides on e-waste recycling, ITAD services, and compliance for Kerala businesses.",
  "url": "https://ewastekochi.com/blog/",
  "inLanguage": "en-IN",
  "isPartOf": {
    "@id": "https://ewastekochi.com/#website"
  },
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": allBlogs.slice(0, 12).map((blog, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "BlogPosting",
        "headline": blog.title,
        "url": `https://ewastekochi.com/blog/${blog.slug}/`,
        "datePublished": blog.publishDate,
        "author": {
          "@type": "Organization",
          "name": "EWaste Kochi Editorial Team"
        }
      }
    }))
  }
};
---

<BaseLayout title={title} description={description}>
  {/* Schema JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <div class="blog-index">
    {/* SECTION 1 — BLOG HERO */}
    <section class="blog-hero">
      <div class="hero-container">
        {/* Left Column - 60% */}
        <div class="hero-left">
          {/* Breadcrumb */}
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="separator">›</span>
            <span>Blog</span>
          </nav>

          {/* Section Label */}
          <div class="section-label">1,000+ Expert Guides</div>

          {/* H1 */}
          <h1 class="hero-title">E-Waste & ITAD Knowledge Base</h1>

          {/* Subheading */}
          <p class="hero-subtitle">
            Compliance guides, recycling how-tos, and ITAD resources for Kerala businesses. Updated weekly.
          </p>

          {/* Stat Strip */}
          <div class="stat-strip">
            <div class="stat-item">
              <span class="stat-number">{totalArticles.toLocaleString()}+</span>
              <span class="stat-label">Articles</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">{totalCategories}</span>
              <span class="stat-label">Categories</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">{totalLocations}</span>
              <span class="stat-label">Locations</span>
            </div>
          </div>
        </div>

        {/* Right Column - 40% */}
        <div class="hero-right">
          {/* Search Bar */}
          <div class="search-container">
            <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>
            <input 
              type="text" 
              id="search-input"
              class="search-input" 
              placeholder="Search articles, locations, topics..."
              aria-label="Search articles"
            />
          </div>

          {/* Category Filter Chips */}
          <div class="filter-chips" role="group" aria-label="Filter by category">
            {filterCategories.map((cat, index) => (
              <button 
                class={`filter-chip ${index === 0 ? 'active' : ''}`}
                data-category={cat.id}
                onclick={`filterByCategory('${cat.id}')`}
              >
                {cat.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* SECTION 2 — FEATURED ARTICLE */}
    <section class="featured-section">
      <article class="featured-card" data-category={featuredArticle.category}>
        {/* Left - 55% Image Zone */}
        <div 
          class="featured-image" 
          style={`background: ${getCategoryGradient(featuredArticle.category)}`}
        >
          <span class="featured-badge">Featured</span>
          <span class="featured-emoji">{getCategoryEmoji(featuredArticle.category)}</span>
        </div>

        {/* Right - 45% Article Info */}
        <div class="featured-content">
          <span class="category-tag">{featuredArticle.category}</span>
          
          <h2 class="featured-title">{featuredArticle.title}</h2>
          
          <p class="featured-excerpt">
            {truncateText(featuredArticle.description, 120)}
          </p>
          
          <div class="featured-author">
            <div class="author-avatar-small">EK</div>
            <span class="author-text">EWaste Kochi Editorial</span>
            <span class="meta-separator">·</span>
            <time>{formatDate(featuredArticle.publishDate)}</time>
            <span class="meta-separator">·</span>
            <span>{calculateReadTime(featuredArticle.wordCount)} min read</span>
          </div>
          
          <a href={`/blog/${featuredArticle.slug}/`} class="featured-cta">
            Read Full Guide →
          </a>
        </div>
      </article>
    </section>

    {/* SECTION 3 — RECENT ARTICLES GRID */}
    <section class="articles-section">
      <div class="section-header">
        <h2 class="section-heading">Latest Guides</h2>
        <a href="/blog/archives/" class="view-all-link">
          View all archives →
        </a>
      </div>

      <div class="articles-grid" id="articles-grid">
        {recentArticles.map((article, index) => (
          <article 
            class="article-card" 
            data-category={article.category}
            data-title={article.title.toLowerCase()}
            style={`display: ${index < 12 ? 'flex' : 'none'}`}
          >
            {/* Image Placeholder */}
            <div 
              class="card-image" 
              style={`background: ${getCategoryGradient(article.category)}`}
            >
              <span class="card-emoji">{getCategoryEmoji(article.category)}</span>
            </div>

            {/* Card Body */}
            <div class="card-body">
              <div class="card-meta-top">
                <span class="card-category">{article.category}</span>
                <span class="card-type">{article.service}</span>
              </div>

              <h3 class="card-title">
                <a href={`/blog/${article.slug}/`} aria-label={`Read ${article.title}`}>
                  {article.title}
                </a>
              </h3>

              <p class="card-excerpt">
                {truncateText(article.description, 100)}
              </p>

              <div class="card-meta-bottom">
                <time>📅 {formatDate(article.publishDate)}</time>
                <span>·</span>
                <span>⏱ {calculateReadTime(article.wordCount)} min</span>
              </div>

              <a href={`/blog/${article.slug}/`} class="card-cta">
                Read More →
              </a>
            </div>
          </article>
        ))}
      </div>

      {/* Pagination / Load More */}
      <div class="pagination">
        <button class="load-more-btn" id="load-more" onclick="loadMoreArticles()">
          Load More Articles
        </button>
        <span class="results-count" id="results-count">
          Showing 12 of {totalArticles}+ articles
        </span>
      </div>
    </section>

    {/* SECTION 4 — CATEGORY EXPLORER */}
    <section class="category-section">
      <h2 class="section-heading">Browse by Topic</h2>
      
      <div class="category-grid">
        {categoryData.map((cat) => (
          <a href={`/blog/category-${cat.slug}/`} class="category-card">
            <span class="category-emoji">{cat.emoji}</span>
            <h3 class="category-name">{cat.name}</h3>
            <span class="category-count">{cat.count} articles</span>
            <span class="category-link">Explore →</span>
          </a>
        ))}
      </div>
    </section>

    {/* SECTION 5 — SIDEBAR CTA STRIP */}
    <section class="cta-strip">
      <div class="cta-content">
        <p class="cta-text">Need help with e-waste disposal in Kerala?</p>
        <div class="cta-buttons">
          <a href="tel:+917500555454" class="cta-btn phone">
            📞 Call +91 75005 55454
          </a>
          <a href="https://wa.me/917500555454" class="cta-btn whatsapp">
            💬 WhatsApp Us
          </a>
        </div>
      </div>
    </section>
  </div>

  {/* Client-side JavaScript for Search and Filtering */}
  <script is:inline>
    // Article data for client-side filtering
    const articles = document.querySelectorAll('.article-card');
    const loadMoreBtn = document.getElementById('load-more');
    const resultsCount = document.getElementById('results-count');
    let visibleCount = 12;
    const totalCount = 1247;
    let currentFilter = 'all';
    let searchTerm = '';

    // Search functionality
    document.getElementById('search-input').addEventListener('input', function(e) {
      searchTerm = e.target.value.toLowerCase();
      filterArticles();
    });

    // Category filter
    function filterByCategory(category) {
      currentFilter = category;
      
      // Update active chip
      document.querySelectorAll('.filter-chip').forEach(chip => {
        chip.classList.remove('active');
        if (chip.dataset.category === category) {
          chip.classList.add('active');
        }
      });
      
      filterArticles();
    }

    // Combined filter function
    function filterArticles() {
      let visible = 0;
      let matching = 0;
      
      articles.forEach(article => {
        const matchesCategory = currentFilter === 'all' || article.dataset.category === currentFilter;
        const matchesSearch = !searchTerm || article.dataset.title.includes(searchTerm);
        
        if (matchesCategory && matchesSearch) {
          matching++;
          if (visible < visibleCount) {
            article.style.display = 'flex';
            visible++;
          } else {
            article.style.display = 'none';
          }
        } else {
          article.style.display = 'none';
        }
      });
      
      // Update results count
      resultsCount.textContent = `Showing ${visible} of ${matching}+ articles`;
      
      // Show/hide load more button
      if (visible >= matching || matching <= 12) {
        loadMoreBtn.style.display = 'none';
      } else {
        loadMoreBtn.style.display = 'inline-block';
      }
    }

    // Load more functionality
    function loadMoreArticles() {
      visibleCount += 12;
      filterArticles();
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
      filterArticles();
    });
  </script>

  {/* CSS Styles */}
  <style>
    /* CSS Variables */
    :root {
      --bg0: #0a0f0b;
      --bg1: #0d1410;
      --bg2: #121a15;
      --bg3: #1a231e;
      --green: #00ff88;
      --amber: #ffb347;
      --text1: #e4f0e7;
      --text2: #b8c4bb;
      --text3: #8a948d;
      --border: #1e2a24;
    }

    /* Main Container */
    .blog-index {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 1rem;
      background: var(--bg0);
      min-height: 100vh;
    }

    /* SECTION 1 — BLOG HERO */
    .blog-hero {
      padding: 5rem 0;
      background: linear-gradient(180deg, var(--bg0) 0%, var(--bg1) 100%);
      border-bottom: 1px solid var(--border);
    }

    .hero-container {
      display: grid;
      grid-template-columns: 60% 40%;
      gap: 3rem;
      max-width: 1200px;
      margin: 0 auto;
      align-items: start;
    }

    /* Hero Left */
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      color: var(--text3);
    }

    .breadcrumb a {
      color: var(--green);
      text-decoration: none;
    }

    .breadcrumb a:hover {
      text-decoration: underline;
    }

    .separator {
      color: var(--text3);
    }

    .section-label {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--amber);
      margin-bottom: 1rem;
    }

    .hero-title {
      font-size: 3rem;
      font-weight: 700;
      line-height: 1.1;
      color: var(--text1);
      margin-bottom: 1.5rem;
    }

    .hero-subtitle {
      font-size: 1.2rem;
      color: var(--text2);
      line-height: 1.6;
      margin-bottom: 2rem;
      max-width: 90%;
    }

    .stat-strip {
      display: flex;
      gap: 2rem;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
    }

    .stat-number {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--green);
    }

    .stat-label {
      font-size: 0.85rem;
      color: var(--text3);
    }

    /* Hero Right */
    .search-container {
      position: relative;
      margin-bottom: 1.5rem;
    }

    .search-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text3);
      pointer-events: none;
    }

    .search-input {
      width: 100%;
      padding: 1rem 1rem 1rem 3rem;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text1);
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    .search-input:focus {
      outline: none;
      border-color: var(--green);
      box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.1);
    }

    .search-input::placeholder {
      color: var(--text3);
    }

    .filter-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .filter-chip {
      padding: 0.5rem 1rem;
      background: transparent;
      border: 1px solid var(--green);
      border-radius: 20px;
      color: var(--green);
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .filter-chip:hover,
    .filter-chip.active {
      background: var(--green);
      color: var(--bg0);
    }

    /* SECTION 2 — FEATURED ARTICLE */
    .featured-section {
      padding: 4rem 0;
    }

    .featured-card {
      display: grid;
      grid-template-columns: 55% 45%;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.3s ease;
    }

    .featured-card:hover {
      border-color: var(--green);
      box-shadow: 0 0 30px rgba(0, 255, 136, 0.1);
    }

    .featured-image {
      height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .featured-badge {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
      background: var(--amber);
      color: var(--bg0);
      padding: 0.5rem 1rem;
      border-radius: 20px;
