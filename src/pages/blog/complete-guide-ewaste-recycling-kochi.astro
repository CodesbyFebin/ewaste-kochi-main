      <div class="community-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px">
        ${communityQAs.map((qa, i) => `
          <article style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px">
            <h4 style="font-size:0.95rem;color:var(--white);margin-bottom:10px">Q: ${qa.q}</h4>
            <p style="font-size:0.9rem;color:var(--text);line-height:1.7">A: ${qa.a}</p>
          </article>
        `).join('')}
      </div>
      <p style="text-align:center;margin-top:40px;color:var(--muted)">+ 200+ more community answers in our database. Have a question? <a href="https://wa.me/917500555454" target="_blank" rel="noreferrer noopener">Ask us on WhatsApp</a>.</p>
    </section>

    <div style="background:linear-gradient(135deg,var(--green),var(--green-dark));color:var(--white);border-radius:20px;padding:50px;text-align:center;margin:80px 0">
      <h2 style="font-size:2rem;margin-bottom:20px">Ready to Recycle or Sell Your E-Waste in Kochi?</h2>
      <p style="font-size:1.1rem;margin-bottom:30px;opacity:0.9">Get a free quote in 15 minutes. Free pickup for 10+ items. NIST-certified data destruction. Certificate of Destruction provided.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a href="https://wa.me/917500555454?text=Hi, I'd like to book e-waste pickup" class="btn" style="background:var(--white);color:var(--green);font-weight:800" target="_blank" rel="noreferrer noopener">💬 WhatsApp Now</a>
        <a href="/contact/" class="btn" style="background:transparent;border:2px solid var(--white);color:var(--white)">Get a Quote</a>
      </div>
    </div>

    <nav aria-label="Breadcrumb" style="font-size:.8rem;color:var(--muted);margin-top:60px;padding-top:30px;border-top:1px solid var(--border)">
      <a href="/" style="color:var(--green)">Home</a> › <a href="/blog/" style="color:var(--green)">Blog</a> › <span>E-Waste Recycling Complete Guide</span>
    </nav>
  </div>
`;

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'Blog', url: 'https://ewastekochi.com/blog/' },
  { name: 'Complete Guide to E-Waste Recycling', url: 'https://ewastekochi.com/blog/complete-guide-ewaste-recycling-kochi/' },
];

const articleSchema = {
  '@type': 'Article',
  headline: pageTitle,
  description: pageDesc,
  datePublished: '2026-04-20',
  author: { '@type': 'Organization', name: 'EWaste Kochi' },
  publisher: { '@id': 'https://ewastekochi.com/#organization' },
  keywords: ['ewaste recycling kochi', 'e-waste laws kerala', 'KSPCB recycling', 'e-waste guide kochi', 'complete guide e-waste'],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  schema={articleSchema}
  breadcrumbs={breadcrumbs}
  pageType="article"
  publishedTime="2026-04-20"
  keywords={['ewaste recycling kochi', 'e-waste guide kochi', 'KSPCB e-waste']}
>
  <Navbar currentPath="/blog/" />
  <main>
    <div set:html={content} />
  </main>
  <Footer />
</BaseLayout>

<style>
  .guide-container h2 { scroll-margin-top: 100px; }
  .guide-container ul, .guide-container ol { margin: 20px 0; padding-left: 30px; }
  .guide-container li { margin-bottom: 10px; }
  .guide-container table { width: 100%; border-collapse: collapse; margin: 30px 0; font-size: 0.9rem; }
  .guide-container th, .guide-container td { padding: 12px; border: 1px solid var(--border); text-align: left; }
  .guide-container th { background: rgba(0, 232, 150, 0.15); color: var(--green); }
  .guide-container tr:nth-child(even) { background: rgba(255,255,255,0.02); }
  .community-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 30px; }
