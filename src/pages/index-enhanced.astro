// Enhanced SEO metadata
const title = "EWaste Kochi — Kerala's #1 Authorized E-Waste & ITAD Platform | KSPCB Certified";
const description = "Free corporate e-waste pickup · NIST-certified data destruction · EPR compliance · Laptop buyback up to ₹65K. KSPCB Auth No. KL/EW/628. Serving Infopark, Smart City, MG Road.";
const canonical = "https://ewastekochi.com/";

// Additional structured data for better SEO
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "EWaste Kochi",
  "url": "https://ewastekochi.com",
  "logo": "https://ewastekochi.com/logo.png",
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+91-75005-55454",
    "contactType": "customer service",
    "availableLanguage": ["English", "Malayalam", "Hindi", "Tamil"]
  },
  "sameAs": [
    "https://www.linkedin.com/company/ewaste-kochi",
    "https://www.facebook.com/ewastekochi",
    "https://twitter.com/ewastekochi"
  ]
};
---

<BaseLayout 
  title={title}
  description={description}
  canonical={canonical}
  schema={[...schema, organizationSchema]}
  pageType="website"
  noindex={false}
>
  <!-- Critical CSS Inline -->
  <style>
    :root{--fd:'Syne',sans-serif;--fb:'Plus Jakarta Sans',sans-serif;--r:14px;--rs:9px;--t:0.28s cubic-bezier(0.4,0,0.2,1)}
    [data-theme="dark"]{--bg:#07090a;--bg2:#0e1214;--gl:rgba(14,20,22,0.72);--gb:rgba(34,197,94,0.13);--gr:#22c55e;--tx:#dff0e4;--t2:#7da686;--sh:0 6px 28px rgba(0,0,0,0.55)}
    [data-theme="light"]{--bg:#f2f7f3;--bg2:#e9f2eb;--gl:rgba(255,255,255,0.78);--gb:rgba(22,163,74,0.18);--gr:#15803d;--tx:#0d1f12;--t2:#2d5c38;--sh:0 6px 28px rgba(0,0,0,0.09)}
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;font-size:16px}
    body{background:var(--bg);color:var(--tx);font-family:var(--fb);line-height:1.65;overflow-x:hidden;transition:background var(--t),color var(--t)}
    #navbar{position:fixed;top:0;left:0;right:0;z-index:1000;transition:all var(--t)}
    #navbar.scrolled{background:var(--gl);backdrop-filter:blur(20px);border-bottom:1px solid var(--gb)}
    .ni{max-width:1100px;margin:0 auto;padding:0 2rem;height:62px;display:flex;align-items:center}
    .nl{font-family:var(--fd);font-size:1.25rem;font-weight:800;color:var(--gr);margin-right:auto;letter-spacing:-0.5px;display:flex;align-items:center;gap:7px}
    .hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:7rem 0 4rem}
    .hbg{position:absolute;inset:0;background:radial-gradient(ellipse 90% 70% at 65% 15%,rgba(34,197,94,0.07) 0%,transparent 65%);pointer-events:none}
    .hi{position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:3.5rem;align-items:center;max-width:1100px;margin:0 auto;padding:0 2rem}
    h1{font-family:var(--fd);font-size:clamp(2.3rem,4.8vw,3.8rem);font-weight:800;line-height:1.07;letter-spacing:-2px;margin-bottom:1.3rem;animation:fadeUp 0.75s ease both}
    h1 em{font-style:normal;color:var(--gr)}
    .hd{font-size:1.05rem;color:var(--t2);line-height:1.78;margin-bottom:1.9rem;max-width:510px;animation:fadeUp 0.75s 0.1s ease both}
    .btn{display:inline-flex;align-items:center;gap:7px;padding:12px 24px;border-radius:var(--rs);font-size:13.5px;font-weight:700;border:none;transition:all var(--t);text-decoration:none;font-family:var(--fb)}
    .bp{background:var(--gr);color:#fff;box-shadow:0 3px 18px rgba(34,197,94,0.28)}
    .bp:hover{transform:translateY(-2px);box-shadow:0 7px 26px rgba(34,197,94,0.38)}
    .glass{background:var(--gl);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid var(--gb);border-radius:var(--r);box-shadow:var(--sh)}
    .fwa{position:fixed;bottom:22px;right:22px;width:50px;height:50px;background:#25d366;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:0 4px 18px rgba(37,211,102,0.38);z-index:998;transition:all var(--t)}
    .fwa:hover{transform:scale(1.1);box-shadow:0 7px 28px rgba(37,211,102,0.48)}
    .container{max-width:1100px;margin:0 auto;padding:0 2rem}
    @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
    @media (max-width:900px){.hi{grid-template-columns:1fr}.hv{display:none}}
    @media (max-width:640px){.container{padding:0 1.2rem}.hero{padding:3.2rem 0}}
  </style>

  <!-- Enhanced Navigation -->
  <nav id="navbar" role="navigation" aria-label="Main navigation">
    <div class="ni">
      <a href="/" class="nl" aria-label="EWaste Kochi Home">
        <div class="nld" style="width:7px;height:7px;background:var(--gr);border-radius:50%;animation:pulse 2s infinite"></div>
        EWaste<span style="color:var(--t2);font-weight:400">Kochi</span>
      </a>
      <div class="nls" role="menubar">
        <a href="#services" role="menuitem">Services</a>
        <a href="#itad" role="menuitem">ITAD</a>
        <a href="#data-destruction" role="menuitem">Data Security</a>
        <a href="#compliance" role="menuitem">Compliance</a>
        <a href="#locations" role="menuitem">Locations</a>
        <a href="#faq" role="menuitem">FAQs</a>
        <a href="#contact" role="menuitem">Contact</a>
      </div>
      <div class="na">
        <select class="ls" id="lang-select" aria-label="Select language" onchange="changeLang(this.value)">
          <option value="en">EN</option>
          <option value="ml">ML</option>
          <option value="hi">HI</option>
        </select>
        <button class="tt" onclick="toggleTheme()" aria-label="Toggle theme" title="Toggle theme">
          <span id="ti">☀️</span>
        </button>
        <button class="spb" id="spb" onclick="toggleSpeech()" aria-label="Voice assistant" title="Voice">
          🎙️
        </button>
        <a href="tel:+917500555454" class="btn bp" style="display:none;font-size:12px;padding:9px 16px;" id="navcta">
          📞 Free Pickup
        </a>
      </div>
    </div>
  </nav>

  <!-- Voice Assistant Overlay -->
  <div id="so" role="status" aria-live="polite" style="position:fixed;bottom:85px;right:22px;z-index:999;background:var(--gl);border:1px solid var(--gb);border-radius:var(--r);padding:.9rem 1.1rem;min-width:250px;backdrop-filter:blur(18px);display:none;box-shadow:var(--sh)">
    <div style="font-size:11.5px;font-weight:700;color:var(--gr);margin-bottom:5px;">🎙️ Voice Assistant</div>
    <div id="spt">Say "book pickup", "get a quote", or "data destruction"...</div>
    <div class="sw" style="display:flex;align-items:center;gap:3px;margin-top:7px;height:18px">
      <div class="wb" style="width:3px;background:var(--gr);border-radius:2px;height:4px"></div>
      <div class="wb" style="width:3px;background:var(--gr);border-radius:2px;height:8px"></div>
      <div class="wb" style="width:3px;background:var(--gr);border-radius:2px;height:12px"></div>
      <div class="wb" style="width:3px;background:var(--gr);border-radius:2px;height:8px"></div>
      <div class="wb" style="width:3px;background:var(--gr);border-radius:2px;height:4px"></div>
    </div>
  </div>

  <!-- Main Content -->
  <main id="main">
    <!-- Hero Section -->
    <HeroGlass />
    
    <!-- Trust Strip -->
    <TrustStrip />
    
    <!-- Services Grid -->
    <ServiceGrid />
    
    <!-- Process Steps -->
    <ProcessSteps />
    
    <!-- Testimonials -->
    <TestimonialGlass />
    
    <!-- FAQ -->
    <FAQAccordion />
    
    <!-- Final CTA -->
    <CTASticky />
  </main>

  <!-- Enhanced Floating WhatsApp Button -->
  <a href="https://wa.me/917500555454" class="fwa" aria-label="WhatsApp" target="_blank" rel="noopener" loading="lazy">
    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.121 1.533 5.85L.057 23.386a.75.75 0 00.921.921l5.536-1.476A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.952 9.952 0 01-5.073-1.39l-.363-.215-3.785 1.01 1.01-3.785-.215-.363A9.952 9.952 0 012 12C2 6.486 6.486 2 12 2s10 5.486 10 10-4.486 10-10 10z"/>
    </svg>
  </a>

  <!-- Enhanced Footer -->
  <footer role="contentinfo">
    <div class="container">
      <div class="fg2">
        <div>
          <div class="flogo">EWaste Kochi</div>
          <p class="fdesc">Kerala's #1 KSPCB-authorized e-waste recycler and ITAD company. Certified data destruction, free pickup, and complete compliance documentation.</p>
          <div style="display:flex;gap:10px;margin-top:1rem">
            <a href="https://linkedin.com/company/ewaste-kochi" aria-label="LinkedIn" style="width:32px;height:32px;background:var(--sf);border:1px solid var(--gb);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--t2)">in</a>
            <a href="https://facebook.com/ewaste-kochi" aria-label="Facebook" style="width:32px;height:32px;background:var(--sf);border:1px solid var(--gb);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--t2)">f</a>
            <a href="https://twitter.com/ewaste-kochi" aria-label="Twitter" style="width:32px;height:32px;background:var(--sf);border:1px solid var(--gb);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--t2)">𝕏</a>
          </div>
        </div>
        <div>
          <div class="fct">Services</div>
          <div class="fc">
            <a href="/free-e-waste-pickup-kochi/">Free E-Waste Pickup</a>
            <a href="/laptop-buyback-kochi/">Laptop Buyback</a>
            <a href="/nist-data-destruction-kerala/">Data Destruction</a>
            <a href="/itad-services-kochi/">ITAD Services</a>
            <a href="/battery-recycling-kochi/">Battery Recycling</a>
          </div>
        </div>
        <div>
          <div class="fct">Compliance</div>
          <div class="fc">
            <a href="/epr-compliance-certificates-kochi/">EPR Certificates</a>
            <a href="/kspcb-authorization/">KSPCB Auth</a>
            <a href="/dpdp-compliance/">DPDP Act 2023</a>
            <a href="/nist-800-88/">NIST Standards</a>
            <a href="/audit-reports/">Audit Reports</a>
          </div>
        </div>
        <div>
          <div class="fct">Company</div>
          <div class="fc">
            <a href="/about/">About Us</a>
            <a href="/locations/">Service Locations</a>
            <a href="/careers/">Careers</a>
            <a href="/blog/">Blog</a>
            <a href="/contact/">Contact</a>
          </div>
        </div>
      </div>
      <div class="fbot">
        <div class="fleg">© 2024 EWaste Kochi. KSPCB Authorization No. KL/EW/628. All rights reserved.</div>
        <div style="display:flex;gap:15px;font-size:11.5px;color:var(--t3)">
          <a href="/privacy/" style="color:var(--t3)">Privacy Policy</a>
          <a href="/terms/" style="color:var(--t3)">Terms of Service</a>
          <a href="/sitemap/" style="color:var(--t3)">Sitemap</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Non-Critical CSS Loaded Async -->
  <link rel="preload" href="/styles/non-critical.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="/styles/non-critical.css" /></noscript>

  <!-- Enhanced JavaScript -->
  <script>
    // Theme Management
    function toggleTheme() {
      const html = document.documentElement;
      const currentTheme = html.getAttribute('data-theme');
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', newTheme);
      localStorage.setItem('ewk-t', newTheme);
      document.getElementById('ti').textContent = newTheme === 'dark' ? '☀️' : '🌙';
    }

    // Language Management
    function changeLang(lang) {
      console.log('Language changed to:', lang);
      // Implement language switching logic
    }

    // Voice Assistant
    function toggleSpeech() {
      const so = document.getElementById('so');
      const spb = document.getElementById('spb');
      const isShow = so.style.display === 'block';
      
      so.style.display = isShow ? 'none' : 'block';
      spb.classList.toggle('active', !isShow);
      
      if (!isShow) {
        // Initialize voice recognition
        if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
          const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
          const recognition = new SpeechRecognition();
          recognition.continuous = false;
          recognition.interimResults = false;
          recognition.lang = 'en-IN';
          
          recognition.onresult = function(event) {
            const command = event.results[0][0].transcript.toLowerCase();
            document.getElementById('spt').textContent = `You said: "${command}"`;
            
            // Process voice commands
            if (command.includes('pickup')) {
              window.location.href = '#contact';
            } else if (command.includes('quote')) {
              window.location.href = '#contact';
            } else if (command.includes('destruction')) {
              window.location.href = '#data-destruction';
            }
          };
          
          recognition.start();
        }
      }
    }

    // Navbar Scroll Effect
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const navbar = document.getElementById('navbar');
      const currentScroll = window.pageYOffset;
      
      if (currentScroll > 100) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
      
      lastScroll = currentScroll;
    });

    // Initialize on DOM Load
    document.addEventListener('DOMContentLoaded', () => {
      // Restore theme
      const savedTheme = localStorage.getItem('ewk-t');
      if (savedTheme) {
        document.documentElement.setAttribute('data-theme', savedTheme);
        document.getElementById('ti').textContent = savedTheme === 'dark' ? '☀️' : '🌙';
      }
      
      // Show nav CTA on large screens
      if (window.innerWidth > 900) {
        document.getElementById('navcta').style.display = 'flex';
      }
      
      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        });
      });
    });

    // Performance Monitoring
    if ('performance' in window) {
      window.addEventListener('load', () => {
        const perfData = performance.getEntriesByType('navigation')[0];
        console.log('Page Load Time:', perfData.loadEventEnd - perfData.loadEventStart, 'ms');
      });
    }
  </script>
</BaseLayout>
