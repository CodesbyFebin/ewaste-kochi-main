---
import BaseLayout from '../layouts/BaseLayout.astro';

// JSON-LD Schema Suite
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness","RecyclingCenter"],
      "@id": "https://ewastekochi.com/#organization",
      "name": "EWaste Kochi",
      "description": "Kerala's #1 KSPCB-certified e-waste recycler offering zero-landfill electronics recycling in Kochi with free pickup service.",
      "url": "https://ewastekochi.com/recycling/",
      "telephone": "+917500555454",
      "email": "info@ewastekochi.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "710A, Hill Palace Road, Thrippunithura",
        "addressLocality": "Kochi",
        "addressRegion": "Kerala",
        "postalCode": "682301",
        "addressCountry": "IN"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 9.9312,
        "longitude": 76.3090
      },
      "areaServed": ["Kochi","Ernakulam","Kerala"],
      "openingHoursSpecification": [
        {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],"opens":"08:00","closes":"20:00"},
        {"@type":"OpeningHoursSpecification","dayOfWeek":"Sunday","opens":"10:00","closes":"16:00"}
      ],
      "hasCredential": [
        {"@type":"EducationalOccupationalCredential","name":"KSPCB Authorization KL/EW/628"},
        {"@type":"EducationalOccupationalCredential","name":"Zero-Landfill Certified"}
      ]
    },
    {
      "@type": "Service",
      "name": "E-Waste Recycling Service",
      "description": "Professional e-waste recycling and disposal service for all electronic devices in Kochi, Kerala",
      "provider": {"@id":"https://ewastekochi.com/#organization"},
      "areaServed": "Kochi, Kerala",
      "serviceType": "Electronics Recycling",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "INR",
        "price": "0",
        "description": "Free pickup for 10+ devices, 99 for 1-9 devices"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {"@type":"Question","name":"What e-waste items do you accept for recycling in Kochi?","acceptedAnswer":{"@type":"Answer","text":"We accept all 21 categories of e-waste including laptops, desktops, servers, phones, tablets, TVs, monitors, printers, batteries, UPS, air conditioners, refrigerators and more. All items are processed at our KSPCB-authorized facility."}},
        {"@type":"Question","name":"Is e-waste recycling free in Kochi?","acceptedAnswer":{"@type":"Answer","text":"Yes! We offer completely free pickup for 10 or more devices anywhere in Ernakulam district. For 1-9 devices, residential collection is just 99. Walk-in drop-off at our Thrippunithura facility is always free."}},
        {"@type":"Question","name":"Where can I recycle e-waste in Kochi?","acceptedAnswer":{"@type":"Answer","text":"Our main facility is at 710A Hill Palace Road, Thrippunithura, Kochi - open Mon-Sat 8AM-8PM, Sun 10AM-4PM. We also offer free pickup across all areas: Infopark, Kakkanad, Smart City, Edappally, MG Road, Vytilla, Aluva and more."}},
        {"@type":"Question","name":"Do you provide a Certificate of Recycling?","acceptedAnswer":{"@type":"Answer","text":"Yes. A serial-numbered Certificate of Recycling is issued within 24 hours for every pickup, documenting KSPCB-compliant processing and zero-landfill disposal of all materials."}},
        {"@type":"Question","name":"What happens to recycled electronics?","acceptedAnswer":{"@type":"Answer","text":"All electronics are processed at our KSPCB facility: hazardous materials are safely extracted, precious metals are recovered, and remaining materials are recycled. We maintain zero-landfill policy for all processed e-waste."}}
      ]
    }
  ]
};

// Service areas data
const serviceAreas = [
  "Infopark", "Kakkanad", "Smart City", "Edappally", "MG Road", 
  "Vytilla", "Aluva", "Thrippunithura", "Maradu", "Palarivattom",
  "Kalamassery", "Ernakulam", "Fort Kochi", "Mattancherry", "Vypeen"
];

// Accepted items
const acceptedItems = [
  { category: "Computers", items: ["Laptops", "Desktops", "Servers", "Workstations"], icon: "computer" },
  { category: "Mobile Devices", items: ["Smartphones", "Tablets", "Feature Phones"], icon: "phone" },
  { category: "Display Equipment", items: ["Monitors", "TVs", "LED/LCD Screens"], icon: "monitor" },
  { category: "Peripherals", items: ["Printers", "Scanners", "Keyboards", "Mice"], icon: "printer" },
  { category: "Storage", items: ["Hard Drives", "SSDs", "USB Drives", "Memory Cards"], icon: "storage" },
  { category: "Large Appliances", items: ["Air Conditioners", "Refrigerators", "Washing Machines"], icon: "ac" }
];
---

<BaseLayout 
  title="E-Waste Recycling in Kochi, Kerala | Free Pickup Service | EWaste Kochi"
  description="Kerala's #1 KSPCB-certified e-waste recycling service in Kochi. Free pickup for 10+ devices, zero-landfill processing, Certificate of Recycling. All electronics accepted."
  canonical="https://ewastekochi.com/recycling/"
  schema={schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <!-- Sticky CTA Bar -->
  <div class="sticky-cta-bar">
    <div class="cta-container">
      <a href="tel:+917500555454" class="cta-button primary">Call Now</a>
      <a href="https://wa.me/917500555454" class="cta-button whatsapp">WhatsApp</a>
      <button onclick="openBookingModal()" class="cta-button secondary">Book Pickup</button>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-content">
      <h1 class="hero-title">E-Waste Recycling in Kochi, Kerala</h1>
      <p class="hero-description">Kerala's #1 KSPCB-certified e-waste recycling service. Free pickup for 10+ devices, zero-landfill processing, and instant Certificate of Recycling for every collection.</p>
      
      <div class="hero-features">
        <div class="feature-badge">
          <span class="icon">check</span>
          <span>KSPCB Authorized KL/EW/628</span>
        </div>
        <div class="feature-badge">
          <span class="icon">check</span>
          <span>Zero-Landfill Facility</span>
        </div>
        <div class="feature-badge">
          <span class="icon">check</span>
          <span>Free Bulk Pickup</span>
        </div>
      </div>

      <div class="hero-cta">
        <a href="tel:+917500555454" class="cta-button primary large">Call +91 75005 55454</a>
        <button onclick="openBookingModal()" class="cta-button secondary large">Schedule Free Pickup</button>
      </div>
    </div>
  </section>

  <!-- Decision Block -->
  <section class="decision-section">
    <div class="decision-container">
      <h2>Choose Your Recycling Option</h2>
      <div class="decision-cards">
        <div class="decision-card">
          <div class="card-header">
            <span class="card-icon">business</span>
            <h3>10+ Devices</h3>
          </div>
          <p class="card-price">FREE Pickup</p>
          <p class="card-desc">Perfect for offices, schools, and bulk recycling</p>
          <button onclick="openBookingModal()" class="card-button primary">Book Free Pickup</button>
        </div>
        <div class="decision-card">
          <div class="card-header">
            <span class="card-icon">person</span>
            <h3>1-9 Devices</h3>
          </div>
          <p class="card-price">99 Collection</p>
          <p class="card-desc">Ideal for home users and small quantities</p>
          <button onclick="openBookingModal()" class="card-button secondary">Schedule Collection</button>
        </div>
        <div class="decision-card">
          <div class="card-header">
            <span class="card-icon">location_on</span>
            <h3>Self Drop-off</h3>
          </div>
          <p class="card-price">FREE</p>
          <p class="card-desc">Visit our facility at Thrippunithura</p>
          <a href="#directions" class="card-button tertiary">Get Directions</a>
        </div>
      </div>
    </div>
  </section>

  <!-- What is E-Waste Recycling -->
  <section class="content-section">
    <div class="content-container">
      <h2>What is E-Waste Recycling?</h2>
      <p class="section-intro">E-waste recycling is the professional process of collecting, dismantling, and processing discarded electronic equipment to recover valuable materials while safely handling hazardous substances.</p>
      
      <div class="info-cards">
        <div class="info-card">
          <div class="card-icon">eco</div>
          <h3>Environmental Protection</h3>
          <p>Prevents toxic materials like lead, mercury, and cadmium from contaminating soil and water sources in Kochi.</p>
        </div>
        <div class="info-card">
          <div class="card-icon">recycling</div>
          <h3>Resource Recovery</h3>
          <p>Recovers valuable metals including gold, silver, copper, and palladium from electronic components.</p>
        </div>
        <div class="info-card">
          <div class="card-icon">security</div>
          <h3>Data Security</h3>
          <p>Ensures complete data destruction through certified processes, protecting your sensitive information.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Proper Recycling Matters -->
  <section class="content-section bg-light">
    <div class="content-container">
      <h2>Why Proper E-Waste Recycling Matters for Kochi</h2>
      
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number">70%</div>
          <div class="stat-label">E-waste contains toxic materials</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">50x</div>
          <div class="stat-label">More gold in circuit boards than ore</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">0%</div>
          <div class="stat-label">Landfill with our process</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">100%</div>
          <div class="stat-label">Compliance with KSPCB</div>
        </div>
      </div>

      <div class="compliance-notice">
        <div class="notice-icon">warning</div>
        <div class="notice-content">
          <h3>KSPCB Compliance Required</h3>
          <p>Under Kerala's E-Waste Management Rules, all electronic waste must be processed through KSPCB-authorized facilities. EWaste Kochi holds authorization KL/EW/628 for legal e-waste processing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Recycling Process -->
  <section class="process-section">
    <div class="content-container">
      <h2>Our Certified Recycling Process</h2>
      
      <div class="process-steps">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Collection</h3>
            <p>Secure pickup from your location or drop-off at our Thrippunithura facility. All collections are documented with proper manifests.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>Sorting & Testing</h3>
            <p>Items are sorted by category and tested for potential reuse or refurbishment before recycling.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Data Destruction</h3>
            <p>All storage devices undergo certified data destruction using NIST 800-88 standards before processing.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>Material Recovery</h3>
            <p>Electronics are dismantled and materials are separated for recovery - metals, plastics, and hazardous components.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">5</div>
          <div class="step-content">
            <h3>Certificate Issued</h3>
            <p>Receive your Certificate of Recycling within 24 hours, documenting complete compliance and zero-landfill processing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Items We Recycle -->
  <section class="items-section">
    <div class="content-container">
      <h2>What Electronics We Recycle</h2>
      <p class="section-intro">We accept all 21 categories of e-waste under India's E-Waste Management Rules 2022.</p>
      
      <div class="items-grid">
        {acceptedItems.map(item => (
          <div class="item-category">
            <div class="category-header">
              <span class="category-icon">{item.icon}</span>
              <h3>{item.category}</h3>
            </div>
            <ul class="items-list">
              {item.items.map(i => <li>{i}</li>)}
            </ul>
          </div>
        ))}
      </div>

      <div class="items-note">
        <p>Don't see your item? <a href="tel:+917500555454">Call us at +91 75005 55454</a> - we accept virtually all electronic equipment!</p>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="areas-section bg-light">
    <div class="content-container">
      <h2>E-Waste Recycling Service Areas in Kochi</h2>
      <p class="section-intro">We provide free pickup services across all major areas in Ernakulam district.</p>
      
      <div class="areas-grid">
        {serviceAreas.map(area => (
          <div class="area-item">
            <span class="area-icon">location_on</span>
            <span class="area-name">{area}</span>
          </div>
        ))}
      </div>

      <div class="areas-cta">
        <p>Serving your area? <a href="tel:+917500555454">Call to confirm</a> or <button onclick="openBookingModal()" class="link-button">schedule pickup</button></p>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="related-section">
    <div class="content-container">
      <h2>Related E-Waste Services</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">shield</div>
          <h3><a href="/data-destruction/">Data Destruction Services</a></h3>
          <p>NIST 800-88 certified data destruction for hard drives, SSDs, and storage media with Certificate of Destruction.</p>
          <a href="/data-destruction/" class="service-link">Learn More</a>
        </div>
        <div class="service-card">
          <div class="service-icon">business</div>
          <h3><a href="/itad-services/">ITAD Services</a></h3>
          <p>Complete IT Asset Disposition for enterprises including asset tracking, data sanitization, and value recovery.</p>
          <a href="/itad-services/" class="service-link">Learn More</a>
        </div>
        <div class="service-card">
          <div class="service-icon">laptop</div>
          <h3><a href="/laptop-recycling-kochi/">Laptop Recycling</a></h3>
          <p>Specialized laptop recycling service with secure data destruction and component recovery.</p>
          <a href="/laptop-recycling-kochi/" class="service-link">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section bg-light">
    <div class="content-container">
      <h2>Frequently Asked Questions</h2>
      
      <div class="faq-list">
        <div class="faq-item">
          <div class="faq-question">
            <h3>What e-waste items do you accept for recycling in Kochi?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>We accept all 21 categories of e-waste including laptops, desktops, servers, phones, tablets, TVs, monitors, printers, batteries, UPS, air conditioners, refrigerators and more. All items are processed at our KSPCB-authorized facility.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question">
            <h3>Is e-waste recycling free in Kochi?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>Yes! We offer completely free pickup for 10 or more devices anywhere in Ernakulam district. For 1-9 devices, residential collection is just 99. Walk-in drop-off at our Thrippunithura facility is always free.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question">
            <h3>Where can I recycle e-waste in Kochi?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>Our main facility is at 710A Hill Palace Road, Thrippunithura, Kochi - open Mon-Sat 8AM-8PM, Sun 10AM-4PM. We also offer free pickup across all areas: Infopark, Kakkanad, Smart City, Edappally, MG Road, Vytilla, Aluva and more.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question">
            <h3>Do you provide a Certificate of Recycling?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>Yes. A serial-numbered Certificate of Recycling is issued within 24 hours for every pickup, documenting KSPCB-compliant processing and zero-landfill disposal of all materials.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question">
            <h3>What happens to recycled electronics?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>All electronics are processed at our KSPCB facility: hazardous materials are safely extracted, precious metals are recovered, and remaining materials are recycled. We maintain zero-landfill policy for all processed e-waste.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="content-container">
      <div class="cta-content">
        <h2>Ready to Recycle Your E-Waste Responsibly?</h2>
        <p>Join hundreds of Kochi businesses and residents who trust EWaste Kochi for certified, compliant e-waste recycling.</p>
        <div class="cta-buttons">
          <a href="tel:+917500555454" class="cta-button primary large">Call +91 75005 55454</a>
          <button onclick="openBookingModal()" class="cta-button secondary large">Schedule Free Pickup</button>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Glass UI Design System */
    :root {
      --glass-bg: rgba(255, 255, 255, 0.95);
      --glass-border: rgba(255, 255, 255, 0.18);
      --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      --primary: #10b981;
      --primary-dark: #059669;
      --secondary: #3b82f6;
      --accent: #f59e0b;
      --text-primary: #1f2937;
      --text-secondary: #6b7280;
      --border-radius: 16px;
      --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Base Styles */
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: var(--text-primary);
    }

    /* Sticky CTA Bar */
    .sticky-cta-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(20px);
      border-top: 1px solid var(--glass-border);
      padding: 1rem;
      z-index: 1000;
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
    }

    .cta-container {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .cta-button {
      padding: 0.75rem 1.5rem;
      border-radius: 12px;
      border: none;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
      transition: var(--transition);
      font-size: 1rem;
    }

    .cta-button.primary {
      background: var(--primary);
      color: white;
    }

    .cta-button.primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
    }

    .cta-button.whatsapp {
      background: #25d366;
      color: white;
    }

    .cta-button.secondary {
      background: var(--secondary);
      color: white;
    }

    .cta-button.large {
      padding: 1rem 2rem;
      font-size: 1.1rem;
    }

    /* Hero Section */
    .hero-section {
      padding: 6rem 1rem 4rem;
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      color: white;
      text-align: center;
    }

    .hero-content {
      max-width: 900px;
      margin: 0 auto;
    }

    .hero-title {
      font-size: 3.5rem;
      font-weight: 800;
      margin-bottom: 1.5rem;
      line-height: 1.1;
    }

    .hero-description {
      font-size: 1.3rem;
      margin-bottom: 2rem;
      opacity: 0.95;
      line-height: 1.5;
    }

    .hero-features {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-bottom: 3rem;
      flex-wrap: wrap;
    }

    .feature-badge {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255, 255, 255, 0.2);
      padding: 0.5rem 1rem;
      border-radius: 50px;
      font-weight: 600;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Content Sections */
    .content-section {
      padding: 5rem 1rem;
    }

    .content-section.bg-light {
      background: #f9fafb;
    }

    .content-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .content-section h2 {
      font-size: 2.5rem;
      font-weight: 800;
      text-align: center;
      margin-bottom: 1rem;
      color: var(--text-primary);
    }

    .section-intro {
      font-size: 1.2rem;
      text-align: center;
      color: var(--text-secondary);
      margin-bottom: 3rem;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Decision Cards */
    .decision-section {
      padding: 4rem 1rem;
      background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
    }

    .decision-container {
      max-width: 1000px;
      margin: 0 auto;
    }

    .decision-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .decision-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      padding: 2rem;
      text-align: center;
      box-shadow: var(--glass-shadow);
      transition: var(--transition);
    }

    .decision-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .card-icon {
      font-size: 2rem;
      color: var(--primary);
    }

    .card-header h3 {
      font-size: 1.5rem;
      margin: 0;
    }

    .card-price {
      font-size: 2rem;
      font-weight: 800;
      color: var(--primary);
      margin: 1rem 0;
    }

    .card-desc {
      color: var(--text-secondary);
      margin-bottom: 2rem;
    }

    .card-button {
      padding: 0.75rem 1.5rem;
      border-radius: 12px;
      border: none;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      text-decoration: none;
      display: inline-block;
    }

    .card-button.primary {
      background: var(--primary);
      color: white;
    }

    .card-button.secondary {
      background: var(--secondary);
      color: white;
    }

    .card-button.tertiary {
      background: transparent;
      color: var(--primary);
      border: 2px solid var(--primary);
    }

    /* Info Cards */
    .info-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .info-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      padding: 2rem;
      box-shadow: var(--glass-shadow);
      transition: var(--transition);
    }

    .info-card:hover {
      transform: translateY(-4px);
    }

    .info-card .card-icon {
      font-size: 3rem;
      color: var(--primary);
      margin-bottom: 1rem;
    }

    .info-card h3 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }

    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      margin: 3rem 0;
    }

    .stat-card {
      text-align: center;
      padding: 2rem;
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
    }

    .stat-number {
      font-size: 3rem;
      font-weight: 800;
      color: var(--primary);
      margin-bottom: 0.5rem;
    }

    .stat-label {
      color: var(--text-secondary);
      font-weight: 600;
    }

    /* Compliance Notice */
    .compliance-notice {
      display: flex;
      gap: 1rem;
      background: #fef3c7;
      border: 1px solid #f59e0b;
      border-radius: var(--border-radius);
      padding: 1.5rem;
      margin-top: 2rem;
    }

    .notice-icon {
      font-size: 2rem;
      color: #f59e0b;
    }

    .notice-content h3 {
      margin: 0 0 0.5rem 0;
      color: #92400e;
    }

    .notice-content p {
      margin: 0;
      color: #78350f;
    }

    /* Process Steps */
    .process-steps {
      margin-top: 3rem;
    }

    .process-step {
      display: flex;
      gap: 2rem;
      margin-bottom: 2rem;
      align-items: flex-start;
    }

    .step-number {
      width: 60px;
      height: 60px;
      background: var(--primary);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-weight: 800;
      flex-shrink: 0;
    }

    .step-content h3 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    /* Items Grid */
    .items-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .item-category {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      padding: 1.5rem;
      box-shadow: var(--glass-shadow);
    }

    .category-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .category-icon {
      font-size: 2rem;
      color: var(--primary);
    }

    .items-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .items-list li {
      padding: 0.5rem 0;
      border-bottom: 1px solid #e5e7eb;
    }

    .items-list li:last-child {
      border-bottom: none;
    }

    /* Areas Grid */
    .areas-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin: 2rem 0;
    }

    .area-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
    }

    .area-icon {
      color: var(--primary);
    }

    /* Services Grid */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .service-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      padding: 2rem;
      box-shadow: var(--glass-shadow);
      transition: var(--transition);
    }

    .service-card:hover {
      transform: translateY(-4px);
    }

    .service-icon {
      font-size: 3rem;
      color: var(--primary);
      margin-bottom: 1rem;
    }

    .service-card h3 {
      margin-bottom: 1rem;
    }

    .service-card h3 a {
      color: var(--text-primary);
      text-decoration: none;
    }

    .service-card h3 a:hover {
      color: var(--primary);
    }

    .service-link {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      display: inline-block;
      margin-top: 1rem;
    }

    .service-link:hover {
      text-decoration: underline;
    }

    /* FAQ Section */
    .faq-list {
      margin-top: 2rem;
    }

    .faq-item {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      margin-bottom: 1rem;
      overflow: hidden;
    }

    .faq-question {
      padding: 1.5rem;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
    }

    .faq-question h3 {
      margin: 0;
    }

    .faq-toggle {
      font-size: 1.5rem;
      color: var(--primary);
      transition: var(--transition);
    }

    .faq-item.active .faq-toggle {
      transform: rotate(45deg);
    }

    .faq-answer {
      padding: 0 1.5rem 1.5rem;
      color: var(--text-secondary);
      display: none;
    }

    .faq-item.active .faq-answer {
      display: block;
    }

    /* Final CTA */
    .final-cta {
      padding: 5rem 1rem;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      color: white;
      text-align: center;
    }

    .cta-content h2 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: white;
    }

    .cta-content p {
      font-size: 1.2rem;
      margin-bottom: 2rem;
      opacity: 0.95;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero-title {
        font-size: 2.5rem;
      }

      .hero-description {
        font-size: 1.1rem;
      }

      .content-section h2 {
        font-size: 2rem;
      }

      .process-step {
        flex-direction: column;
        text-align: center;
      }

      .step-number {
        margin: 0 auto 1rem;
      }

      .sticky-cta-bar {
        padding: 0.75rem 1rem;
      }

      .cta-container {
        flex-direction: column;
      }

      .cta-button {
        width: 100%;
        justify-content: center;
      }
    }
  </style>

  <script>
    // FAQ Toggle
    document.querySelectorAll('.faq-question').forEach(question => {
      question.addEventListener('click', () => {
        const faqItem = question.parentElement;
        const isActive = faqItem.classList.contains('active');
        
        // Close all FAQ items
        document.querySelectorAll('.faq-item').forEach(item => {
          item.classList.remove('active');
        });
        
        // Open clicked item if it wasn't active
        if (!isActive) {
          faqItem.classList.add('active');
        }
      });
    });

    // Booking Modal (placeholder)
    function openBookingModal() {
      // In production, this would open a booking modal
      window.location.href = 'tel:+917500555454';
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });

    // Add scroll effect to sticky CTA
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const currentScroll = window.pageYOffset;
      const ctaBar = document.querySelector('.sticky-cta-bar');
      
      if (ctaBar) {
        if (currentScroll > lastScroll && currentScroll > 500) {
          // Scrolling down
          ctaBar.style.transform = 'translateY(100%)';
        } else {
          // Scrolling up
          ctaBar.style.transform = 'translateY(0)';
        }
      }
      
      lastScroll = currentScroll;
    });
  </script>
</BaseLayout>
