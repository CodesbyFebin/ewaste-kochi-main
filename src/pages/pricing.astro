    }

    /* FAQ Section */
    .faq-list {
      margin-top: 2rem;
    }

    .faq-item {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      margin-bottom: 1rem;
      overflow: hidden;
    }

    .faq-question {
      padding: 1.5rem;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
    }

    .faq-question h3 {
      margin: 0;
    }

    .faq-toggle {
      font-size: 1.5rem;
      color: var(--primary);
      transition: var(--transition);
    }

    .faq-item.active .faq-toggle {
      transform: rotate(45deg);
    }

    .faq-answer {
      padding: 0 1.5rem 1.5rem;
      color: var(--text-secondary);
      display: none;
    }

    .faq-item.active .faq-answer {
      display: block;
    }

    /* Final CTA */
    .final-cta {
      padding: 5rem 1rem;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      color: white;
      text-align: center;
    }

    .cta-content h2 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: white;
    }

    .cta-content p {
      font-size: 1.2rem;
      margin-bottom: 2rem;
      opacity: 0.95;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero-title {
        font-size: 2.5rem;
      }

      .hero-description {
        font-size: 1.1rem;
      }

      .content-section h2 {
        font-size: 2rem;
      }

      .sticky-cta-bar {
        padding: 0.75rem 1rem;
      }

      .cta-container {
        flex-direction: column;
      }

      .cta-button {
        width: 100%;
        justify-content: center;
      }

      .pricing-card.popular {
        transform: none;
      }

      .discount-tier.featured {
        transform: none;
      }
    }
  </style>

  <script>
    // Price Calculator
    function updatePrice() {
      const deviceType = document.getElementById('device-type').value;
      const quantity = parseInt(document.getElementById('device-quantity').value) || 1;
      const condition = document.getElementById('device-condition').value;
      const dataDestruction = document.getElementById('data-destruction').checked;
      
      const resultAmount = document.getElementById('result-amount');
      const resultNote = document.getElementById('result-note');
      
      if (!deviceType) {
        resultAmount.textContent = 'Select options to calculate';
        resultNote.textContent = '';
        return;
      }
      
      let basePrice = 0;
      let hasBuyback = false;
      
      // Buyback prices (simplified)
      const buybackPrices = {
        laptop: { working: 12000, 'non-working': 1000, 'for-parts': 800 },
        desktop: { working: 8000, 'non-working': 800, 'for-parts': 500 },
        mobile: { working: 4000, 'non-working': 300, 'for-parts': 200 },
        monitor: { working: 1500, 'non-working': 200, 'for-parts': 100 },
        printer: { working: 800, 'non-working': 150, 'for-parts': 100 },
        server: { working: 15000, 'non-working': 2000, 'for-parts': 1000 }
      };
      
      if (buybackPrices[deviceType] && buybackPrices[deviceType][condition]) {
        basePrice = buybackPrices[deviceType][condition] * quantity;
        hasBuyback = true;
      }
      
      // Add data destruction cost
      if (dataDestruction) {
        basePrice += 299 * quantity;
      }
      
      // Collection fee
      if (quantity < 10 && !hasBuyback) {
        basePrice += 99;
      }
      
      // Display result
      if (hasBuyback && basePrice > 0) {
        resultAmount.textContent = `₹${basePrice.toLocaleString()} (You Receive)`;
        resultNote.textContent = 'We pay you for these devices!';
      } else if (basePrice > 0) {
        resultAmount.textContent = `₹${basePrice.toLocaleString()}`;
        resultNote.textContent = quantity >= 10 ? 'Free pickup included' : 'Collection fee applies';
      } else {
        resultAmount.textContent = 'FREE';
        resultNote.textContent = 'Free pickup and processing';
      }
    }
    
    // Service Selection
    function selectService(serviceName) {
      // In production, this would open a booking modal with pre-selected service
      window.location.href = 'tel:+917500555454';
    }
    
    // Quote Modal
    function openQuoteModal() {
      // In production, this would open a detailed quote modal
      window.location.href = 'tel:+917500555454';
    }
    
    // FAQ Toggle
    document.querySelectorAll('.faq-question').forEach(question => {
      question.addEventListener('click', () => {
        const faqItem = question.parentElement;
        const isActive = faqItem.classList.contains('active');
        
        // Close all FAQ items
        document.querySelectorAll('.faq-item').forEach(item => {
          item.classList.remove('active');
        });
        
        // Open clicked item if it wasn't active
        if (!isActive) {
          faqItem.classList.add('active');
        }
      });
    });
    
    // Add scroll effect to sticky CTA
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const currentScroll = window.pageYOffset;
      const ctaBar = document.querySelector('.sticky-cta-bar');
      
      if (ctaBar) {
        if (currentScroll > lastScroll && currentScroll > 500) {
          // Scrolling down
          ctaBar.style.transform = 'translateY(100%)';
        } else {
          // Scrolling up
          ctaBar.style.transform = 'translateY(0)';
        }
      }
      
      lastScroll = currentScroll;
    });
  </script>
</BaseLayout>
