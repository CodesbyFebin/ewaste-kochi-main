    }

    .discount-tier.featured {
      border: 2px solid var(--primary);
      transform: scale(1.05);
    }

    .discount-tier:hover {
      transform: translateY(-4px);
    }

    .discount-tier.featured:hover {
      transform: scale(1.05) translateY(-4px);
    }

    .tier-header {
      margin-bottom: 1rem;
    }

    .tier-header h3 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .tier-quantity {
      background: var(--primary);
      color: white;
