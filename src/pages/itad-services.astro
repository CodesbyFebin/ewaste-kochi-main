---
import BaseLayout from '../layouts/BaseLayout.astro';

// JSON-LD Schema Suite
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness","RecyclingCenter"],
      "@id": "https://ewastekochi.com/#organization",
      "name": "EWaste Kochi",
      "description": "Kerala's #1 certified IT Asset Disposition (ITAD) service provider in Kochi. Complete enterprise IT lifecycle management with data security and compliance.",
      "url": "https://ewastekochi.com/itad-services/",
      "telephone": "+917500555454",
      "email": "info@ewastekochi.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "710A, Hill Palace Road, Thrippunithura",
        "addressLocality": "Kochi",
        "addressRegion": "Kerala",
        "postalCode": "682301",
        "addressCountry": "IN"
      },
      "hasCredential": [
        {"@type":"EducationalOccupationalCredential","name":"NIST SP 800-88 Certified"},
        {"@type":"EducationalOccupationalCredential","name":"DPDP Act 2023 Compliant"},
        {"@type":"EducationalOccupationalCredential","name":"KSPCB Authorized"}
      ]
    },
    {
      "@type": "Service",
      "name": "IT Asset Disposition Service",
      "description": "Complete ITAD services including asset tracking, data destruction, value recovery, and environmental recycling for enterprises in Kochi, Kerala",
      "provider": {"@id":"https://ewastekochi.com/#organization"},
      "areaServed": "Kochi, Kerala",
      "serviceType": "IT Asset Disposition"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {"@type":"Question","name":"What is IT Asset Disposition (ITAD)?","acceptedAnswer":{"@type":"Answer","text":"ITAD is the complete process of retiring IT equipment including data destruction, asset tracking, value recovery, and environmental recycling. It ensures secure, compliant, and cost-effective disposal of enterprise IT assets."}},
        {"@type":"Question","name":"Why do Kochi companies need certified ITAD services?","acceptedAnswer":{"@type":"Answer","text":"Kochi companies need certified ITAD for DPDP Act 2023 compliance, data security, environmental regulations, and asset value recovery. Non-compliance can result in penalties up to 250 crore under DPDP Act."}},
        {"@type":"Question","name":"What IT assets do you handle in ITAD?","acceptedAnswer":{"@type":"Answer","text":"We handle all enterprise IT assets: servers, workstations, laptops, network equipment, storage systems, mobile devices, and data center equipment. Each asset is tracked and processed according to industry standards."}},
        {"@type":"Question","name":"Do you provide IT asset valuation and buyback?","acceptedAnswer":{"@type":"Answer","text":"Yes. We provide fair market valuation for reusable IT assets and offer competitive buyback prices. Working equipment is refurbished and remarketed, maximizing your return on retired assets."}},
        {"@type":"Question","name":"How do you ensure data security in ITAD?","acceptedAnswer":{"@type":"Answer","text":"We use NIST 800-88 certified data destruction methods, maintain chain of custody documentation, provide serial-numbered Certificates of Destruction, and offer on-site destruction for high-security requirements."}}
      ]
    }
  ]
};

// ITAD services
const itadServices = [
  {
    name: "Asset Assessment",
    description: "Comprehensive evaluation of IT assets including age, condition, market value, and data security requirements",
    process: ["Asset inventory", "Condition assessment", "Market valuation", "Security classification"],
    icon: "assessment"
  },
  {
    name: "Data Destruction",
    description: "NIST 800-88 certified data sanitization for all storage media with Certificate of Destruction",
    process: ["Data classification", "Method selection", "Certified destruction", "Documentation"],
    icon: "security"
  },
  {
    name: "Value Recovery",
    description: "Maximize ROI through refurbishment, remarketing, and responsible component recovery",
    process: ["Refurbishment", "Testing", "Remarketing", "Component recovery"],
    icon: "trending_up"
  },
  {
    name: "Environmental Recycling",
    description: "KSPCB-compliant recycling with zero-landfill policy and precious metal recovery",
    process: ["Hazardous extraction", "Material separation", "Precious metal recovery", "Certified recycling"],
    icon: "eco"
  },
  {
    name: "Compliance Reporting",
    description: "Complete documentation for regulatory compliance and audit requirements",
    process: ["Chain of custody", "Certificates", "Compliance reports", "Audit documentation"],
    icon: "description"
  },
  {
    name: "Logistics Management",
    description: "Secure transport, deinstallation, and project management for large-scale ITAD projects",
    process: ["Secure transport", "Deinstallation", "Project management", "Asset tracking"],
    icon: "local_shipping"
  }
];

// Asset types
const assetTypes = [
  {
    category: "Computing Systems",
    items: ["Servers", "Workstations", "Laptops", "Thin Clients"],
    icon: "computer"
  },
  {
    category: "Storage Systems",
    items: ["SAN/NAS", "Tape Libraries", "Disk Arrays", "Backup Systems"],
    icon: "storage"
  },
  {
    category: "Network Equipment",
    items: ["Switches", "Routers", "Firewalls", "Load Balancers"],
    icon: "router"
  },
  {
    category: "Data Center",
    items: ["Racks", "Cooling Systems", "UPS Systems", "PDUs"],
    icon: "dns"
  },
  {
    category: "Mobile Devices",
    items: ["Smartphones", "Tablets", "Mobile POS", "IoT Devices"],
    icon: "phone_iphone"
  },
  {
    category: "Peripherals",
    items: ["Monitors", "Printers", "Scanners", "Projectors"],
    icon: "devices"
  }
];
---

<BaseLayout 
  title="ITAD Services Kochi | Enterprise IT Asset Disposition | EWaste Kochi"
  description="Kerala's #1 certified ITAD service provider in Kochi. Complete enterprise IT asset disposition with NIST 800-88 data destruction, value recovery, and DPDP Act 2023 compliance."
  canonical="https://ewastekochi.com/itad-services/"
  schema={schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <!-- Sticky CTA Bar -->
  <div class="sticky-cta-bar">
    <div class="cta-container">
      <a href="tel:+917500555454" class="cta-button primary">Call Now</a>
      <a href="https://wa.me/917500555454" class="cta-button whatsapp">WhatsApp</a>
      <button onclick="openBookingModal()" class="cta-button secondary">Get Quote</button>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-content">
      <h1 class="hero-title">Enterprise IT Asset Disposition Services</h1>
      <p class="hero-description">Complete ITAD solutions for Kochi enterprises. NIST 800-88 data destruction, asset valuation, value recovery, and DPDP Act 2023 compliance. Trusted by Infopark and Smart City companies.</p>
      
      <div class="hero-features">
        <div class="feature-badge">
          <span class="icon">business</span>
          <span>Enterprise ITAD</span>
        </div>
        <div class="feature-badge">
          <span class="icon">security</span>
          <span>NIST 800-88 Certified</span>
        </div>
        <div class="feature-badge">
          <span class="icon">trending_up</span>
          <span>Value Recovery</span>
        </div>
      </div>

      <div class="hero-cta">
        <a href="tel:+917500555454" class="cta-button primary large">Call +91 75005 55454</a>
        <button onclick="openBookingModal()" class="cta-button secondary large">Get ITAD Quote</button>
      </div>
    </div>
  </section>

  <!-- Enterprise Alert -->
  <section class="enterprise-alert">
    <div class="content-container">
      <div class="alert-content">
        <div class="alert-icon">business</div>
        <div class="alert-text">
          <h2>ITAD: Critical for Enterprise Compliance & Security</h2>
          <p>Under DPDP Act 2023, enterprises must ensure complete data destruction when retiring IT assets. EWaste Kochi provides certified ITAD services that protect your data, maximize asset value, and ensure regulatory compliance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What is ITAD -->
  <section class="content-section">
    <div class="content-container">
      <h2>What is IT Asset Disposition (ITAD)?</h2>
      <p class="section-intro">IT Asset Disposition is the complete process of retiring, disposing, and repurposing IT equipment in a secure, compliant, and environmentally responsible manner.</p>
      
      <div class="info-cards">
        <div class="info-card">
          <div class="card-icon">security</div>
          <h3>Data Security</h3>
          <p>Certified data destruction ensuring complete sanitization of all storage media with NIST 800-88 compliance.</p>
        </div>
        <div class="info-card">
          <div class="card-icon">account_balance</div>
          <h3>Value Recovery</h3>
          <p>Maximize ROI through asset valuation, refurbishment, and responsible resale of reusable IT equipment.</p>
        </div>
        <div class="info-card">
          <div class="card-icon">gavel</div>
          <h3>Regulatory Compliance</h3>
          <p>Complete documentation for DPDP Act 2023, KSPCB, and international compliance standards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ITAD Services -->
  <section class="services-section bg-light">
    <div class="content-container">
      <h2>Complete ITAD Service Suite</h2>
      <p class="section-intro">End-to-end IT asset disposition services covering the entire lifecycle from assessment to final reporting.</p>
      
      <div class="services-grid">
        {itadServices.map(service => (
          <div class="service-card">
            <div class="service-header">
              <div class="service-icon">{service.icon}</div>
              <h3>{service.name}</h3>
            </div>
            <p class="service-description">{service.description}</p>
            <div class="service-process">
              <h4>Process Steps:</h4>
              <ul class="process-list">
                {service.process.map(step => <li>{step}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Asset Types -->
  <section class="assets-section">
    <div class="content-container">
      <h2>IT Assets We Handle</h2>
      <p class="section-intro">Comprehensive ITAD services for all enterprise IT equipment across multiple categories.</p>
      
      <div class="assets-grid">
        {assetTypes.map(asset => (
          <div class="asset-category">
            <div class="category-header">
              <div class="category-icon">{asset.icon}</div>
              <h3>{asset.category}</h3>
            </div>
            <ul class="assets-list">
              {asset.items.map(item => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ITAD Process -->
  <section class="process-section bg-light">
    <div class="content-container">
      <h2>Our ITAD Process</h2>
      
      <div class="process-steps">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Asset Assessment</h3>
            <p>Complete inventory and evaluation of IT assets including age, condition, market value, and data security classification.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>Data Destruction</h3>
            <p>NIST 800-88 certified data sanitization for all storage media with serial-numbered Certificates of Destruction.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Value Recovery</h3>
            <p>Refurbishment and remarketing of reusable assets to maximize return on investment for your retired equipment.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>Environmental Recycling</h3>
            <p>KSPCB-compliant recycling of non-reusable components with zero-landfill policy and precious metal recovery.</p>
          </div>
        </div>
        <div class="process-step">
          <div class="step-number">5</div>
          <div class="step-content">
            <h3>Compliance Reporting</h3>
            <p>Complete documentation including chain of custody, certificates, and compliance reports for audit requirements.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Recovery Options -->
  <section class="value-section">
    <div class="content-container">
      <h2>Maximize Your IT Asset Value</h2>
      <p class="section-intro">Our value recovery program ensures you get the maximum return on your retired IT assets while maintaining security and compliance.</p>
      
      <div class="value-options">
        <div class="value-option">
          <div class="option-header">
            <h3>Refurbishment & Resale</h3>
            <div class="option-value">Maximum ROI</div>
          </div>
          <p>Professional refurbishment and testing to restore IT assets to market-ready condition for resale.</p>
          <ul class="option-benefits">
            <li>Highest return on investment</li>
            <li>Extended equipment lifecycle</li>
            <li>Environmental benefits</li>
            <li>Complete data sanitization</li>
          </ul>
        </div>
        
        <div class="value-option">
          <div class="option-header">
            <h3>Component Recovery</h3>
            <div class="option-value">Moderate ROI</div>
          </div>
          <p>Recovery of valuable components like memory, processors, and precious metals from non-functional equipment.</p>
          <ul class="option-benefits">
            <li>Component-level value extraction</li>
            <li>Precious metal recovery</li>
            <li>Environmental recycling</li>
            <li>Zero-landfill compliance</li>
          </ul>
        </div>
        
        <div class="value-option">
          <div class="option-header">
            <h3>Donation Programs</h3>
            <div class="option-value">Tax Benefits</div>
          </div>
          <p>Refurbished equipment donation to educational institutions and non-profits with tax deduction benefits.</p>
          <ul class="option-benefits">
            <li>Tax deduction opportunities</li>
            <li>Corporate social responsibility</li>
            <li>Community impact</li>
            <li>Brand enhancement</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Compliance Section -->
  <section class="compliance-section bg-light">
    <div class="content-container">
      <h2>Enterprise Compliance & Security</h2>
      <p class="section-intro">Our ITAD services meet all major regulatory requirements and security standards for enterprise IT asset disposition.</p>
      
      <div class="compliance-grid">
        <div class="compliance-card">
          <div class="compliance-icon">gavel</div>
          <h3>DPDP Act 2023</h3>
          <p>Complete compliance with India's Digital Personal Data Protection Act for data destruction and privacy protection.</p>
        </div>
        <div class="compliance-card">
          <div class="compliance-icon">security</div>
          <h3>NIST 800-88</h3>
          <p>U.S. government standard for data sanitization ensuring complete and irreversible data destruction.</p>
        </div>
        <div class="compliance-card">
          <div class="compliance-icon">eco</div>
          <h3>KSPCB Authorized</h3>
          <p>Kerala State Pollution Control Board authorization KL/EW/628 for legal e-waste processing and recycling.</p>
        </div>
        <div class="compliance-card">
          <div class="compliance-icon">verified</div>
          <h3>ISO 27001</h3>
          <p>International information security management standard for enterprise data protection and security.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="content-container">
      <h2>Frequently Asked Questions</h2>
      
      <div class="faq-list">
        <div class="faq-item">
          <div class="faq-question">
            <h3>What is IT Asset Disposition (ITAD)?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>ITAD is the complete process of retiring IT equipment including data destruction, asset tracking, value recovery, and environmental recycling. It ensures secure, compliant, and cost-effective disposal of enterprise IT assets.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question">
            <h3>Why do Kochi companies need certified ITAD services?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>Kochi companies need certified ITAD for DPDP Act 2023 compliance, data security, environmental regulations, and asset value recovery. Non-compliance can result in penalties up to 250 crore under DPDP Act.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question">
            <h3>What IT assets do you handle in ITAD?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>We handle all enterprise IT assets: servers, workstations, laptops, network equipment, storage systems, mobile devices, and data center equipment. Each asset is tracked and processed according to industry standards.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question">
            <h3>Do you provide IT asset valuation and buyback?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>Yes. We provide fair market valuation for reusable IT assets and offer competitive buyback prices. Working equipment is refurbished and remarketed, maximizing your return on retired assets.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question">
            <h3>How do you ensure data security in ITAD?</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>We use NIST 800-88 certified data destruction methods, maintain chain of custody documentation, provide serial-numbered Certificates of Destruction, and offer on-site destruction for high-security requirements.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="content-container">
      <div class="cta-content">
        <h2>Secure Your Enterprise IT Asset Disposition</h2>
        <p>Protect your data, maximize asset value, and ensure compliance with certified ITAD services trusted by Kochi's leading enterprises.</p>
        <div class="cta-buttons">
          <a href="tel:+917500555454" class="cta-button primary large">Call +91 75005 55454</a>
          <button onclick="openBookingModal()" class="cta-button secondary large">Get ITAD Quote</button>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Glass UI Design System */
    :root {
      --glass-bg: rgba(255, 255, 255, 0.95);
      --glass-border: rgba(255, 255, 255, 0.18);
      --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      --primary: #7c3aed;
      --primary-dark: #5b21b6;
      --secondary: #3b82f6;
      --accent: #f59e0b;
      --text-primary: #1f2937;
      --text-secondary: #6b7280;
      --border-radius: 16px;
      --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Base Styles */
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: var(--text-primary);
    }

    /* Sticky CTA Bar */
    .sticky-cta-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(20px);
      border-top: 1px solid var(--glass-border);
      padding: 1rem;
      z-index: 1000;
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
    }

    .cta-container {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .cta-button {
      padding: 0.75rem 1.5rem;
      border-radius: 12px;
      border: none;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
      transition: var(--transition);
      font-size: 1rem;
    }

    .cta-button.primary {
      background: var(--primary);
      color: white;
    }

    .cta-button.primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
    }

    .cta-button.whatsapp {
      background: #25d366;
      color: white;
    }

    .cta-button.secondary {
      background: var(--secondary);
      color: white;
    }

    .cta-button.large {
      padding: 1rem 2rem;
      font-size: 1.1rem;
    }

    /* Hero Section */
    .hero-section {
      padding: 6rem 1rem 4rem;
      background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%);
      color: white;
      text-align: center;
    }

    .hero-content {
      max-width: 900px;
      margin: 0 auto;
    }

    .hero-title {
      font-size: 3.5rem;
      font-weight: 800;
      margin-bottom: 1.5rem;
      line-height: 1.1;
    }

    .hero-description {
      font-size: 1.3rem;
      margin-bottom: 2rem;
      opacity: 0.95;
      line-height: 1.5;
    }

    .hero-features {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-bottom: 3rem;
      flex-wrap: wrap;
    }

    .feature-badge {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255, 255, 255, 0.2);
      padding: 0.5rem 1rem;
      border-radius: 50px;
      font-weight: 600;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Enterprise Alert */
    .enterprise-alert {
      padding: 2rem 1rem;
      background: #f3f4f6;
      border-bottom: 3px solid var(--primary);
    }

    .alert-content {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }

    .alert-icon {
      font-size: 2.5rem;
      color: var(--primary);
      flex-shrink: 0;
    }

    .alert-text h2 {
      color: var(--primary-dark);
      margin-bottom: 0.5rem;
    }

    .alert-text p {
      color: var(--text-secondary);
      margin: 0;
    }

    /* Content Sections */
    .content-section {
      padding: 5rem 1rem;
    }

    .content-section.bg-light {
      background: #f9fafb;
    }

    .content-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .content-section h2 {
      font-size: 2.5rem;
      font-weight: 800;
      text-align: center;
      margin-bottom: 1rem;
      color: var(--text-primary);
    }

    .section-intro {
      font-size: 1.2rem;
      text-align: center;
      color: var(--text-secondary);
      margin-bottom: 3rem;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Info Cards */
    .info-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .info-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      padding: 2rem;
      box-shadow: var(--glass-shadow);
      transition: var(--transition);
    }

    .info-card:hover {
      transform: translateY(-4px);
    }

    .info-card .card-icon {
      font-size: 3rem;
      color: var(--primary);
      margin-bottom: 1rem;
    }

    .info-card h3 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }

    /* Services Grid */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .service-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      padding: 2rem;
      box-shadow: var(--glass-shadow);
      transition: var(--transition);
    }

    .service-card:hover {
      transform: translateY(-4px);
    }

    .service-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .service-icon {
      font-size: 2.5rem;
      color: var(--primary);
    }

    .service-header h3 {
      font-size: 1.5rem;
      margin: 0;
    }

    .service-description {
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
    }

    .service-process h4 {
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .process-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .process-list li {
      padding: 0.25rem 0;
      color: var(--text-secondary);
      position: relative;
      padding-left: 1.5rem;
    }

    .process-list li:before {
      content: "check";
      position: absolute;
      left: 0;
      color: var(--primary);
    }

    /* Assets Grid */
    .assets-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .asset-category {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      padding: 1.5rem;
      box-shadow: var(--glass-shadow);
      transition: var(--transition);
    }

    .asset-category:hover {
      transform: translateY(-4px);
    }

    .category-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .category-icon {
      font-size: 2rem;
      color: var(--primary);
    }

    .category-header h3 {
      font-size: 1.3rem;
      margin: 0;
    }

    .assets-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .assets-list li {
      padding: 0.5rem 0;
      border-bottom: 1px solid #e5e7eb;
    }

    .assets-list li:last-child {
      border-bottom: none;
    }

    /* Process Steps */
    .process-steps {
      margin-top: 3rem;
    }

    .process-step {
      display: flex;
      gap: 2rem;
      margin-bottom: 2rem;
      align-items: flex-start;
    }

    .step-number {
      width: 60px;
      height: 60px;
      background: var(--primary);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-weight: 800;
      flex-shrink: 0;
    }

    .step-content h3 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    /* Value Options */
    .value-options {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .value-option {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      padding: 2rem;
      box-shadow: var(--glass-shadow);
      transition: var(--transition);
    }

    .value-option:hover {
      transform: translateY(-4px);
    }

    .option-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .option-header h3 {
      font-size: 1.5rem;
      margin: 0;
    }

    .option-value {
      background: var(--primary);
      color: white;
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-weight: 600;
    }

    .option-benefits {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0 0;
    }

    .option-benefits li {
      padding: 0.5rem 0;
      border-bottom: 1px solid #e5e7eb;
      position: relative;
      padding-left: 1.5rem;
    }

    .option-benefits li:before {
      content: "check";
      position: absolute;
      left: 0;
      color: var(--primary);
    }

    /* Compliance Grid */
    .compliance-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .compliance-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      padding: 2rem;
      box-shadow: var(--glass-shadow);
      transition: var(--transition);
      text-align: center;
    }

    .compliance-card:hover {
      transform: translateY(-4px);
    }

    .compliance-icon {
      font-size: 3rem;
      color: var(--primary);
      margin-bottom: 1rem;
    }

    .compliance-card h3 {
      font-size: 1.3rem;
      margin-bottom: 1rem;
    }

    /* FAQ Section */
    .faq-list {
      margin-top: 2rem;
    }

    .faq-item {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius);
      margin-bottom: 1rem;
      overflow: hidden;
    }

    .faq-question {
      padding: 1.5rem;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
    }

    .faq-question h3 {
      margin: 0;
    }

    .faq-toggle {
      font-size: 1.5rem;
      color: var(--primary);
      transition: var(--transition);
    }

    .faq-item.active .faq-toggle {
      transform: rotate(45deg);
    }

    .faq-answer {
      padding: 0 1.5rem 1.5rem;
      color: var(--text-secondary);
      display: none;
    }

    .faq-item.active .faq-answer {
      display: block;
    }

    /* Final CTA */
    .final-cta {
      padding: 5rem 1rem;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      color: white;
      text-align: center;
    }

    .cta-content h2 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: white;
    }

    .cta-content p {
      font-size: 1.2rem;
      margin-bottom: 2rem;
      opacity: 0.95;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero-title {
        font-size: 2.5rem;
      }

      .hero-description {
        font-size: 1.1rem;
      }

      .content-section h2 {
        font-size: 2rem;
      }

      .process-step {
        flex-direction: column;
        text-align: center;
      }

      .step-number {
        margin: 0 auto 1rem;
      }

      .sticky-cta-bar {
        padding: 0.75rem 1rem;
      }

      .cta-container {
        flex-direction: column;
      }

      .cta-button {
        width: 100%;
        justify-content: center;
      }

      .alert-content {
        flex-direction: column;
        text-align: center;
      }
    }
  </style>

  <script>
    // FAQ Toggle
    document.querySelectorAll('.faq-question').forEach(question => {
      question.addEventListener('click', () => {
        const faqItem = question.parentElement;
        const isActive = faqItem.classList.contains('active');
        
        // Close all FAQ items
        document.querySelectorAll('.faq-item').forEach(item => {
          item.classList.remove('active');
        });
        
        // Open clicked item if it wasn't active
        if (!isActive) {
          faqItem.classList.add('active');
        }
      });
    });

    // Booking Modal (placeholder)
    function openBookingModal() {
      // In production, this would open a booking modal
      window.location.href = 'tel:+917500555454';
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });

    // Add scroll effect to sticky CTA
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const currentScroll = window.pageYOffset;
      const ctaBar = document.querySelector('.sticky-cta-bar');
      
      if (ctaBar) {
        if (currentScroll > lastScroll && currentScroll > 500) {
          // Scrolling down
          ctaBar.style.transform = 'translateY(100%)';
        } else {
          // Scrolling up
          ctaBar.style.transform = 'translateY(0)';
        }
      }
      
      lastScroll = currentScroll;
    });
  </script>
</BaseLayout>
