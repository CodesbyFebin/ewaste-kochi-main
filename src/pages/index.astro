.chat-msg.user{background:var(--green);color:#000;align-self:flex-end;border-radius:12px 12px 4px 12px;font-weight:500}
.chat-chips{padding:.5rem 1rem;display:flex;flex-wrap:wrap;gap:.4rem;border-top:1px solid var(--border)}
.chip{font-size:.75rem;padding:.3rem .65rem;border:1px solid var(--border2);border-radius:20px;cursor:pointer;color:var(--text2);background:transparent;transition:all .15s;font-family:var(--font-body)}
.chip:hover{border-color:var(--green);color:var(--green)}
.chat-input-row{padding:.75rem;border-top:1px solid var(--border);display:flex;gap:.5rem}
#chat-input{flex:1;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:.6rem .9rem;color:var(--text1);font-family:var(--font-body);font-size:.88rem;outline:none;transition:border-color .2s}
#chat-input:focus{border-color:var(--green)}
#chat-send{background:var(--green);color:#000;border:none;border-radius:8px;padding:.6rem .9rem;cursor:pointer;font-size:1rem;transition:background .2s}
