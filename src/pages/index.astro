    "aggregateRating": {
      "@type":"AggregateRating",
      "ratingValue":"4.9",
      "reviewCount":"312",
      "bestRating":"5",
      "worstRating":"1",
      "author": {
        "@type": "Organization",
        "name": "EWaste Kochi"
      }
    },
    "hasOfferCatalog": {
      "@type":"OfferCatalog",
      "name":"E-Waste & ITAD Services",
      "itemListElement": [
        {"@type":"Offer","itemOffered":{"@type":"Service","name":"E-Waste Recycling Kochi","serviceType":"E-Waste Recycling","areaServed":"Kochi","url":"https://ewastekochi.com/services/e-waste-recycling-kochi"}},
        {"@type":"Offer","itemOffered":{"@type":"Service","name":"ITAD Services Kochi","serviceType":"IT Asset Disposition","areaServed":"Kochi","url":"https://ewastekochi.com/services/itad-services-kochi"}},
        {"@type":"Offer","itemOffered":{"@type":"Service","name":"Data Destruction Kochi","serviceType":"Data Destruction","areaServed":"Kochi","url":"https://ewastekochi.com/services/data-destruction-kochi"}},
