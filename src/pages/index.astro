      "latitude": 9.9312,
      "longitude": 76.3090
    },
    "areaServed": [
      {"@type":"City","name":"Kochi"},
      {"@type":"AdministrativeArea","name":"Ernakulam"},
      {"@type":"AdministrativeArea","name":"Kerala"}
    ],
