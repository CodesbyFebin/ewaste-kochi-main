  <script>
    // Theme Toggle Function
    function toggleTheme() {
      const html = document.documentElement;
      const currentTheme = html.getAttribute('data-theme');
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      
      html.setAttribute('data-theme', newTheme);
      localStorage.setItem('ew-theme', newTheme);
      
      // Update aria-label
      const themeToggle = document.querySelector('.theme-toggle');
      themeToggle.setAttribute('aria-label', `Switch to ${newTheme === 'dark' ? 'light' : 'dark'} mode`);
    }

    // Language Switcher
    function toggleLanguageSwitcher() {
      const dropdown = document.getElementById('langDropdown');
      dropdown.classList.toggle('show');
    }

    // Close language dropdown when clicking outside
    document.addEventListener('click', function(event) {
      const langSwitcher = document.querySelector('.language-switcher');
      if (!langSwitcher.contains(event.target)) {
        document.getElementById('langDropdown').classList.remove('show');
      }
    });

    // Chatbot Functions
    function toggleChatbot() {
      const panel = document.getElementById('chatbotPanel');
      panel.classList.toggle('show');
    }

    function sendQuickReply(message) {
      const input = document.getElementById('chatbotInput');
      input.value = message;
      sendChatbotMessage();
    }

    function sendChatbotMessage() {
      const input = document.getElementById('chatbotInput');
      const message = input.value.trim();
      
      if (!message) return;
      
      const messagesContainer = document.getElementById('chatbotMessages');
      
      // Add user message
      const userMessage = document.createElement('div');
      userMessage.className = 'message user';
      userMessage.innerHTML = `<div class="message-content">${message}</div>`;
      messagesContainer.appendChild(userMessage);
      
      // Clear input
      input.value = '';
      
      // Add typing indicator
      const typingIndicator = document.createElement('div');
      typingIndicator.className = 'message bot';
      typingIndicator.innerHTML = `<div class="message-content">...</div>`;
      messagesContainer.appendChild(typingIndicator);
      
      // Scroll to bottom
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
      
      // Simulate bot response (replace with actual API call)
      setTimeout(() => {
        messagesContainer.removeChild(typingIndicator);
        
        const botResponse = document.createElement('div');
        botResponse.className = 'message bot';
        
        // Simple response logic
        let response = 'Thank you for your inquiry. For immediate assistance, please call +91 75005 55454 or visit our contact page.';
        
        if (message.toLowerCase().includes('pickup')) {
          response = 'We offer free e-waste pickup for 10+ devices in Ernakulam district. Call us at +91 75005 55454 to schedule!';
        } else if (message.toLowerCase().includes('price')) {
          response = 'We offer competitive prices for electronics. MacBook Pro M2/M3: Rs 65,000, iPhone 15 Pro Max: Rs 75,000. Call for exact quotes!';
        } else if (message.toLowerCase().includes('itad')) {
          response = 'Our ITAD services include NIST 800-88 data destruction, asset inventory, and compliance documentation. Perfect for corporate clients!';
        } else if (message.toLowerCase().includes('data')) {
          response = 'We provide NIST 800-88 and DoD certified data destruction with serial-numbered certificates issued within 24 hours.';
        }
        
        botResponse.innerHTML = `<div class="message-content">${response}</div>`;
        messagesContainer.appendChild(botResponse);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      }, 1000);
    }

    function handleChatbotKeyPress(event) {
      if (event.key === 'Enter') {
        sendChatbotMessage();
      }
    }

    // Page Reader Functions
    let speechSynthesis = window.speechSynthesis;
    let currentUtterance = null;
    let isReading = false;
    let currentParagraphIndex = 0;
    let paragraphs = [];

    function togglePageReader() {
      const controls = document.getElementById('readerControls');
      controls.classList.toggle('show');
    }

    function getReadableContent() {
      // Get all paragraphs and headings
      return document.querySelectorAll('h1, h2, h3, p, .faq-answer');
    }

    function startReading() {
      if (isReading) {
        pauseReading();
        return;
      }
      
      paragraphs = getReadableContent();
      if (paragraphs.length === 0) return;
      
      isReading = true;
      updatePlayButton();
      
      readNextParagraph();
    }

    function readNextParagraph() {
      if (!isReading || currentParagraphIndex >= paragraphs.length) {
        stopReading();
        return;
      }
      
      const paragraph = paragraphs[currentParagraphIndex];
      const text = paragraph.textContent.trim();
      
      if (!text) {
        currentParagraphIndex++;
        readNextParagraph();
        return;
      }
      
      // Highlight current paragraph
      document.querySelectorAll('.reading-highlight').forEach(el => {
        el.classList.remove('reading-highlight');
      });
      paragraph.classList.add('reading-highlight');
      
      // Update progress
      const progress = ((currentParagraphIndex + 1) / paragraphs.length) * 100;
      document.getElementById('readerProgress').style.width = progress + '%';
      
      // Create utterance
      currentUtterance = new SpeechSynthesisUtterance(text);
      currentUtterance.rate = parseFloat(document.getElementById('readerSpeed').value);
      
      // Try to set Indian English voice
      const voices = speechSynthesis.getVoices();
      const indianVoice = voices.find(voice => voice.lang === 'en-IN');
      if (indianVoice) {
        currentUtterance.voice = indianVoice;
      }
      
      currentUtterance.onend = () => {
        currentParagraphIndex++;
        readNextParagraph();
      };
      
      speechSynthesis.speak(currentUtterance);
    }

    function pauseReading() {
      if (speechSynthesis.speaking) {
        speechSynthesis.pause();
        isReading = false;
        updatePlayButton();
      }
    }

    function stopReading() {
      speechSynthesis.cancel();
      isReading = false;
      currentParagraphIndex = 0;
      updatePlayButton();
      
      // Remove highlights
      document.querySelectorAll('.reading-highlight').forEach(el => {
        el.classList.remove('reading-highlight');
      });
      
      // Reset progress
      document.getElementById('readerProgress').style.width = '0%';
    }

    function toggleReaderPlay() {
      if (isReading) {
        if (speechSynthesis.paused) {
          speechSynthesis.resume();
          isReading = true;
        } else {
          pauseReading();
        }
      } else {
        startReading();
      }
      updatePlayButton();
    }

    function changeReaderSpeed() {
      if (currentUtterance && speechSynthesis.speaking) {
        currentUtterance.rate = parseFloat(document.getElementById('readerSpeed').value);
        speechSynthesis.cancel();
        speechSynthesis.speak(currentUtterance);
      }
    }

    function updatePlayButton() {
      const playBtn = document.getElementById('readerPlayBtn');
      if (isReading && !speechSynthesis.paused) {
        playBtn.textContent = 'Pause';
      } else {
        playBtn.textContent = 'Play';
      }
    }

    // Initialize voices when page loads
    if (speechSynthesis.onvoiceschanged !== undefined) {
      speechSynthesis.onvoiceschanged = () => {
        speechSynthesis.getVoices();
      };
    }

    // Initialize theme from localStorage or system preference
    document.addEventListener('DOMContentLoaded', function() {
      const savedTheme = localStorage.getItem('ew-theme');
      const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      const theme = savedTheme || systemTheme;
      
      document.documentElement.setAttribute('data-theme', theme);
      
      // Update theme toggle aria-label
      const themeToggle = document.querySelector('.theme-toggle');
      themeToggle.setAttribute('aria-label', `Switch to ${theme === 'dark' ? 'light' : 'dark'} mode`);
    });
  </script>
</BaseLayout>
