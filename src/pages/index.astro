<script>
/* THEME TOGGLE */
const themeBtn=document.getElementById('theme-toggle');
function applyTheme(t){
  document.documentElement.setAttribute('data-theme',t);
  localStorage.setItem('ew-theme',t);
  themeBtn.textContent=t==='dark'?'Sun':'Moon';
  themeBtn.setAttribute('aria-label','Switch to '+(t==='dark'?'light':'dark')+' mode');
}
themeBtn.addEventListener('click',()=>{
  applyTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark');
});
applyTheme(document.documentElement.getAttribute('data-theme')||'dark');

/* SCROLL ANIMATIONS */
const io=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target)}});
},{threshold:0.15});
document.querySelectorAll('.fade-up').forEach(el=>io.observe(el));

/* STAT COUNTER */
const io2=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const el=e.target,target=+el.dataset.count;
      if(!target)return;
      let start=0,dur=1600;
      const step=()=>{
        start+=Math.ceil(target/60);
        el.textContent=(start>=target?target:start).toLocaleString('en-IN')+(target===50000?'+':target===2400?'+':'');
        if(start<target)requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
      io2.unobserve(e);
    }
  });
},{threshold:0.5});
document.querySelectorAll('[data-count]').forEach(el=>io2.observe(el));

/* CHATBOT */
const chatBtn=document.getElementById('chat-btn');
const chatPanel=document.getElementById('chat-panel');
const chatClose=document.getElementById('chat-close');
const chatInput=document.getElementById('chat-input');
const chatSend=document.getElementById('chat-send');
const chatMessages=document.getElementById('chat-messages');
let chatHistory=[];

const SYSTEM=`You are the EWaste Kochi assistant - Kerala's #1 certified e-waste recycler. Be helpful, concise (max 3 sentences), and direct.
Key facts:
- KSPCB authorized: KL/EW/628
- Phone: +91 75005 55454  
- Address: 710A Hill Palace Road, Thrippunithura, Kochi, Kerala 682301
- Free pickup: 10+ devices, Ernakulam district. 1-9 devices: 99.
- Same-day slots: Infopark, Smart City, Kakkanad
- NIST 800-88 + DoD certified data destruction
- Certificate of Destruction: free, within 24 hours
- Hours: Mon-Sat 8AM-8PM, Sun 10AM-4PM
Pickup booking intent: capture how many devices, what type, which area of Kochi, then direct to +91 75005 55454.
Language: respond in the same language the user writes in.`;

chatBtn.addEventListener('click',()=>{chatPanel.classList.toggle('open');chatBtn.setAttribute('aria-expanded',chatPanel.classList.contains('open'))});
chatClose.addEventListener('click',()=>{chatPanel.classList.remove('open');chatBtn.setAttribute('aria-expanded','false')});
chatInput.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage()}});
chatSend.addEventListener('click',sendMessage);

function sendChip(text){
  document.getElementById('chat-chips').style.display='none';
  sendMessage(text);
}

function appendMsg(text,role){
  const d=document.createElement('div');
  d.className='chat-msg '+role;
  d.textContent=text;
  chatMessages.appendChild(d);
  chatMessages.scrollTop=chatMessages.scrollHeight;
  return d;
}

function showTyping(){
  const d=document.createElement('div');
  d.className='chat-msg bot';d.id='typing';
  d.innerHTML='<div class="typing"><span></span><span></span><span></span></div>';
  chatMessages.appendChild(d);
  chatMessages.scrollTop=chatMessages.scrollHeight;
}

async function sendMessage(overrideText){
  const text=(overrideText||chatInput.value).trim();
  if(!text)return;
  chatInput.value='';
  appendMsg(text,'user');
  chatHistory.push({role:'user',content:text});
  showTyping();

  try{
    const res=await fetch('/api/chat',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:400,
        system:SYSTEM,
        messages:chatHistory
      })
    });
    const data=await res.json();
    const reply=data.content?.[0]?.text||"I'm sorry, I had trouble connecting. Please call us at +91 75005 55454.";
    document.getElementById('typing')?.remove();
    appendMsg(reply,'bot');
    chatHistory.push({role:'assistant',content:reply});
  }catch{
    document.getElementById('typing')?.remove();
    appendMsg("Sorry, I'm having trouble connecting. Please call +91 75005 55454 or WhatsApp us for immediate help.",'bot');
  }
}

/* LANGUAGE SWITCHER */
document.getElementById('lang-toggle').addEventListener('click',()=>{
  document.getElementById('lang-modal').classList.add('open');
});
document.getElementById('lang-modal').addEventListener('click',e=>{
  if(e.target===document.getElementById('lang-modal'))e.target.classList.remove('open');
});
function setLang(code,name){
  document.getElementById('lang-toggle').textContent=code.toUpperCase();
  document.documentElement.lang=code+'-IN';
  localStorage.setItem('ew-lang',code);
  document.querySelectorAll('.lang-option').forEach(o=>o.classList.remove('active'));
  event.currentTarget.classList.add('active');
  if(code!=='en')window.location.href='/'+code+'/';
  else document.getElementById('lang-modal').classList.remove('open');
}
</script>

<!-- Performance Monitoring -->
  <script type="module">
    // Core Web Vitals monitoring
    const vitals = {};
    
    function logMetric(name, value, rating) {
      vitals[name] = { value, rating, timestamp: Date.now() };
      console.log(`[Performance] ${name}: ${value} (${rating})`);
      
      // Store in localStorage for analysis
      const existing = JSON.parse(localStorage.getItem('ewaste-vitals') || '{}');
      existing[name] = vitals[name];
      localStorage.setItem('ewaste-vitals', JSON.stringify(existing));
      
      // Send to Google Analytics if available
      if (typeof gtag !== 'undefined') {
        gtag('event', name, {
          event_category: 'Web Vitals',
          event_label: rating,
          value: Math.round(name === 'CLS' ? value * 1000 : value),
          non_interaction: true
        });
      }
    }
    
    // Largest Contentful Paint (LCP)
    new PerformanceObserver((list) => {
      const entries = list.getEntries();
      const lastEntry = entries[entries.length - 1];
      logMetric('LCP', lastEntry.startTime, lastEntry.startTime <= 2500 ? 'good' : lastEntry.startTime <= 4000 ? 'needs-improvement' : 'poor');
    }).observe({ entryTypes: ['largest-contentful-paint'] });
    
    // Cumulative Layout Shift (CLS)
    let clsValue = 0;
    new PerformanceObserver((list) => {
      list.getEntries().forEach((entry) => {
        if (!entry.hadRecentInput) {
          clsValue += entry.value;
        }
      });
      logMetric('CLS', clsValue, clsValue <= 0.1 ? 'good' : clsValue <= 0.25 ? 'needs-improvement' : 'poor');
    }).observe({ entryTypes: ['layout-shift'] });
    
    // Interaction to Next Paint (INP)
    new PerformanceObserver((list) => {
      const entries = list.getEntries();
      entries.forEach((entry) => {
        logMetric('INP', entry.duration, entry.duration <= 200 ? 'good' : entry.duration <= 500 ? 'needs-improvement' : 'poor');
      });
    }).observe({ entryTypes: ['event'] });
    
    // First Contentful Paint (FCP)
    new PerformanceObserver((list) => {
      const entries = list.getEntries();
      const fcpEntry = entries.find(entry => entry.name === 'first-contentful-paint');
      if (fcpEntry) {
        logMetric('FCP', fcpEntry.startTime, fcpEntry.startTime <= 1800 ? 'good' : fcpEntry.startTime <= 3000 ? 'needs-improvement' : 'poor');
      }
    }).observe({ entryTypes: ['paint'] });
    
    // Time to First Byte (TTFB)
    const navEntry = performance.getEntriesByType('navigation')[0];
    if (navEntry) {
      const ttfb = navEntry.responseStart - navEntry.requestStart;
      logMetric('TTFB', ttfb, ttfb <= 800 ? 'good' : ttfb <= 1800 ? 'needs-improvement' : 'poor');
    }
    
    // Resource timing analysis
    new PerformanceObserver((list) => {
      list.getEntries().forEach((entry) => {
        if (entry.duration > 1000) {
          console.warn(`[Performance] Slow resource: ${entry.name} - ${entry.duration.toFixed(0)}ms`);
        }
      });
    }).observe({ entryTypes: ['resource'] });
    
    // Make vitals available globally for debugging
    window.ewasteVitals = vitals;
    console.log('Performance monitoring initialized');
  </script>

