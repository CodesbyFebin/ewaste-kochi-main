/* CHATBOT */
#chat-btn{
  position:fixed;bottom:1.5rem;right:1.5rem;z-index:300;
  background:var(--green);color:#000;
  width:56px;height:56px;border-radius:50%;
  border:none;cursor:pointer;font-size:1.4rem;
  box-shadow:0 4px 24px var(--green-glow);
  display:flex;align-items:center;justify-content:center;
  transition:transform .2s,box-shadow .2s;
}
#chat-btn:hover{transform:scale(1.1);box-shadow:0 8px 32px var(--green-glow)}
#chat-btn .pulse{position:absolute;width:100%;height:100%;border-radius:50%;background:var(--green);opacity:.35;animation:pulse 2s ease-out infinite}
@keyframes pulse{0%{transform:scale(1);opacity:.35}100%{transform:scale(1.7);opacity:0}}
#chat-panel{
