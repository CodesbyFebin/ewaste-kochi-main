---
import BaseLayout from '../layouts/BaseLayout.astro';

// Complete E-E-A-T Schema Suite for Maximum Authority
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness", "RecyclingCenter"],
      "@id": "https://ewastekochi.com/#organization",
      "name": "EWaste Kochi",
      "alternateName": ["E-Waste Kochi", "EWasteKochi"],
      "description": "Kerala's #1 KSPCB-certified e-waste recycler and ITAD company in Kochi. NIST 800-88 data destruction, free bulk pickup, Certificate of Destruction for every job.",
      "url": "https://ewastekochi.com",
      "telephone": "+917500555454",
      "email": "info@ewastekochi.com",
      "foundingDate": "2018",
      "inLanguage": ["en-IN", "ml-IN", "hi-IN", "ta-IN"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "710A, Hill Palace Road, Thrippunithura",
        "addressLocality": "Kochi",
        "addressRegion": "Kerala",
        "postalCode": "682301",
        "addressCountry": "IN"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 9.9312,
        "longitude": 76.3090
      },
      "areaServed": [
        {"@type": "City", "name": "Kochi"},
        {"@type": "AdministrativeArea", "name": "Ernakulam"},
        {"@type": "AdministrativeArea", "name": "Kerala"}
      ],
      "openingHoursSpecification": [
        {"@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"], "opens": "08:00", "closes": "20:00"},
        {"@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "10:00", "closes": "16:00"}
      ],
      "hasCredential": [
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "Environmental Authorization", "name": "KSPCB Authorization KL/EW/628", "recognizedBy": {"@type": "Organization", "name": "Kerala State Pollution Control Board"}},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "Data Destruction Standard", "name": "NIST SP 800-88 Certified"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "Regulatory Compliance", "name": "DPDP Act 2023 Compliant"},
        {"@type": "EducationalOccupationalCredential", "credentialCategory": "EPR Registration", "name": "CPCB EPR Registered Recycler"}
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "312",
        "bestRating": "5",
        "worstRating": "1"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "E-Waste & ITAD Services",
        "itemListElement": [
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "E-Waste Recycling Kochi", "serviceType": "E-Waste Recycling", "areaServed": "Kochi", "url": "https://ewastekochi.com/services/e-waste-recycling-kochi"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "ITAD Services Kochi", "serviceType": "IT Asset Disposition", "areaServed": "Kochi", "url": "https://ewastekochi.com/services/itad-services-kochi"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Data Destruction Kochi", "serviceType": "Data Destruction", "areaServed": "Kochi", "url": "https://ewastekochi.com/services/data-destruction-kochi"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Hard Drive Shredding Kochi", "serviceType": "Hard Drive Destruction", "areaServed": "Kochi"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Laptop Buyback Kochi", "serviceType": "Electronics Buyback", "areaServed": "Kochi"}}
        ]
      },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".hero-h1", ".services-section", ".process-section", ".faq-section"]
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "EWaste Kochi",
      "url": "https://ewastekochi.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {"@type": "EntryPoint", "urlTemplate": "https://ewastekochi.com/search?q={search_term_string}"},
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://ewastekochi.com/"}]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {"@type": "Question", "name": "Is e-waste disposal free in Kochi?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. EWaste Kochi offers completely free pickup for 10 or more devices anywhere in Ernakulam district. For 1-9 devices, residential collection is 99. Walk-in drop-off at our Thrippunithura facility is always free."}},
        {"@type": "Question", "name": "Do you provide a Certificate of Destruction?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. A serial-numbered Certificate of Destruction is issued within 24 hours for every job, at no extra cost. This certificate documents NIST 800-88 data sanitization and KSPCB-compliant recycling of all devices."}},
        {"@type": "Question", "name": "What certifications should I look for in an e-waste recycler?", "acceptedAnswer": {"@type": "Answer", "text": "Always verify KSPCB authorization. EWaste Kochi holds KL/EW/628 - one of only three authorized facilities in Ernakulam district. We also provide NIST 800-88 data destruction and DPDP Act 2023 compliance documentation."}},
        {"@type": "Question", "name": "How quickly can you collect e-waste from my office?", "acceptedAnswer": {"@type": "Answer", "text": "Same-day to 48-hour turnaround is standard. We offer 4-hour emergency service for urgent corporate needs. Priority same-day slots are available for Infopark, Smart City, and Kakkanad."}},
        {"@type": "Question", "name": "What is ITAD and do I need it for my business?", "acceptedAnswer": {"@type": "Answer", "text": "ITAD stands for IT Asset Disposition - the certified, auditable process of retiring IT equipment. Any business handling personal or financial data is legally required to use certified ITAD to comply with DPDP Act 2023 and India's E-Waste Rules 2022."}}
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to Recycle E-Waste in Kochi",
      "description": "Simple 4-step certified e-waste recycling process by EWaste Kochi",
      "step": [
        {"@type": "HowToStep", "position": 1, "name": "Book Pickup", "text": "Call, WhatsApp or book online. Same-day slots available for Infopark and Smart City."},
        {"@type": "HowToStep", "position": 2, "name": "Secure Collection", "text": "Our certified team arrives with KSPCB manifest documentation and GPS-tracked secure transport."},
        {"@type": "HowToStep", "position": 3, "name": "NIST Data Destruction", "text": "All storage media wiped using NIST 800-88 certified methods at our Thrippunithura facility."},
        {"@type": "HowToStep", "position": 4, "name": "Certificate Issued", "text": "Serial-numbered Certificate of Destruction delivered within 24 hours. Zero landfill guaranteed."}
      ]
    }
  ]
};
---

<!-- FWOT Prevention - Must be first script -->
<script>
(function(){var t=localStorage.getItem('ew-theme');
if(t){document.documentElement.setAttribute('data-theme',t)}
else if(!window.matchMedia('(prefers-color-scheme:dark)').matches)
{document.documentElement.setAttribute('data-theme','light')}})();
</script>

<!-- AI Crawler Directives -->
<meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1">
<meta name="googlebot" content="index,follow">
<meta name="GPTBot" content="index,follow">
<meta name="ClaudeBot" content="index,follow">
<meta name="PerplexityBot" content="index,follow">
<meta name="anthropic-ai" content="index,follow">

<!-- hreflang Multilingual -->
<link rel="alternate" hreflang="en-IN" href="https://ewastekochi.com/">
<link rel="alternate" hreflang="ml-IN" href="https://ewastekochi.com/ml/">
<link rel="alternate" hreflang="hi-IN" href="https://ewastekochi.com/hi/">
<link rel="alternate" hreflang="ta-IN" href="https://ewastekochi.com/ta/">
<link rel="alternate" hreflang="x-default" href="https://ewastekochi.com/">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:title" content="E-Waste Recycling & ITAD Services in Kochi, Kerala | EWaste Kochi">
<meta property="og:description" content="KSPCB authorized e-waste recycler in Kochi. NIST data destruction, free bulk pickup, Certificate of Destruction for every job.">
<meta property="og:url" content="https://ewastekochi.com/">
<meta property="og:locale" content="en_IN">

<!-- Fonts - Barlow Condensed + Outfit -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;700;900&family=Outfit:wght@300;400;500;600&display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;700;900&family=Outfit:wght@300;400;500;600&display=swap">

<BaseLayout 
  title="E-Waste Recycling & ITAD Services in Kochi, Kerala | EWaste Kochi"
  description="Kerala's #1 certified e-waste recycler & ITAD company in Kochi. KSPCB authorized (KL/EW/628), NIST 800-88 data destruction, DPDP Act 2023 compliant. Free bulk pickup across Ernakulam. Certificate of Destruction every job."
  schema={schema}
>

<style>
/* DESIGN TOKEN SYSTEM - DARK / LIGHT */
:root {
  --bg0: #0a0f0b;
  --bg1: #0f1a11;
  --bg2: #162018;
  --bg3: #1e2d21;
  --text1: #e4f0e7;
  --text2: #8aab90;
  --text3: #527a58;
  --green: #00ff88;
  --green-dim: #00cc6e;
  --green-glow: rgba(0,255,136,0.12);
  --amber: #ffb347;
  --cyan: #00d4ff;
  --border: rgba(0,255,136,0.12);
  --border2: rgba(0,255,136,0.22);
  --card-bg: rgba(22,32,24,0.85);
  --glass: rgba(15,26,17,0.7);
  --r: 14px;
  --r-sm: 8px;
  --font-head: 'Barlow Condensed', sans-serif;
  --font-body: 'Outfit', sans-serif;
  --shadow: 0 4px 32px rgba(0,0,0,0.5);
}
[data-theme="light"] {
  --bg0: #f0f7f2;
  --bg1: #ffffff;
  --bg2: #e8f2ea;
  --bg3: #d6edda;
  --text1: #0a1f0d;
  --text2: #2d5e35;
  --text3: #5a8c62;
  --green: #007a3d;
  --green-dim: #006030;
  --green-glow: rgba(0,122,61,0.1);
  --amber: #b36200;
  --cyan: #005f8a;
  --border: rgba(0,100,50,0.15);
  --border2: rgba(0,100,50,0.3);
  --card-bg: rgba(255,255,255,0.9);
  --glass: rgba(240,247,242,0.85);
  --shadow: 0 4px 24px rgba(0,80,30,0.12);
}

/* RESET */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{
  font-family:var(--font-body);
  background:var(--bg0);
  color:var(--text1);
  line-height:1.65;
  overflow-x:hidden;
  transition:background .3s,color .3s;
}
img{max-width:100%;height:auto;display:block}
a{color:var(--green);text-decoration:none}
a:hover{text-decoration:underline}
ul{list-style:none}

/* TYPOGRAPHY */
h1,h2,h3,h4{font-family:var(--font-head);line-height:1.1;letter-spacing:.01em}
h1{font-size:clamp(2.6rem,6vw,5rem);font-weight:900;text-transform:uppercase}
h2{font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase}
h3{font-size:clamp(1.1rem,2.5vw,1.5rem);font-weight:700}
p{font-size:1rem;color:var(--text2)}

/* LAYOUT */
.container{max-width:1200px;margin:0 auto;padding:0 1.5rem}
section{padding:5rem 0}
.grid-2{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem}
.grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem}
.grid-4{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem}
.grid-5{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem}

/* CARDS */
.card{
  background:var(--card-bg);
  border:1px solid var(--border);
  border-radius:var(--r);
  padding:1.5rem;
  backdrop-filter:blur(12px);
  transition:border-color .25s,transform .25s,box-shadow .25s;
}
.card:hover{border-color:var(--border2);transform:translateY(-3px);box-shadow:0 8px 40px var(--green-glow)}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:.4rem;font-size:.72rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;padding:.3rem .75rem;border-radius:4px}
.badge-green{background:rgba(0,255,136,.1);color:var(--green);border:1px solid rgba(0,255,136,.25)}
.badge-amber{background:rgba(255,179,71,.1);color:var(--amber);border:1px solid rgba(255,179,71,.25)}
.badge-cyan{background:rgba(0,212,255,.1);color:var(--cyan);border:1px solid rgba(0,212,255,.25)}
[data-theme="light"] .badge-green{background:rgba(0,122,61,.1);color:var(--green)}
[data-theme="light"] .badge-amber{background:rgba(179,98,0,.1);color:var(--amber)}
[data-theme="light"] .badge-cyan{background:rgba(0,95,138,.1);color:var(--cyan)}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--font-head);font-size:1rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:.75rem 1.75rem;border-radius:var(--r-sm);border:none;cursor:pointer;transition:all .2s;text-decoration:none!important}
.btn-primary{background:var(--green);color:#000}
.btn-primary:hover{background:var(--green-dim);transform:translateY(-2px)}
.btn-secondary{background:transparent;color:var(--green);border:1.5px solid var(--green)}
.btn-secondary:hover{background:var(--green-glow)}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border2)}
.btn-ghost:hover{color:var(--text1);border-color:var(--green)}

/* NAV */
#nav{
  position:sticky;top:0;z-index:100;
  background:var(--glass);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  transition:background .3s;
}
.nav-inner{display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.5rem;max-width:1200px;margin:0 auto;gap:1rem}
.nav-logo{font-family:var(--font-head);font-size:1.4rem;font-weight:900;color:var(--text1);letter-spacing:.05em;text-decoration:none!important}
.nav-logo span{color:var(--green)}
.nav-links{display:flex;gap:1.75rem;align-items:center}
.nav-links a{font-size:.85rem;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--text2);transition:color .2s}
.nav-links a:hover{color:var(--green);text-decoration:none}
.nav-right{display:flex;align-items:center;gap:.75rem}
.theme-btn{background:transparent;border:1px solid var(--border2);border-radius:6px;cursor:pointer;padding:.4rem .5rem;color:var(--text2);font-size:1rem;transition:all .2s;line-height:1}
.theme-btn:hover{color:var(--green);border-color:var(--green)}
.lang-btn{font-size:.75rem;font-weight:600;letter-spacing:.05em;background:transparent;border:1px solid var(--border2);border-radius:6px;padding:.4rem .65rem;color:var(--text2);cursor:pointer;font-family:var(--font-body);transition:all .2s}
.lang-btn:hover{border-color:var(--green);color:var(--green)}
.nav-hamburger{display:none;background:transparent;border:none;cursor:pointer;padding:.4rem;color:var(--text2);font-size:1.4rem}

/* HERO */
#hero{
  position:relative;min-height:85vh;display:flex;align-items:center;
  padding:4rem 0 2rem;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;z-index:0;
  background:
    radial-gradient(ellipse 60% 50% at 70% 40%, rgba(0,255,136,.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 20% 80%, rgba(0,212,255,.04) 0%, transparent 60%);
}
.hero-grid-lines{
  position:absolute;inset:0;z-index:0;
  background-image:
    linear-gradient(rgba(0,255,136,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,255,136,.04) 1px, transparent 1px);
  background-size:60px 60px;
}
.hero-inner{position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;max-width:1200px;margin:0 auto;padding:0 1.5rem}
.hero-eyebrow{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.25rem}
.hero-h1{margin-bottom:1rem}
.hero-h1 .accent{color:var(--green)}
.hero-sub{font-size:1.05rem;color:var(--text2);max-width:520px;margin-bottom:2rem;line-height:1.7}
.hero-ctas{display:flex;flex-wrap:wrap;gap:.75rem;margin-bottom:2rem}
.hero-trust{display:flex;flex-wrap:wrap;gap:.5rem}
.hero-stats{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.stat-card{
  background:var(--card-bg);border:1px solid var(--border);border-radius:var(--r);
  padding:1.25rem;backdrop-filter:blur(12px);text-align:center;
}
.stat-num{font-family:var(--font-head);font-size:2.2rem;font-weight:900;color:var(--green);line-height:1}
.stat-label{font-size:.8rem;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;margin-top:.3rem}

/* SERVICES */
.service-card{
  background:var(--card-bg);border:1px solid var(--border);border-radius:var(--r);
  padding:1.5rem;backdrop-filter:blur(12px);
  transition:all .25s;display:flex;flex-direction:column;gap:.75rem;
}
.service-card:hover{border-color:var(--green);transform:translateY(-4px);box-shadow:0 12px 40px var(--green-glow)}
.service-icon{font-size:1.6rem;width:2.8rem;height:2.8rem;display:flex;align-items:center;justify-content:center;background:var(--green-glow);border-radius:10px;border:1px solid var(--border2)}
.service-card h3{font-size:1.1rem}
.service-card p{font-size:.88rem;flex:1}
.service-link{font-size:.82rem;font-weight:600;color:var(--green);text-transform:uppercase;letter-spacing:.06em;display:flex;align-items:center;gap:.3rem}

/* PROCESS */
.process-steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:0;position:relative}
.process-step{padding:2rem 1.5rem;position:relative;text-align:center;border-right:1px solid var(--border)}
.process-step:last-child{border-right:none}
.step-num{font-family:var(--font-head);font-size:3.5rem;font-weight:900;color:var(--border2);line-height:1;margin-bottom:.75rem}
.step-icon{font-size:1.5rem;margin-bottom:.75rem}
.process-step h3{margin-bottom:.5rem;font-size:1.05rem}

/* LOCATIONS */
.location-card{
  background:var(--card-bg);border:1px solid var(--border);border-radius:var(--r-sm);
  padding:1rem 1.25rem;display:flex;align-items:center;justify-content:space-between;
  transition:all .2s;
}
.location-card:hover{border-color:var(--green);background:var(--green-glow)}
.loc-name{font-weight:600;font-size:.95rem}
.loc-badge{font-size:.7rem;color:var(--green)}

/* BUYBACK */
.buyback-card{
  background:var(--card-bg);border:1px solid var(--border);border-radius:var(--r);
  padding:1.25rem;display:flex;flex-direction:column;gap:.5rem;transition:all .2s;
}
.buyback-card:hover{border-color:var(--amber)}
.buyback-device{font-weight:600;font-size:1rem}
.buyback-price{font-family:var(--font-head);font-size:1.8rem;font-weight:900;color:var(--amber)}
.buyback-note{font-size:.78rem;color:var(--text3)}

/* FAQ */
.faq-group{margin-bottom:2rem}
.faq-group-label{font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--green);margin-bottom:.75rem;padding-left:.5rem;border-left:3px solid var(--green)}
details{border:1px solid var(--border);border-radius:var(--r-sm);margin-bottom:.5rem;overflow:hidden;transition:border-color .2s}
details[open]{border-color:var(--border2)}
summary{
  padding:1rem 1.25rem;cursor:pointer;font-weight:600;font-size:.95rem;
  list-style:none;display:flex;align-items:center;justify-content:space-between;
  background:var(--card-bg);color:var(--text1);
}
summary::-webkit-details-marker{display:none}
summary::after{content:"+";font-size:1.2rem;color:var(--green);transition:transform .2s;font-family:var(--font-head)}
details[open] summary::after{content:"-"}
.faq-body{padding:1rem 1.25rem;background:var(--bg2);font-size:.93rem;color:var(--text2);line-height:1.7}

/* SOCIAL PROOF */
.client-strip{display:flex;flex-wrap:wrap;gap:1rem;align-items:center;justify-content:center}
.client-badge{
  background:var(--card-bg);border:1px solid var(--border);border-radius:var(--r-sm);
  padding:.6rem 1.25rem;font-size:.8rem;font-weight:600;color:var(--text2);letter-spacing:.04em;
}
.review-card{background:var(--card-bg);border:1px solid var(--border);border-radius:var(--r);padding:1.5rem}
.review-stars{color:var(--amber);font-size:1.1rem;letter-spacing:.1em;margin-bottom:.5rem}
.review-text{font-size:.93rem;color:var(--text2);margin-bottom:1rem;font-style:italic}
.review-author{font-size:.82rem;font-weight:600;color:var(--text1)}
.review-company{font-size:.78rem;color:var(--text3)}

/* BLOG SECTION */
.blog-card{background:var(--card-bg);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;transition:all .25s}
.blog-card:hover{border-color:var(--border2);transform:translateY(-3px)}
.blog-img-placeholder{height:160px;background:linear-gradient(135deg,var(--bg2),var(--bg3));display:flex;align-items:center;justify-content:center;font-size:2rem}
.blog-body{padding:1.25rem}
.blog-meta{font-size:.75rem;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.5rem;display:flex;gap:1rem}
.blog-body h3{font-size:1rem;margin-bottom:.5rem;line-height:1.3}
.blog-body p{font-size:.85rem}

/* CERTIFICATE PROOF */
.cert-block{
  background:linear-gradient(135deg,rgba(0,255,136,.05),rgba(0,212,255,.04));
  border:1.5px solid var(--green);border-radius:var(--r);padding:2rem;
  display:flex;gap:2rem;align-items:center;flex-wrap:wrap;
}
.cert-icon{font-size:3rem;flex-shrink:0}
