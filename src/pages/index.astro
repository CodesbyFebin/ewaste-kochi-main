  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [{"@type":"ListItem","position":1,"name":"Home","item":"https://ewastekochi.com/"}]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Is e-waste disposal free in Kochi?","acceptedAnswer":{"@type":"Answer","text":"Yes. EWaste Kochi offers completely free pickup for 10 or more devices anywhere in Ernakulam district. For 1-9 devices, residential collection is 99. Walk-in drop-off at our Thrippunithura facility is always free."}},
