<!-- No Flash of Wrong Theme (FWOT) Script -->
<script>
(function(){var t=localStorage.getItem('ew-theme');if(t){document.documentElement.setAttribute('data-theme',t)}else if(window.matchMedia('(prefers-color-scheme: dark)').matches){document.documentElement.setAttribute('data-theme','dark')}})();
</script>

<!-- AI Crawler Directives -->
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large">
<meta name="googlebot" content="index, follow">
<meta name="GPTBot" content="index, follow">
<meta name="ClaudeBot" content="index, follow">
<meta name="PerplexityBot" content="index, follow">
<meta name="anthropic-ai" content="index, follow">

