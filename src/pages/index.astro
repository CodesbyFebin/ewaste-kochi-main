<!-- Font Preload for Performance -->
<link rel="preload" as="font" type="font/woff2" crossorigin href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap">

