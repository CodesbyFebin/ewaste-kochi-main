  <style>
    /* Enhanced CSS Design System with Dark/Light Theme */
    :root {
      /* Light mode tokens */
      --bg-primary: #ffffff;
      --bg-surface: #f4f7f2;
      --bg-card: #ffffff;
      --text-primary: #0d1a0f;
      --text-secondary: #3d5c42;
      --text-muted: #6b8a7f;
      --accent-green: #00b359;
      --accent-green-hover: #00994d;
      --accent-amber: #e07b00;
      --accent-cyan: #0077a8;
      --accent-cyan-hover: #006699;
      --border: rgba(0,0,0,0.1);
      --border-light: rgba(0,0,0,0.05);
      --glow: rgba(0,179,89,0.15);
      --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      --shadow-hover: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      
      /* Glassmorphism */
      --glass-bg: rgba(255, 255, 255, 0.8);
      --glass-border: rgba(255, 255, 255, 0.2);
      --glass-blur: blur(12px);
      
      /* Component tokens */
      --radius-card: 16px;
      --radius-button: 8px;
      --space-xs: 0.5rem;
      --space-sm: 1rem;
      --space-md: 1.5rem;
      --space-lg: 2rem;
      --space-xl: 3rem;
      
      /* Typography */
      --font-heading: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
    }

    [data-theme="dark"] {
      /* Dark mode tokens */
      --bg-primary: #0a0f0b;
      --bg-surface: #111a12;
      --bg-card: #162018;
      --text-primary: #e0f0e3;
      --text-secondary: #7aaa82;
      --text-muted: #5a7a6f;
      --accent-green: #00ff88;
      --accent-green-hover: #00e67a;
      --accent-amber: #ffb347;
      --accent-cyan: #00d4ff;
      --accent-cyan-hover: #00b8e6;
      --border: rgba(0,255,136,0.15);
      --border-light: rgba(0,255,136,0.08);
      --glow: rgba(0,255,136,0.08);
      --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.2);
      --shadow-hover: 0 10px 15px -3px rgba(0, 0, 0, 0.3), 0 4px 6px -2px rgba(0, 0, 0, 0.2);
      
      /* Glassmorphism dark */
      --glass-bg: rgba(10, 15, 11, 0.8);
      --glass-border: rgba(0, 255, 136, 0.1);
    }

    /* Base Reset */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: var(--font-body);
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Skip to Content */
    .skip-to-content {
      position: absolute;
      top: -40px;
      left: 6px;
      background: var(--accent-green);
      color: var(--bg-primary);
      padding: 8px;
      text-decoration: none;
      border-radius: var(--radius-button);
      z-index: 1000;
    }

    .skip-to-content:focus {
      top: 6px;
    }

    /* Header with Theme Support */
    header {
      background: var(--glass-bg);
      backdrop-filter: var(--glass-blur);
      border-bottom: 1px solid var(--glass-border);
      position: sticky;
      top: 0;
      z-index: 100;
      transition: all 0.3s ease;
    }

    .nav-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: var(--space-sm) var(--space-md);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--accent-green);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: var(--space-xs);
    }

    .logo-icon {
      font-size: 1.2rem;
    }

    .nav-menu {
      display: flex;
      list-style: none;
      gap: var(--space-lg);
      align-items: center;
    }

    .nav-menu a {
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.3s ease;
    }

    .nav-menu a:hover {
      color: var(--accent-green);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: var(--space-md);
    }

    /* Theme Toggle */
    .theme-toggle {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: var(--radius-button);
      padding: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .theme-toggle:hover {
      border-color: var(--accent-green);
      background: var(--accent-green);
      color: var(--bg-primary);
    }

    .sun-icon {
      display: block;
    }

    .moon-icon {
      display: none;
    }

    [data-theme="dark"] .sun-icon {
      display: none;
    }

    [data-theme="dark"] .moon-icon {
      display: block;
    }

    /* Language Switcher */
    .language-switcher {
      position: relative;
    }

    .lang-btn {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: var(--radius-button);
      padding: 8px 12px;
      cursor: pointer;
      font-size: 0.9rem;
      transition: all 0.3s ease;
    }

    .lang-btn:hover {
      border-color: var(--accent-green);
      color: var(--accent-green);
    }

    .lang-dropdown {
      position: absolute;
      top: 100%;
      right: 0;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-card);
      padding: var(--space-sm);
      margin-top: var(--space-xs);
      display: none;
      min-width: 120px;
      box-shadow: var(--shadow-card);
    }

    .lang-dropdown.show {
      display: block;
    }

    .lang-option {
      display: block;
      padding: var(--space-xs);
      color: var(--text-primary);
      text-decoration: none;
      border-radius: var(--radius-button);
      transition: background-color 0.3s ease;
    }

    .lang-option:hover {
      background: var(--bg-surface);
    }

    .cta-button {
      background: var(--accent-green);
      color: var(--bg-primary);
      padding: var(--space-xs) var(--space-md);
      border-radius: var(--radius-card);
      text-decoration: none;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .cta-button:hover {
      background: var(--accent-green-hover);
      transform: translateY(-1px);
    }

    /* Container */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: var(--space-lg) var(--space-md);
    }

    /* Hero Section */
    .hero {
      padding: var(--space-xl) 0;
      text-align: center;
      background: radial-gradient(ellipse at top, var(--accent-green) 5%, transparent 50%),
                  linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-surface) 100%);
      transition: all 0.3s ease;
    }

    .hero-title {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: var(--space-sm);
      background: linear-gradient(135deg, var(--accent-green), var(--accent-cyan));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-subheading {
      font-size: 1.2rem;
      color: var(--text-secondary);
      margin-bottom: var(--space-lg);
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      display: flex;
      gap: var(--space-md);
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: var(--space-lg);
    }

    .trust-badges {
      display: flex;
      gap: var(--space-sm);
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: var(--space-lg);
    }

    .badge {
      background: var(--glass-bg);
      backdrop-filter: var(--glass-blur);
      border: 1px solid var(--glass-border);
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-card);
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text-secondary);
      transition: all 0.3s ease;
    }

    .badge:hover {
      border-color: var(--accent-green);
      color: var(--accent-green);
    }

    .stats-bar {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: var(--space-md);
      margin-top: var(--space-lg);
    }

    .stat {
      text-align: center;
      padding: var(--space-md);
