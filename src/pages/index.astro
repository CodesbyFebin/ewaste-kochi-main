      {"@type":"HowToStep","position":3,"name":"NIST Data Destruction","text":"All storage media wiped using NIST 800-88 certified methods at our Thrippunithura facility."},
      {"@type":"HowToStep","position":4,"name":"Certificate Issued","text":"Serial-numbered Certificate of Destruction delivered within 24 hours. Zero landfill guaranteed."}
    ]
  }
