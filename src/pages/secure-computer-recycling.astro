---
// src/pages/secure-computer-recycling.astro — Secure Computer Recycling & Disposal Authority for Kochi
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact.js';

const pageTitle = "Secure Computer Recycling & Disposal — NIST 800-88 Data Destruction | Kochi";
const pageDesc = "Certified secure computer recycling and disposal in Kochi. NIST 800-88 compliant data destruction, DPDP Act 2023 compliance, certified destruction processes, zero data breach risk. Free pickup for businesses across Ernakulam.";

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'Secure Computer Recycling', url: 'https://ewastekochi.com/secure-computer-recycling' },
];

const certifications = [
  { name: 'NIST 800-88', desc: 'National Institute of Standards and Technology media sanitization standard' },
  { name: 'ISO 27001', desc: 'Information Security Management System certification' },
  { name: 'R2v3', desc: 'Responsible Recycling certification for e-waste' },
  { name: 'DPDP Act 2023', desc: 'Digital Personal Data Protection compliance for Kerala businesses' },
];

const destructionProcesses = [
  {
    title: 'Cryptographic Erasure',
    desc: 'Military-grade data wiping using NIST-approved algorithms. All user data is irrecoverably purged before any physical processing.'
  },
  {
    title: 'Physical Destruction',
    desc: 'Industrial-grade shredding of storage media (HDD/SSD) with certified residual verification. 100% material traceability.'
  },
  {
    title: 'Degaussing',
    desc: 'High-intensity magnetic field treatment for magnetic media. Validated per DoD 5220.22-M standards where applicable.'
  },
];

const complianceStandards = [
  { name: 'Data Security', check: '256-bit AES wiping' },
  { name: 'Chain of Custody', check: 'Barcode-tracked from pickup to destruction' },
  { name: 'Audit Trail', check: 'Digital logs with timestamps and operator verification' },
  { name: 'Certificate of Destruction', check: 'Instant PDF delivery within 1 hour of processing' },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  schema={{
    "@type": "ServicePage",
    "name": pageTitle,
    "description": pageDesc,
    "serviceType": "Secure Computer Recycling"
  }}
  breadcrumbs={breadcrumbs}
>
  <Navbar currentPath="/secure-computer-recycling" />

  <!-- Top Security Banner -->
  <div class="security-banner" style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding:40px 0;text-align:center;border-bottom:4px solid var(--blue)">
    <div class="wrap">
      <h1 class="sec-title" style="color:#fff;font-size:2.5rem;margin-bottom:12px">Secure Computer Recycling & Disposal</h1>
      <p class="sec-desc" style="color:#cbd5e1;font-size:1.2rem;max-width:700px;margin:0 auto">NIST 800-88 compliant data destruction processes ensuring zero data breach risk for businesses across Kochi and Ernakulam</p>
    </div>
  </div>

  <section class="section">
    <div class="wrap">
      <div class="two-col-grid">
        <div class="col">
          <h2 class="sec-title" style="font-size:1.8rem">Why Secure Computer Recycling Matters</h2>
          <p class="sec-desc" style="font-size:1.1rem;line-height:1.9;color:var(--text)">
            Improper disposal of computers, laptops, servers, and storage devices creates severe data security risks. Hard drives, SSDs, and memory modules retain sensitive information even after deletion. Our certified secure computer recycling process ensures complete data sanitization and environmental compliance, protecting your business from data breaches, regulatory fines, and reputation damage.
          </p>
          <div class="benefits-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:30px">
            <div style="background:var(--card);padding:24px;border-radius:16px;border:1px solid var(--border)">
              <h4 style="color:var(--blue);margin-bottom:12px">✅ Data Security</h4>
              <p style="font-size:.9rem;color:var(--text);line-height:1.7">Military-grade wiping, NIST 800-88 compliant sanitization, verified destruction certificates</p>
            </div>
            <div style="background:var(--card);padding:24px;border-radius:16px;border:1px solid var(--border)">
              <h4 style="color:var(--blue);margin-bottom:12px">🌱 Environmental Compliance</h4>
              <p style="font-size:.9rem;color:var(--text);line-height:1.7">R2v3 certified e-waste handling, responsible recycling, zero landfill disposal</p>
            </div>
          </div>
        </div>
        <div class="col" style="display:flex;align-items:center">
          <div style="width:100%;background:var(--surface);border-radius:20px;padding:40px;border:1px solid var(--border)">
            <h3 style="color:var(--blue);margin-bottom:20px;font-size:1.3rem">📋 Certified Destruction Processes</h3>
            {destructionProcesses.map(proc => (
              <div style="margin-bottom:24px">
                <h4 style="color:#fff;margin-bottom:8px">{proc.title}</h4>
                <p style="font-size:.95rem;color:var(--muted);line-height:1.6">{proc.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Compliance & Standards Section -->
  <section class="section-alt">
    <div class="wrap">
      <h2 class="sec-title" style="text-align:center;margin-bottom:50px">Compliance Standards & Certifications</h2>
      <div class="cert-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:30px">
        {certifications.map(cert => (
          <div style="background:var(--card);padding:30px;border-radius:16px;border:1px solid var(--border);text-align:center">
            <h4 style="color:var(--blue);margin-bottom:12px;font-size:1.1rem">{cert.name}</h4>
            <p style="font-size:.9rem;color:var(--text);line-height:1.6">{cert.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Data Security Features -->
  <section class="section">
    <div class="wrap">
      <h2 class="sec-title" style="text-align:center;margin-bottom:40px">🔒 Data Security Features</h2>
      <div class="security-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:30px">
        {complianceStandards.map(standard => (
          <div style="background:var(--card);padding:30px;border-radius:16px;border:1px solid var(--border);text-align:center">
            <div style="font-size:2rem;margin-bottom:16px">🔒</div>
            <h4 style="color:var(--white);margin-bottom:10px">{standard.name}</h4>
            <p style="font-size:.95rem;color:var(--muted);line-height:1.6">{standard.check}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="section-alt" style="background:var(--blue);color:#fff;padding:80px 0;text-align:center">
    <div class="wrap">
      <h2 class="sec-title" style="color:#fff;margin-bottom:20px">Ready to Secure Your Data?</h2>
      <p class="sec-desc" style="color:rgba(255,255,255,0.8);max-width:600px;margin:0 auto 30px">Schedule certified computer recycling with free pickup across Kochi. Get instant Certificate of Destruction.</p>
      <a href={contact.phoneLink} class="btn" style="background:#fff;color:var(--blue);font-weight:800;padding:18px 48px;border-radius:12px;text-decoration:none;box-shadow:0 8px 32px rgba(0,0,0,0.3);display:inline-block;margin:10px">📞 Call for Pickup</a>
      <a href="/contact" class="btn" style="background:transparent;color:#fff;border:2px solid #fff;font-weight:800;padding:18px 48px;border-radius:12px;text-decoration:none;display:inline-block;margin:10px">📝 Online Quote</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .security-banner { margin-bottom: 0; }
  .two-col-grid { display:grid;grid-template-columns:1fr 1fr;gap:60px }
  .col { display:flex;flex-direction:column;gap:20px }
  .cert-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px }
  .security-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px }
  .sec-title { color:var(--white);font-size:1.8rem }
  .sec-desc { color:rgba(255,255,255,0.8);font-size:1.05rem }
  .benefits-grid { margin-top:20px }
  .btn { display:inline-flex;align-items:center;gap:10px;text-decoration:none;font-weight:700;transition:transform .2s;justify-content:center }
  .btn:hover { transform:translateY(-2px) }
  @media (max-width:1024px) {
    .two-col-grid { grid-template-columns:1fr }
    .security-banner { padding:30px 0 }
  }
</style>
