---
// BaseLayout.astro — Master layout for all pages
// Injects schema, meta, fonts, and wraps every page
import { contact } from "../data/contact.js";
import ChatbotWidget from "../components/ChatbotWidget.astro";
import GTM_INIT from "../components/GTM_INIT.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import type { Metadata } from "../types/metadata.js";

interface Props extends Metadata {}

const siteOrigin = "https://ewastekochi.com";
const normalizeUrl = (value: string) => {
  const url = new URL(value, siteOrigin);

  if (
    url.origin === siteOrigin &&
    url.pathname !== "/" &&
    !url.pathname.endsWith("/") &&
    !url.pathname.split("/").pop()?.includes(".")
  ) {
    url.pathname = `${url.pathname}/`;
  }

  return url.toString();
};

const {
  title,
  description,
  canonical = normalizeUrl(Astro.url.pathname),
  ogImage = "/img/ewaste-guide-hero.webp",
  ogImageAlt = "EWaste Kochi certified e-waste recycling, ITAD, and pickup services in Kerala",
  schema,
  faqs = [],
  breadcrumbs = [{ name: "Home", url: "https://ewastekochi.com/" }],
  noIndex = false,
  dateModified = new Date().toISOString().split("T")[0],
  pageType = "website",
  publishedTime,
  keywords,
  chatbotContext = "homepage",
} = Astro.props;

const absoluteCanonical = normalizeUrl(canonical);
const absoluteOgImage = normalizeUrl(ogImage);
const absoluteBreadcrumbs = breadcrumbs.map((crumb) => ({
  ...crumb,
  url: normalizeUrl(crumb.url),
}));
const keywordContent = Array.isArray(keywords) ? keywords.join(", ") : keywords;
const ogType = pageType === "article" ? "article" : "website";

// Build FAQ schema if provided
const faqSchema =
  faqs.length > 0
    ? {
        "@type": "FAQPage",
        mainEntity: faqs.map((f) => ({
          "@type": "Question",
          name: f.q,
          acceptedAnswer: { "@type": "Answer", text: f.a },
        })),
      }
    : null;

// Build full JSON-LD graph
const baseSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness", "RecyclingCenter", "ProfessionalService"],
      "@id": "https://ewastekochi.com/#organization",
      name: "EWaste Kochi",
      alternateName: [
        "EWaste Kochi ITAD",
        "EWasteKochi",
        "Kochi E-Waste Recycling",
      ],
      url: "https://ewastekochi.com/",
      logo: {
        "@type": "ImageObject",
        url: "https://ewastekochi.com/brand/ewastekochi-logo.svg",
        width: 200,
        height: 60,
      },
      image: "https://ewastekochi.com/img/ewaste-guide-hero.webp",
      telephone: contact.phone,
      email: contact.email,
      foundingDate: contact.founded,
      address: {
        "@type": "PostalAddress",
        streetAddress: contact.address.street,
        addressLocality: contact.address.city,
        addressRegion: "Kerala",
        postalCode: contact.address.pincode,
        addressCountry: "IN",
      },
      founder: { "@id": "https://ewastekochi.com/#founder" },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 9.939,
        longitude: 76.359,
      },
      openingHoursSpecification: [
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday",
          ],
          opens: "00:00",
          closes: "23:59",
        },
      ],
      sameAs: Object.values(contact.social),
    },
    {
      "@type": "Person",
      "@id": "https://ewastekochi.com/#founder",
      name: "Febin Francis",
      jobTitle: "Founder & Operations Director",
      url: "https://ewastekochi.com/about-us/",
      sameAs: ["https://linkedin.com/in/febin-francis"],
      worksFor: { "@id": "https://ewastekochi.com/#organization" },
    },
    {
      "@type": "WebSite",
      "@id": "https://ewastekochi.com/#website",
      url: "https://ewastekochi.com/",
      name: "EWaste Kochi",
      publisher: { "@id": "https://ewastekochi.com/#organization" },
    },
    {
      "@type": "WebPage",
      "@id": `${absoluteCanonical}#webpage`,
      url: absoluteCanonical,
      name: title,
      description,
      isPartOf: { "@id": "https://ewastekochi.com/#website" },
      dateModified,
      inLanguage: "en-IN",
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: absoluteBreadcrumbs.map((crumb, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: crumb.name,
        item: crumb.url,
      })),
    },
    ...(faqSchema ? [faqSchema] : []),
    ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
  ],
};
---

<!doctype html>
<html lang="en-IN" itemscope itemtype="https://schema.org/WebPage">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0"
    />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywordContent ? <meta name="keywords" content={keywordContent} /> : null}
    <meta
      name="robots"
      content={noIndex
        ? "noindex, nofollow"
        : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />
    <meta name="author" content="EWaste Kochi" />
    <meta name="theme-color" content="#050908" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={absoluteCanonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Geo -->
    <meta name="geo.region" content="IN-KL" />
    <meta name="geo.placename" content="Kochi, Ernakulam, Kerala, India" />
    <meta name="geo.position" content="9.9390;76.3590" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={absoluteCanonical} />
    <meta property="og:site_name" content="EWaste Kochi" />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:secure_url" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    {
      pageType === "article" && publishedTime ? (
        <meta property="article:published_time" content={publishedTime} />
      ) : null
    }
    {
      pageType === "article" ? (
        <meta property="article:modified_time" content={dateModified} />
      ) : null
    }

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ewastekochi" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Preconnects & Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Preload critical assets -->
    <link
      rel="preload"
      href="/brand/ewastekochi-logo.svg"
      as="image"
      type="image/svg+xml"
    />
    <link
      rel="preload"
      href="/img/ewaste-guide-hero.webp"
      as="image"
      type="image/webp"
      fetchpriority="high"
    />

    <!-- AI and Search Engine Indexing -->
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1, archive, snippet, odp"
    />
    <meta
      name="googlebot"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1, archive, snippet, odp"
    />
    <meta
      name="bingbot"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1, archive, snippet, odp"
    />
    <meta
      name="slurp"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1, archive, snippet, odp"
    />
    <meta
      name="duckduckbot"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1, archive, snippet, odp"
    />

    <!-- Schema JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />

    <slot name="head" />
    
    <!-- Vercel Speed Insights -->
    <SpeedInsights />
  </head>
  <body>
    <slot />
    <ChatbotWidget pageContext={chatbotContext} />

    <style is:global>
      /* ══════════════════════════════════════════════
       GLOBAL DESIGN SYSTEM — EWaste Kochi 2026
    ══════════════════════════════════════════════ */
      :root {
        --bg: #050908;
        --surface: #080e0a;
        --card: #0b1410;
        --card2: #0f1a14;
        --border: #162018;
        --border2: #1e2e22;
        --green: #00e896;
        --green2: #00c07a;
        --green3: #007a50;
        --lime: #aaff57;
        --amber: #f5a623;
        --red: #ff4757;
        --blue: #00b4ff;
        --white: #ebf5ef;
        --muted: #426052;
        --text: #8ab4a0;
        --font: "Syne", sans-serif;
        --mono: "JetBrains Mono", monospace;
        --serif: "Lora", Georgia, serif;
        --radius: 12px;
        --radius-lg: 18px;

        /* Industrial Authority Theme (Amber) */
        --amber: #F5A623;
        --amber2: #D4891C;
        --bg-wiki: #060809;
        --card-wiki: #0C1014;
        --border-wiki: #161E22;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
        font-size: 16px;
      }
      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text);
        overflow-x: hidden;
        line-height: 1.65;
      }
      a {
        text-decoration: none;
        color: inherit;
      }
      img {
        max-width: 100%;
        display: block;
      }
      button {
        font-family: var(--font);
        cursor: pointer;
      }
      ::-webkit-scrollbar {
        width: 3px;
      }
      ::-webkit-scrollbar-track {
        background: var(--surface);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--green3);
        border-radius: 2px;
      }
      ::selection {
        background: rgba(245, 166, 35, 0.18);
        color: var(--amber);
      }

      /* Authority Ticker (Industrial) */
      #topbar { background: var(--amber); padding: 8px 0; overflow: hidden; z-index: 1000; position: relative; }
      #ticker { display: flex; white-space: nowrap; animation: tick 45s linear infinite; }
      .tb-item { display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem; font-weight: 800; color: #1a0d00; padding: 0 40px; }
      @keyframes tick { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

      /* Layout */
      .wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
      }
      .section {
        padding: 100px 0;
      }
      .section-alt {
        padding: 100px 0;
        background: var(--surface);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .section-tight {
        padding: 64px 0;
      }

      /* Typography */
      h1,
      h2,
      h3,
      h4,
      h5 {
        color: var(--white);
        line-height: 1.1;
        font-weight: 700;
      }
      .sec-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--green);
        margin-bottom: 16px;
      }
      .sec-eyebrow::before {
        content: "";
        width: 28px;
        height: 1.5px;
        background: var(--green);
      }
      .sec-title {
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 800;
        margin-bottom: 0.5rem;
        letter-spacing: -0.03em;
      }
      .sec-title em {
        color: var(--green);
        font-style: normal;
      }
      .sec-sub {
        color: var(--muted);
        max-width: 560px;
        font-size: 0.95rem;
        line-height: 1.8;
      }
      .text-center {
        text-align: center;
      }
      .text-center .sec-sub {
        margin: 0 auto 3.5rem;
      }
      .text-green {
        color: var(--green);
      }

      /* Buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
        cursor: pointer;
        font-family: var(--font);
        font-weight: 700;
        text-decoration: none;
        transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 0.88rem;
        letter-spacing: 0.01em;
        border-radius: var(--radius);
      }
      .btn-primary {
        background: var(--green);
        color: #051008;
        padding: 14px 28px;
        box-shadow: 0 4px 24px rgba(0, 232, 150, 0.2);
      }
      .btn-primary:hover {
        background: var(--green2);
        transform: translateY(-2px);
        box-shadow: 0 8px 36px rgba(0, 232, 150, 0.32);
      }
      .btn-outline {
        background: transparent;
        border: 1.5px solid rgba(0, 232, 150, 0.4);
        color: var(--green);
        padding: 13px 26px;
      }
      .btn-outline:hover {
        background: rgba(0, 232, 150, 0.06);
        border-color: var(--green);
        transform: translateY(-1px);
      }
      .btn-wa {
        background: #25d366;
        color: #fff;
        padding: 14px 28px;
        box-shadow: 0 4px 20px rgba(37, 211, 102, 0.2);
      }
      .btn-wa:hover {
        background: #1fb855;
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(37, 211, 102, 0.32);
      }
      .btn-lg {
        padding: 16px 36px;
        font-size: 0.95rem;
        border-radius: 14px;
      }
      .btn-sm {
        padding: 9px 18px;
        font-size: 0.8rem;
      }

      /* Badges */
      .badge {
        display: inline-flex;
        align-items: center;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 16px;
      }
      .badge-g {
        background: rgba(0, 232, 150, 0.1);
        color: var(--green);
        border: 1px solid rgba(0, 232, 150, 0.18);
      }
      .badge-a {
        background: rgba(245, 166, 35, 0.1);
        color: var(--amber);
        border: 1px solid rgba(245, 166, 35, 0.18);
      }
      .badge-b {
        background: rgba(0, 180, 255, 0.1);
        color: var(--blue);
        border: 1px solid rgba(0, 180, 255, 0.18);
      }
      .badge-r {
        background: rgba(255, 71, 87, 0.1);
        color: var(--red);
        border: 1px solid rgba(255, 71, 87, 0.18);
      }

      /* FAQ */
      .faq-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-width: 820px;
        margin: 0 auto;
      }
      .faq-item {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        transition: border-color 0.2s;
      }
      .faq-item.open {
        border-color: rgba(0, 232, 150, 0.22);
      }
      .faq-q {
        width: 100%;
        background: none;
        border: none;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        text-align: left;
        gap: 16px;
      }
      .faq-qt {
        font-size: 0.93rem;
        font-weight: 700;
        color: var(--white);
        flex: 1;
      }
      .faq-ic {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: rgba(0, 232, 150, 0.09);
        border: 1px solid rgba(0, 232, 150, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--green);
        flex-shrink: 0;
        font-size: 1rem;
        transition: transform 0.25s;
      }
      .faq-item.open .faq-ic {
        transform: rotate(45deg);
      }
      .faq-a {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.38s ease;
      }
      .faq-item.open .faq-a {
        max-height: 400px;
      }
      .faq-at {
        padding: 0 24px 20px;
        font-size: 0.87rem;
        color: var(--text);
        line-height: 1.75;
        border-top: 1px solid var(--border);
        padding-top: 16px;
        font-family: var(--serif);
      }

      /* Responsive */
      @media (max-width: 768px) {
        .section {
          padding: 72px 0;
        }
        .section-alt {
          padding: 72px 0;
        }
      }
    </style>

    <script>
      // FAQ accordion
      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".faq-q").forEach((btn) => {
          btn.addEventListener("click", () => {
            const item = btn.closest(".faq-item");
            const isOpen = item.classList.contains("open");
            document
              .querySelectorAll(".faq-item.open")
              .forEach((i) => i.classList.remove("open"));
            if (!isOpen) item.classList.add("open");
          });
        });
      });
    </script>
  </body>
</html>
