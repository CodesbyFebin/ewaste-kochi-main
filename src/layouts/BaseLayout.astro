---
// BaseLayout.astro - EWaste Kochi
// Full SEO: dynamic schema, canonical, OG, Twitter, hreflang, AI-indexing meta
// Covers: LocalBusiness, Service, BlogPosting, FAQPage, BreadcrumbList, HowTo, Product

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface HowToStep {
  name: string;
  text: string;
}

interface Props {
  // Core
  title: string;
  description: string;
  canonical?: string;

  // Page type
  pageType?: 'website' | 'service' | 'blog' | 'location' | 'faq' | 'product' | 'how-to';

  // OG / Social
  ogImage?: string;
  ogType?: 'website' | 'article';
  articleDate?: string;
  articleModified?: string;
  articleAuthor?: string;

  // Schema extras
  breadcrumbs?: BreadcrumbItem[];
  faqs?: FaqItem[];
  howToSteps?: HowToStep[];
  serviceName?: string;
  serviceDescription?: string;
  serviceArea?: string[];
  productName?: string;
  productDescription?: string;
  productPrice?: string;

  // Location
  locationName?: string;
  locationSlug?: string;

  // Robots
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  pageType = 'website',
  ogImage = '/og-default.jpg',
  ogType = 'website',
  articleDate,
  articleModified,
  articleAuthor = 'EWaste Kochi',
  breadcrumbs,
  faqs,
  howToSteps,
  serviceName,
  serviceDescription,
  serviceArea = ['Kochi', 'Ernakulam', 'Kakkanad', 'Kerala'],
  productName,
  productDescription,
  productPrice,
  locationName,
  locationSlug,
  noindex = false,
} = Astro.props;

const SITE_URL = 'https://www.ewastekochi.com';
const currentPath = Astro.url.pathname;
const canonicalURL = canonical || `${SITE_URL}${currentPath}`;
const fullOgImage = ogImage && ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage || '/images/og-default.jpg'}`;

// Organisation schema (always present)
const orgSchema = {
  "@type": "Organization",
  "@id": `${SITE_URL}/#organization`,
  "name": "EWaste Kochi",
  "alternateName": ["E-Waste Kochi", "EWasteKochi", "EWaste Kochi ITAD"],
  "url": SITE_URL,
  "logo": {
    "@type": "ImageObject",
    "url": `${SITE_URL}/logo.png`,
    "width": 512,
    "height": 512
  },
  "image": `${SITE_URL}/og-default.jpg`,
  "description": "Kerala's most trusted certified e-waste recycling and IT Asset Disposition company. KSPCB authorized (KL/EW/628), EPR compliant, NIST 800-88 certified data destruction.",
  "telephone": "+91-75005-55454",
  "email": "info@ewastekochi.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "710A, Hill Palace Road",
    "addressLocality": "Thrippunithura",
    "addressRegion": "Kerala",
    "postalCode": "682301",
    "addressCountry": "IN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 9.9312,
    "longitude": 76.2673
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      "opens": "08:00",
      "closes": "20:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Sunday"],
      "opens": "10:00",
      "closes": "16:00"
    }
  ],
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": "+91-75005-55454",
      "contactType": "customer service",
      "areaServed": "IN",
      "availableLanguage": ["English", "Malayalam", "Hindi", "Tamil"],
      "hoursAvailable": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      }
    },
    {
      "@type": "ContactPoint",
      "telephone": "+91-75005-55454",
      "contactType": "sales",
      "areaServed": "IN"
    }
  ],
  "sameAs": [
    "https://www.facebook.com/ewastekochi",
    "https://www.instagram.com/ewastekochi",
    "https://www.linkedin.com/company/ewastekochi",
    "https://twitter.com/ewastekochi",
    "https://maps.app.goo.gl/QgrapT2UYUBPVy4Z9"
  ],
  "hasCredential": [
    {
      "@type": "EducationalOccupationalCredential",
      "name": "KSPCB Authorization",
      "credentialCategory": "Environmental Compliance",
      "recognizedBy": {
        "@type": "Organization",
        "name": "Kerala State Pollution Control Board"
      },
      "identifier": "KL/EW/628"
    },
    {
      "@type": "EducationalOccupationalCredential",
      "name": "EPR Registration",
      "credentialCategory": "Extended Producer Responsibility",
      "recognizedBy": {
        "@type": "Organization",
        "name": "Central Pollution Control Board, India"
      }
    }
  ]
};

// LocalBusiness schema
const localBusinessSchema = {
  "@type": ["LocalBusiness", "RecyclingCenter", "EnvironmentalService"],
  "@id": `${SITE_URL}/#localbusiness`,
  "name": "EWaste Kochi",
  "description": orgSchema.description,
  "url": SITE_URL,
  "telephone": "+91-75005-55454",
  "email": "info@ewastekochi.com",
  "image": orgSchema.image,
  "logo": orgSchema.logo,
  "address": orgSchema.address,
  "geo": orgSchema.geo,
  "openingHoursSpecification": orgSchema.openingHoursSpecification,
  "priceRange": "Rs",
  "currenciesAccepted": "INR",
  "paymentAccepted": "Cash, Credit Card, UPI, Bank Transfer, NEFT, RTGS",
  "areaServed": [
    { "@type": "City", "name": "Kochi" },
    { "@type": "City", "name": "Ernakulam" },
    { "@type": "State", "name": "Kerala" },
    { "@type": "Country", "name": "India" }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "E-Waste & ITAD Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "E-Waste Recycling Kochi" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ITAD Services Kochi" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Data Destruction Kochi" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Hard Drive Shredding Kochi" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Laptop Buyback Kochi" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Battery Recycling Kochi" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Free E-Waste Pickup Kochi" }}
    ]
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "247",
    "bestRating": "5",
    "worstRating": "1"
  },
  "sameAs": orgSchema.sameAs
};

// WebSite schema (homepage only)
const websiteSchema = currentPath === '/' ? {
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  "url": SITE_URL,
  "name": "EWaste Kochi",
  "description": "Kerala's #1 Certified E-Waste Recycling & ITAD Company",
  "publisher": { "@id": `${SITE_URL}/#organization` },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${SITE_URL}/?q={search_term_string}` 
    },
    "query-input": "required name=search_term_string"
  },
  "inLanguage": "en-IN"
} : null;

// WebPage schema
const webPageSchema = {
  "@type": "WebPage",
  "@id": `${canonicalURL}#webpage`,
  "url": canonicalURL,
  "name": title,
  "description": description,
  "isPartOf": { "@id": `${SITE_URL}/#website` },
  "about": { "@id": `${SITE_URL}/#localbusiness` },
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": fullOgImage
  },
  "inLanguage": "en-IN",
  ...(articleDate && { "datePublished": articleDate }),
  ...(articleModified && { "dateModified": articleModified }),
};

// Service schema
const serviceSchema = pageType === 'service' && serviceName ? {
  "@type": "Service",
  "@id": `${canonicalURL}#service`,
  "name": serviceName || title,
  "description": serviceDescription || description,
  "provider": { "@id": `${SITE_URL}/#organization` },
  "areaServed": serviceArea.map(area => ({ "@type": "City", "name": area })),
  "serviceType": "E-Waste & ITAD Services",
  "termsOfService": `${SITE_URL}/terms/`,
  "url": canonicalURL,
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": serviceName,
    "itemListElement": [
      {
        "@type": "Offer",
        "name": serviceName,
        "description": serviceDescription || description,
        "seller": { "@id": `${SITE_URL}/#organization` }
      }
    ]
  }
} : null;

// BlogPosting schema
const blogSchema = pageType === 'blog' ? {
  "@type": "BlogPosting",
  "@id": `${canonicalURL}#article`,
  "headline": title,
  "description": description,
  "image": {
    "@type": "ImageObject",
    "url": fullOgImage,
    "width": 1200,
    "height": 630
  },
  "author": {
    "@type": "Organization",
    "name": articleAuthor || "EWaste Kochi",
    "@id": `${SITE_URL}/#organization` 
  },
  "publisher": {
    "@type": "Organization",
    "name": "EWaste Kochi",
    "logo": {
      "@type": "ImageObject",
      "url": `${SITE_URL}/logo.png` 
    },
    "@id": `${SITE_URL}/#organization` 
  },
  "datePublished": articleDate || new Date().toISOString().split('T')[0],
  "dateModified": articleModified || articleDate || new Date().toISOString().split('T')[0],
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${canonicalURL}#webpage` },
  "inLanguage": "en-IN",
  "url": canonicalURL,
  "isPartOf": { "@id": `${SITE_URL}/#website` },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".article-summary", ".article-intro"]
  }
} : null;

// FAQPage schema
const faqSchema = faqs && faqs.length > 0 ? {
  "@type": "FAQPage",
  "@id": `${canonicalURL}#faqpage`,
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

// HowTo schema
const howToSchema = howToSteps && howToSteps.length > 0 ? {
  "@type": "HowTo",
  "@id": `${canonicalURL}#howto`,
  "name": title,
  "description": description,
  "step": howToSteps.map((step, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": step.name,
    "text": step.text
  })),
  "totalTime": "PT30M",
  "tool": [
    { "@type": "HowToTool", "name": "EWaste Kochi Certified Pickup" },
    { "@type": "HowToTool", "name": "KSPCB-Authorised Processing" }
  ]
} : null;

// BreadcrumbList schema
const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  "@type": "BreadcrumbList",
  "@id": `${canonicalURL}#breadcrumbs`,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": SITE_URL + "/"
    },
    ...breadcrumbs.map((crumb, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": crumb.name,
      "item": crumb.url && crumb.url.startsWith('http') ? crumb.url : `${SITE_URL}${crumb.url || '/'}` 
    }))
  ]
} : null;

// Product schema
const productSchema = pageType === 'product' && productName ? {
  "@type": "Product",
  "@id": `${canonicalURL}#product`,
  "name": productName,
  "description": productDescription || description,
  "brand": {
    "@type": "Brand",
    "name": "EWaste Kochi"
  },
  "offers": {
    "@type": "Offer",
    "url": canonicalURL,
    "priceCurrency": "INR",
    "price": productPrice || "0",
    "priceValidUntil": new Date(new Date().setFullYear(new Date().getFullYear() + 1)).toISOString().split('T')[0],
    "availability": "https://schema.org/InStock",
    "seller": { "@id": `${SITE_URL}/#organization` }
  }
} : null;

// Build graph
const schemaGraph = [
  orgSchema,
  localBusinessSchema,
  webPageSchema,
  websiteSchema,
  serviceSchema,
  blogSchema,
  faqSchema,
  howToSchema,
  breadcrumbSchema,
  productSchema,
].filter(Boolean);

const schemaJSON = JSON.stringify({ "@context": "https://schema.org", "@graph": schemaGraph });

---

<!DOCTYPE html>
<html lang="en-IN" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Robots -->
  {noindex
    ? <meta name="robots" content="noindex, nofollow" />
    : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  }

  <!-- Geo targeting -->
  <meta name="geo.region"    content="IN-KL" />
  <meta name="geo.placename" content="Kochi, Kerala, India" />
  <meta name="geo.position"  content="9.9312;76.2673" />
  <meta name="ICBM"          content="9.9312, 76.2673" />

  <!-- Language / locale -->
  <link rel="alternate" hreflang="en-IN" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />

  <!-- AI / LLM indexing -->
  <meta name="llms-txt"                content="allow" />
  <meta name="ai-content-declaration"  content="human-quality, factual, local-service, e-waste, kochi, kerala" />

  <!-- Open Graph -->
  <meta property="og:type"         content={ogType} />
  <meta property="og:title"        content={title} />
  <meta property="og:description"  content={description} />
  <meta property="og:url"          content={canonicalURL} />
  <meta property="og:image"        content={fullOgImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"    content={`${title} | EWaste Kochi`} />
  <meta property="og:site_name"    content="EWaste Kochi" />
  <meta property="og:locale"       content="en_IN" />
  {articleDate && <meta property="article:published_time" content={articleDate} />}
  {articleModified && <meta property="article:modified_time" content={articleModified} />}

  <!-- Twitter / X Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@ewastekochi" />
  <meta name="twitter:creator"     content="@ewastekochi" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={fullOgImage} />

  <!-- Verification (update with actual codes) -->
  <meta name="google-site-verification" content="YOUR_ACTUAL_CODE_HERE" />

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Favicon -->
  <link rel="icon"             type="image/svg+xml"  href="/favicon.svg" />
  <link rel="icon"             type="image/png"      href="/favicon.png" sizes="32x32" />
  <link rel="apple-touch-icon"                       href="/apple-touch-icon.png" />
  <link rel="manifest"                               href="/site.webmanifest" />
  <meta name="theme-color"     content="#f5a623" />
  <meta name="msapplication-TileColor" content="#0a0c0f" />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={schemaJSON} />

  <slot name="head" />
</head>

<body>
  <!-- Skip to main content (accessibility) -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-amber-400 focus:text-black focus:font-bold focus:rounded">
    Skip to main content
  </a>

  <slot name="header" />

  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <slot name="footer" />
</body>
</html>
