---
import DynamicBreadcrumbs from '../components/DynamicBreadcrumbs.astro';

interface Props {
  title: string;
  description?: string;
  breadcrumbs?: {
    name: string;
    url?: string;
  }[];
  schema?: any;
  noIndex?: boolean;
  pageType?: 'website' | 'article' | 'service';
  keywords?: string[];
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title,
  description = '',
  breadcrumbs = [],
  schema,
  noIndex = false,
  pageType = 'website',
  keywords,
  canonical,
  ogImage = '/img/ewaste-guide-hero.webp',
  ogImageAlt = title,
} = Astro.props;

const siteOrigin = 'https://ewastekochi.com';
const currentUrl = canonical || new URL(Astro.url.pathname, siteOrigin).toString();
const pageKeywords = keywords.length > 0 ? keywords.join(', ') : title;
---

<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary SEO Meta Tags -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={pageKeywords} />
  <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
  <meta name="author" content="EWaste Kochi" />
  
  <!-- Canonical URL -->
  <link rel="canonical" href={currentUrl} />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={pageType} />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="EWaste Kochi" />
  
  <!-- Twitter Card -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={currentUrl} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImage} />
  <meta property="twitter:image:alt" content={ogImageAlt} />
  <meta name="twitter:site" content="@ewastekochi" />
  
  <!-- Schema.org structured data -->
  {schema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
  )}
  
  <!-- Preload critical assets -->
  <link rel="preload" href="/brand/ewastekochi-logo.svg" as="image" type="image/svg+xml" />
  <link rel="preload" href="/img/ewaste-guide-hero.webp" as="image" fetchpriority="high" />
  
  <!-- Site manifest -->
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  
  <!-- Theme color -->
  <meta name="theme-color" content="#050908" />
  <meta name="format-detection" content="telephone=no" />
  
  <!-- AI crawler support -->
  <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow'} />
  <meta name="googlebot" content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
  <meta name="bingbot" content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
  <meta name="slurp" content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
  <meta name="duckduckbot" content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
</head>
<body>
  <DynamicBreadcrumbs breadcrumbs={breadcrumbs} pageTitle={title} />
  <slot />
</body>
</html>

<style>
  /* Reset and base styles */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; font-size: 16px; }
  body { font-family: var(--font); background: var(--bg); color: var(--text); overflow-x: hidden; line-height: 1.65; }
  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }
  button { font-family: var(--font); cursor: pointer; }
  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-track { background: var(--surface); }
  ::-webkit-scrollbar-thumb { background: var(--green3); border-radius: 2px; }
  ::selection { background: rgba(0, 232, 150, 0.18); color: var(--green); }

  /* Layout */
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .section { padding: 100px 0; }
  .section-alt { padding: 100px 0; background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .section-tight { padding: 64px 0; }

  /* Typography */
  h1, h2, h3, h4, h5 { color: var(--white); line-height: 1.1; font-weight: 700; }
  .sec-eyebrow { display: inline-flex; align-items: center; gap: 10px; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); margin-bottom: 16px; }
  .sec-eyebrow::before { content: ""; width: 28px; height: 1.5px; background: var(--green); }
  .sec-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; margin-bottom: 0.5rem; letter-spacing: -0.03em; }
  .sec-title em { color: var(--green); font-style: normal; }
  .sec-sub { color: var(--muted); max-width: 560px; font-size: 0.95rem; line-height: 1.8; }
  .text-center { text-align: center; }
  .text-center .sec-sub { margin: 0 auto 3.5rem; }
  .text-green { color: var(--green); }

  /* Buttons */
  .btn { display: inline-flex; align-items: center; gap: 8px; border: none; cursor: pointer; font-family: var(--font); font-weight: 700; text-decoration: none; transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1); font-size: 0.88rem; letter-spacing: 0.01em; border-radius: var(--radius); }
  .btn-primary { background: var(--green); color: #051008; padding: 14px 28px; box-shadow: 0 4px 24px rgba(0, 232, 150, 0.2); }
  .btn-primary:hover { background: var(--green2); transform: translateY(-2px); box-shadow: 0 8px 36px rgba(0, 232, 150, 0.32); }
  .btn-outline { background: transparent; border: 1.5px solid rgba(0, 232, 150, 0.4); color: var(--green); padding: 13px 26px; }
  .btn-outline:hover { background: rgba(0, 232, 150, 0.06); border-color: var(--green); transform: translateY(-1px); }
  .btn-wa { background: #25d366; color: #fff; padding: 14px 28px; box-shadow: 0 4px 20px rgba(37, 211, 102, 0.2); }
  .btn-wa:hover { background: #1fb855; transform: translateY(-2px); box-shadow: 0 8px 32px rgba(37, 211, 102, 0.32); }
  .btn-lg { padding: 16px 36px; font-size: 0.95rem; border-radius: 14px; }
  .btn-sm { padding: 9px 18px; font-size: 0.8rem; }

  /* Badges */
  .badge { display: inline-flex; align-items: center; font-size: 0.7rem; font-weight: 600; padding: 3px 9px; border-radius: 16px; }
  .badge-g { background: rgba(0, 232, 150, 0.1); color: var(--green); border: 1px solid rgba(0, 232, 150, 0.18); }
  .badge-a { background: rgba(245, 166, 35, 0.1); color: var(--amber); border: 1px solid rgba(245, 166, 35, 0.18); }
  .badge-b { background: rgba(0, 180, 255, 0.1); color: var(--blue); border: 1px solid rgba(0, 180, 255, 0.18); }
  .badge-r { background: rgba(255, 71, 87, 0.1); color: var(--red); border: 1px solid rgba(255, 71, 87, 0.18); }

  /* FAQ */
  .faq-list { display: flex; flex-direction: column; gap: 10px; max-width: 820px; margin: 0 auto; }
  .faq-item { background: var(--card); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; transition: border-color 0.2s; }
  .faq-item.open { border-color: rgba(0, 232, 150, 0.22); }
  .faq-q { width: 100%; background: none; border: none; padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; text-align: left; gap: 16px; }
  .faq-qt { font-size: 0.93rem; font-weight: 700; color: var(--white); flex: 1; }
  .faq-ic { width: 28px; height: 28px; border-radius: 8px; background: rgba(0, 232, 150, 0.09); border: 1px solid rgba(0, 232, 150, 0.18); display: flex; align-items: center; justify-content: center; color: var(--green); flex-shrink: 0; font-size: 1rem; transition: transform 0.25s; }
  .faq-item.open .faq-ic { transform: rotate(45deg); }
  .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.38s ease; }
  .faq-item.open .faq-a { max-height: 400px; }
  .faq-at { padding: 0 24px 20px; font-size: 0.87rem; color: var(--text); line-height: 1.75; border-top: 1px solid var(--border); padding-top: 16px; font-family: var(--serif); }

  /* Responsive */
  @media (max-width: 768px) {
    .section { padding: 72px 0; }
    .section-alt { padding: 72px 0; }
  }
</style>

<script>
  // FAQ accordion
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".faq-q").forEach((btn) => {
      btn.addEventListener("click", () => {
        const item = btn.closest(".faq-item");
        const isOpen = item.classList.contains("open");
        document.querySelectorAll(".faq-item.open").forEach((i) => i.classList.remove("open"));
        if (!isOpen) item.classList.add("open");
      });
    });
  });
</script>
